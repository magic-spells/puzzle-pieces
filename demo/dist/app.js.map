
import { PuzzleView } from '@magic-spells/puzzle';
import Slider from '@/components/ui/Slider.pzl';
import Label from '@/components/ui/Label.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece slider';
const usageImport = `import Slider from '@/components/ui/Slider.pzl';`;
const usageMarkup = `<Slider value={ volume } min={ 0 } max={ 100 } @input={ setVolume } @change={ setVolume } />`;

const codeHero = `<Slider value={ volume } min={ 0 } max={ 100 } @input={ setVolume } @change={ setVolume } />

// parent — @input fires live during drag, @change on release
events = {
  setVolume: (v) => this.setData('volume', v),
};`;

const codeRange = `// the presence of valueMin / valueMax switches to dual-thumb range mode
<Slider valueMin={ priceMin } valueMax={ priceMax } min={ 0 } max={ 1000 } step={ 10 }
  @input={ setPrice } @change={ setPrice } />

// parent — range callbacks receive { valueMin, valueMax }
events = {
  setPrice: ({ valueMin, valueMax }) => this.setData({ priceMin: valueMin, priceMax: valueMax }),
};`;

const codeSteps = `// a numeric step quantizes to a detent
<Slider value={ stepped } min={ 0 } max={ 100 } step={ 10 } @change={ setStepped } />

// step="any" is continuous
<Slider value={ fine } min={ 0 } max={ 100 } step="any" @change={ setFine } />`;

const codeDisabled = `<Slider value={ 40 } disabled />`;

export default class SliderDoc extends PuzzleView {
  created() {
    this.setData({
      volume: 60,
      priceMin: 200,
      priceMax: 800,
      stepped: 40,
      fine: 33,
    });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeRange,
      codeSteps,
      codeDisabled,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Range', href: '#range' },
        { label: 'Steps', href: '#steps' },
        { label: 'Disabled', href: '#disabled' },
      ],
    };
  }

  events = {
    setVolume: (v) => {
      this.setData('volume', v);
      this.refresh();
    },
    setPrice: ({ valueMin, valueMax }) => {
      this.setData({ priceMin: valueMin, priceMax: valueMax });
      this.refresh();
    },
    setStepped: (v) => {
      this.setData('stepped', v);
      this.refresh();
    },
    setFine: (v) => {
      this.setData('fine', v);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

SliderDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Slider' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A touch-friendly single-value or dual-thumb range slider. It is controlled — the parent owns the value and reads it back from' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@input' }),
            ]),
            new ViewNode('text', { value: '(live during drag) and' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: '(on commit). A focused thumb responds to arrow keys, PageUp / PageDown, and Home / End.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-sm space-y-2' }, [
            new ViewNode('div', { class: 'flex items-center justify-between' }, [
              new ViewNode(Label, {}, [
                new ViewNode('text', { value: 'Volume' }),
              ]),
              new ViewNode('p', { class: 'text-sm text-muted' }, [
                new ViewNode('text', { value: String(__d.volume) }),
              ]),
            ]),
            new ViewNode(Slider, {
              value: __d.volume,
              min: 0,
              max: 100,
              input: ((this.__h ??= {})[0] ??= (event) => this.events.setVolume(event)),
              change: ((this.__h ??= {})[1] ??= (event) => this.events.setVolume(event)),
            }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'range',
            title: 'Range',
            code: __d.codeRange,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm space-y-2' }, [
              new ViewNode('div', { class: 'flex items-center justify-between' }, [
                new ViewNode(Label, {}, [
                  new ViewNode('text', { value: 'Price range' }),
                ]),
                new ViewNode('p', { class: 'text-sm text-muted' }, [
                  new ViewNode('text', { value: '$' + String(__d.priceMin) + ' – $' + String(__d.priceMax) }),
                ]),
              ]),
              new ViewNode(Slider, {
                valueMin: __d.priceMin,
                valueMax: __d.priceMax,
                min: 0,
                max: 1000,
                step: 10,
                input: ((this.__h ??= {})[2] ??= (event) => this.events.setPrice(event)),
                change: ((this.__h ??= {})[3] ??= (event) => this.events.setPrice(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'steps',
            title: 'Steps',
            code: __d.codeSteps,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm space-y-6' }, [
              new ViewNode('div', { class: 'space-y-2' }, [
                new ViewNode('div', { class: 'flex items-center justify-between' }, [
                  new ViewNode(Label, {}, [
                    new ViewNode('text', { value: 'Step 10' }),
                  ]),
                  new ViewNode('p', { class: 'text-sm text-muted' }, [
                    new ViewNode('text', { value: String(__d.stepped) }),
                  ]),
                ]),
                new ViewNode(Slider, {
                  value: __d.stepped,
                  min: 0,
                  max: 100,
                  step: 10,
                  input: ((this.__h ??= {})[4] ??= (event) => this.events.setStepped(event)),
                  change: ((this.__h ??= {})[5] ??= (event) => this.events.setStepped(event)),
                }, []),
              ]),
              new ViewNode('div', { class: 'space-y-2' }, [
                new ViewNode('div', { class: 'flex items-center justify-between' }, [
                  new ViewNode(Label, {}, [
                    new ViewNode('text', { value: 'Continuous (step="any")' }),
                  ]),
                  new ViewNode('p', { class: 'text-sm text-muted' }, [
                    new ViewNode('text', { value: String(__d.fine) }),
                  ]),
                ]),
                new ViewNode(Slider, {
                  value: __d.fine,
                  min: 0,
                  max: 100,
                  step: 'any',
                  input: ((this.__h ??= {})[6] ??= (event) => this.events.setFine(event)),
                  change: ((this.__h ??= {})[7] ??= (event) => this.events.setFine(event)),
                }, []),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'disabled',
            title: 'Disabled',
            code: __d.codeDisabled,
            tall: false,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm space-y-2' }, [
              new ViewNode(Label, {}, [
                new ViewNode('text', { value: 'Disabled' }),
              ]),
              new ViewNode(Slider, {
                value: 40,
                disabled: true,
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
