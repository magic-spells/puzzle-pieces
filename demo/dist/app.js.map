
import { PuzzleView } from '@magic-spells/puzzle';
import StatCard from '../components/ui/StatCard.pzl';
import LineChart from '../components/ui/LineChart.pzl';
import AreaChart from '../components/ui/AreaChart.pzl';
import BarChart from '../components/ui/BarChart.pzl';
import PieChart from '../components/ui/PieChart.pzl';
import ProgressRing from '../components/ui/ProgressRing.pzl';

// Static, deterministic demo data so the dashboard always renders the same.
const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const THIS_YEAR = [98400, 104200, 101800, 110300, 118900, 115200, 124600, 131400, 128900, 137200, 144800, 152300];
const LAST_YEAR = [92100, 96400, 99200, 97800, 105600, 108900, 112400, 110800, 118300, 121700, 125200, 128400];

export default class AnalyticsDemo extends PuzzleView {
  data() {
    return {
      revenueSpark: [98, 104, 102, 110, 119, 115, 125, 131, 129, 137, 145, 152],
      usersSpark: [71, 74, 73, 78, 80, 79, 83, 85, 84, 87, 88, 89],
      conversionSpark: [3.6, 3.5, 3.6, 3.5, 3.4, 3.5, 3.4, 3.4, 3.5, 3.4, 3.4, 3.42],
      aovSpark: [79, 80, 82, 81, 83, 82, 84, 85, 84, 85, 86, 86],
      revenueRows: MONTHS.map((month, i) => ({ month, current: THIS_YEAR[i], previous: LAST_YEAR[i] })),
      revenueSeries: [
        { key: 'current', label: 'This year' },
        { key: 'previous', label: 'Last year' },
      ],
      categoryRows: [
        { category: 'Apparel', online: 4200, store: 2800 },
        { category: 'Footwear', online: 3100, store: 2400 },
        { category: 'Home', online: 2400, store: 1900 },
        { category: 'Outdoor', online: 2100, store: 1200 },
        { category: 'Accessories', online: 1800, store: 900 },
        { category: 'Beauty', online: 1500, store: 1100 },
      ],
      categorySeries: [
        { key: 'online', label: 'Online' },
        { key: 'store', label: 'In-store' },
      ],
      trafficSlices: [
        { label: 'Organic search', value: 4180 },
        { label: 'Direct', value: 2140 },
        { label: 'Social', value: 1690 },
        { label: 'Referral', value: 1210 },
        { label: 'Email', value: 830 },
      ],
      deviceRows: [
        { week: 'W1', desktop: 3200, mobile: 4100, tablet: 700 },
        { week: 'W2', desktop: 3400, mobile: 4300, tablet: 650 },
        { week: 'W3', desktop: 3300, mobile: 4600, tablet: 720 },
        { week: 'W4', desktop: 3600, mobile: 4800, tablet: 680 },
        { week: 'W5', desktop: 3500, mobile: 5100, tablet: 640 },
        { week: 'W6', desktop: 3800, mobile: 5300, tablet: 700 },
        { week: 'W7', desktop: 3700, mobile: 5600, tablet: 660 },
        { week: 'W8', desktop: 3900, mobile: 5900, tablet: 690 },
      ],
      deviceSeries: [
        { key: 'desktop', label: 'Desktop' },
        { key: 'mobile', label: 'Mobile' },
        { key: 'tablet', label: 'Tablet' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

AnalyticsDemo.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-6xl' }, [
      new ViewNode('header', { class: 'mb-8' }, [
        new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
          new ViewNode('text', { value: 'Analytics' }),
        ]),
        new ViewNode('p', { class: 'mt-2 text-body' }, [
          new ViewNode('text', { value: 'Every chart piece working together — stat cards, line, area, bar, and pie charts, and a progress ring, all fed static demo data. Hover any plot for details.' }),
        ]),
      ]),
      new ViewNode('section', {
        'aria-label': 'Key metrics',
        class: 'grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4',
      }, [
        new ViewNode(StatCard, {
          label: 'Revenue',
          value: '$128,430',
          delta: 12.4,
          deltaLabel: 'vs last quarter',
          sparkline: __d.revenueSpark,
        }, []),
        new ViewNode(StatCard, {
          label: 'Active users',
          value: '8,912',
          delta: 3.1,
          deltaLabel: 'vs last quarter',
          sparkline: __d.usersSpark,
        }, []),
        new ViewNode(StatCard, {
          label: 'Conversion rate',
          value: '3.42%',
          delta: -0.4,
          deltaLabel: 'vs last quarter',
          sparkline: __d.conversionSpark,
        }, []),
        new ViewNode(StatCard, {
          label: 'Avg. order value',
          value: '$86.12',
          delta: 5.7,
          deltaLabel: 'vs last quarter',
          sparkline: __d.aovSpark,
        }, []),
      ]),
      new ViewNode('section', { class: 'mt-6 rounded-xl border border-border bg-surface p-6' }, [
        new ViewNode('h2', { class: 'text-sm font-medium text-ink' }, [
          new ViewNode('text', { value: 'Revenue' }),
        ]),
        new ViewNode('p', { class: 'mb-4 text-sm text-muted' }, [
          new ViewNode('text', { value: 'Monthly revenue, this year vs last year' }),
        ]),
        new ViewNode(LineChart, {
          data: __d.revenueRows,
          xKey: 'month',
          series: __d.revenueSeries,
          height: 320,
          label: 'Monthly revenue, this year versus last year',
        }, []),
      ]),
      new ViewNode('div', { class: 'mt-6 grid grid-cols-1 gap-6 lg:grid-cols-3' }, [
        new ViewNode('section', { class: 'rounded-xl border border-border bg-surface p-6 lg:col-span-2' }, [
          new ViewNode('h2', { class: 'text-sm font-medium text-ink' }, [
            new ViewNode('text', { value: 'Sales by category' }),
          ]),
          new ViewNode('p', { class: 'mb-4 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Units sold this quarter, online vs in-store' }),
          ]),
          new ViewNode(BarChart, {
            data: __d.categoryRows,
            xKey: 'category',
            series: __d.categorySeries,
            height: 280,
            label: 'Sales by category, online versus in-store',
          }, []),
        ]),
        new ViewNode('section', { class: 'rounded-xl border border-border bg-surface p-6' }, [
          new ViewNode('h2', { class: 'text-sm font-medium text-ink' }, [
            new ViewNode('text', { value: 'Traffic sources' }),
          ]),
          new ViewNode('p', { class: 'mb-4 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Sessions by acquisition channel' }),
          ]),
          new ViewNode(PieChart, {
            data: __d.trafficSlices,
            totalLabel: 'Sessions',
            label: 'Sessions by acquisition channel',
          }, []),
        ]),
      ]),
      new ViewNode('div', { class: 'mt-6 mb-12 grid grid-cols-1 gap-6 lg:grid-cols-3' }, [
        new ViewNode('section', { class: 'rounded-xl border border-border bg-surface p-6 lg:col-span-2' }, [
          new ViewNode('h2', { class: 'text-sm font-medium text-ink' }, [
            new ViewNode('text', { value: 'Sessions by device' }),
          ]),
          new ViewNode('p', { class: 'mb-4 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Stacked weekly sessions across device types' }),
          ]),
          new ViewNode(AreaChart, {
            data: __d.deviceRows,
            xKey: 'week',
            series: __d.deviceSeries,
            stacked: true,
            height: 260,
            label: 'Weekly sessions stacked by device type',
          }, []),
        ]),
        new ViewNode('section', {
          class: 'flex flex-col items-center justify-center rounded-xl border border-border bg-surface p-6',
        }, [
          new ViewNode('h2', { class: 'self-start text-sm font-medium text-ink' }, [
            new ViewNode('text', { value: 'Quarterly goal' }),
          ]),
          new ViewNode('p', { class: 'mb-4 self-start text-sm text-muted' }, [
            new ViewNode('text', { value: 'Progress toward $175k target' }),
          ]),
          new ViewNode(ProgressRing, {
            value: 73,
            size: 128,
            thickness: 10,
            label: 'Quarterly goal',
          }, []),
          new ViewNode('p', { class: 'mt-4 text-sm text-body' }, [
            new ViewNode('text', { value: '$128.4k of $175k' }),
          ]),
        ]),
      ]),
    ]),
  ]);
};
