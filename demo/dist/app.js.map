
import { PuzzleView } from '@magic-spells/puzzle';
import Code from '@/components/ui/Code.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece code';
const usageImport = `import Code from '@/components/ui/Code.pzl';`;
const usageMarkup = `<Code code={ snippet }/>`;

const heroSnippet = `export function debounce(fn, wait = 150) {
  let timer = null;
  return (...args) => {
    clearTimeout(timer);
    timer = setTimeout(() => fn(...args), wait);
  };
}`;

const commandSnippet = `npm install @magic-spells/morph-engine
npm run build`;

const longSnippet = `import { PuzzleView } from '@magic-spells/puzzle';

// A parent-owned counter: the view holds the value and
// passes both the number and the handlers down as props.
export default class Counter extends PuzzleView {
  created() {
    this.setData({ count: 0 });
  }

  data(params, props) {
    return { count: this.getData().count ?? 0 };
  }

  events = {
    increment: () => {
      this.setData({ count: this.getData().count + 1 });
      this.refresh();
    },
    reset: () => {
      this.setData({ count: 0 });
      this.refresh();
    },
  };
}`;

const bashSnippet = `cp registry/ui/button/Button.pzl app/components/ui/`;

const markupSnippet = `<Select options={ opts } value={ pet } @change={ setPet } />`;

const codeHero = `const snippet = \`export function debounce(fn, wait = 150) {
  …
}\`;

<Code code={ snippet }/>`;

const codeCommand = `// numbers off for command blocks (CodeBlock is a thin alias for this)
<Code code={ installCmd } numbers={ false }/>`;

const codeCollapsible = `// starts as a dimmed three-line peek with a View Code pill,
// animates open, and a chevron collapses it back
<Code code={ longSnippet } collapsible={ true } maxHeight="450px"/>`;

const codeLang = `<Code code={ bashSnippet } numbers={ false }/>   // guessed: bash
<Code code={ markupSnippet }/>                    // guessed: xml
<Code code={ snippet } lang="javascript"/>        // explicit override`;

export default class CodeDoc extends PuzzleView {
  data(params, props) {
    return {
      installCmd,
      usageImport,
      usageMarkup,
      heroSnippet,
      commandSnippet,
      longSnippet,
      bashSnippet,
      markupSnippet,
      codeHero,
      codeCommand,
      codeCollapsible,
      codeLang,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Command block', href: '#command' },
        { label: 'Collapsible', href: '#collapsible' },
        { label: 'Language detection', href: '#languages' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

CodeDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Code' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A complete code panel in one piece: syntax highlighting on a GitHub light/dark palette, an optional line-number gutter, a corner copy button, and a collapsible View Code preview that animates open. Hand it a snippet string and it takes care of the rest — this docs site renders every example through it.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, {
          code: __d.codeHero,
          tall: false,
        }, [
          new ViewNode('div', { class: 'w-full max-w-xl' }, [
            new ViewNode(Code, { code: __d.heroSnippet }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece and its highlighting lib, then install highlight.js:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'The highlighter registers only the javascript, xml, and bash grammars (about 13 KB gzipped total) — add more in app/lib/highlight.js if your snippets need them. The token colors travel inside Code.pzl in a global ' + String('<styles>') + ' block, so there is nothing to merge into pieces.css — retheme the palette by editing the --hl- variables at the bottom of the file.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'command',
            title: 'Command block',
            code: __d.codeCommand,
            tall: false,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xl' }, [
              new ViewNode(Code, {
                code: __d.commandSnippet,
                numbers: false,
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'collapsible',
            title: 'Collapsible',
            code: __d.codeCollapsible,
            tall: false,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xl' }, [
              new ViewNode(Code, {
                code: __d.longSnippet,
                collapsible: true,
                maxHeight: '450px',
              }, []),
            ]),
          ]),
          new ViewNode('section', {
            id: 'languages',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Language detection' }),
            ]),
            new ViewNode('p', { class: 'mb-4 text-sm text-body' }, [
              new ViewNode('text', { value: 'The grammar is guessed from the snippet\'s shape — install-style commands go to bash, snippets that open with a tag go to xml, and everything else (including the common const-then-markup mix) goes to javascript, whose JSX support colors embedded tags. Pass' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'lang' }),
              ]),
              new ViewNode('text', { value: 'to override the guess.' }),
            ]),
            new ViewNode(ExampleBox, {
              code: __d.codeLang,
              tall: false,
            }, [
              new ViewNode('div', { class: 'flex w-full max-w-xl flex-col gap-4' }, [
                new ViewNode(Code, {
                  code: __d.bashSnippet,
                  numbers: false,
                }, []),
                new ViewNode(Code, { code: __d.markupSnippet }, []),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
