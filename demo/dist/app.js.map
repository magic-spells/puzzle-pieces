
import { PuzzleView } from '@magic-spells/puzzle';
import Progress from '@/components/ui/Progress.pzl';
import Button from '@/components/ui/Button.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Progress — follows the Button exemplar shape (header → hero
// ExampleBox → Installation → titled example sections → Toc).
const installCmd = 'puzzle add piece progress';
const usageImport = `import Progress from '@/components/ui/Progress.pzl';`;
const usageMarkup = `<Progress value={ pct } max={ 100 } label="Uploading" showValue />`;

const codeHero = `<Progress value={ pct } max={ 100 } label="Uploading" showValue />

// parent
events = {
  bump: () => this.setData({ pct: Math.min(100, this.getData().pct + 10) }),
  reset: () => this.setData({ pct: 0 }),
};`;

const codeIndeterminate = `// Omit value to render the indeterminate (pulsing) state.
<Progress label="Syncing" />`;

const codeSizes = `<Progress value={ 40 } size="sm" />
<Progress value={ 40 } size="md" />`;

export default class ProgressDoc extends PuzzleView {
  created() {
    this.setData({ pct: 30 });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeIndeterminate,
      codeSizes,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Indeterminate', href: '#indeterminate' },
        { label: 'Sizes', href: '#sizes' },
      ],
    };
  }

  events = {
    bump: () => {
      this.setData({ pct: Math.min(100, this.getData().pct + 10) });
      this.refresh();
    },
    reset: () => {
      this.setData({ pct: 0 });
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ProgressDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Progress' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A determinate or indeterminate progress bar. Pass a numeric' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: '; omit it for the indeterminate state.' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'showValue' }),
            ]),
            new ViewNode('text', { value: 'prints a percentage beside the label.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-md space-y-5' }, [
            new ViewNode(Progress, {
              value: __d.pct,
              max: 100,
              label: 'Uploading',
              showValue: true,
            }, []),
            new ViewNode('div', { class: 'flex justify-center gap-3' }, [
              new ViewNode(Button, {
                variant: 'outline',
                press: ((this.__h ??= {})[0] ??= (event) => this.events.bump(event)),
              }, [
                new ViewNode('text', { value: '+10%' }),
              ]),
              new ViewNode(Button, {
                variant: 'ghost',
                press: ((this.__h ??= {})[1] ??= (event) => this.events.reset(event)),
              }, [
                new ViewNode('text', { value: 'Reset' }),
              ]),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'indeterminate',
            title: 'Indeterminate',
            code: __d.codeIndeterminate,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Progress, { label: 'Syncing' }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'sizes',
            title: 'Sizes',
            code: __d.codeSizes,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md space-y-5' }, [
              new ViewNode(Progress, {
                value: 40,
                size: 'sm',
              }, []),
              new ViewNode(Progress, {
                value: 40,
                size: 'md',
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
