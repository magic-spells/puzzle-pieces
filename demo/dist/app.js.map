
import { PuzzleView } from '@magic-spells/puzzle';
import Breadcrumb from '@/components/ui/Breadcrumb.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece breadcrumb';
const usageImport = `import Breadcrumb from '@/components/ui/Breadcrumb.pzl';`;
const usageMarkup = `<Breadcrumb items={ trail } />`;

const codeHero = `const trail = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'puzzle-pieces', href: '/projects/puzzle-pieces' },
  { label: 'Settings' },
];

<Breadcrumb items={ trail } />`;

const codeCurrent = `// The last item renders as text with aria-current="page";
// its href, if present, is ignored.
const trail = [
  { label: 'Docs', href: '/docs' },
  { label: 'Components', href: '/docs/components' },
  { label: 'Breadcrumb' },
];

<Breadcrumb items={ trail } />`;

export default class BreadcrumbDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeCurrent,
      trail: [
        { label: 'Home', href: '/' },
        { label: 'Projects', href: '/content' },
        { label: 'puzzle-pieces', href: '/content' },
        { label: 'Settings' },
      ],
      shortTrail: [
        { label: 'Docs', href: '/content' },
        { label: 'Components', href: '/content' },
        { label: 'Breadcrumb' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Current page', href: '#current' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

BreadcrumbDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Breadcrumb' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A config-first breadcrumb trail rendered from an' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'items' }),
            ]),
            new ViewNode('text', { value: 'array, with a chevron separator between crumbs and the final crumb as the current page.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, {
          tall: false,
          code: __d.codeHero,
        }, [
          new ViewNode(Breadcrumb, { items: __d.trail }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'current',
            title: 'Current page',
            tall: false,
            code: __d.codeCurrent,
          }, [
            new ViewNode(Breadcrumb, { items: __d.shortTrail }, []),
          ]),
          new ViewNode('p', { class: 'text-sm text-body' }, [
            new ViewNode('text', { value: 'The last item in the array is the current page: it renders as plain text carrying' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'aria-current="page"' }),
            ]),
            new ViewNode('text', { value: ', and any href on it is ignored. Every earlier item is a link.' }),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
