
import { PuzzleView } from '@magic-spells/puzzle';
import Meter from '@/components/ui/Meter.pzl';
import Button from '@/components/ui/Button.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Meter — follows the Progress exemplar shape (header → hero
// ExampleBox → Installation → titled example sections → Toc). The hero is a
// disk-usage gauge: `low`/`high` mark the caution/full thresholds and
// `optimum={ 0 }` declares "lower is better" explicitly (Meter defaults to
// this when `optimum` is omitted, since resource-usage gauges are the most
// common case — the hero spells it out for teaching purposes).
const installCmd = 'puzzle add piece meter';
const usageImport = `import Meter from '@/components/ui/Meter.pzl';`;
const usageMarkup = `<Meter value={ disk } low={ 60 } high={ 85 } optimum={ 0 } label="Disk usage" valueText={ \`\${disk}% used\` }/>`;

const codeHero = `<Meter
  value={ disk }
  low={ 60 }
  high={ 85 }
  optimum={ 0 }
  label="Disk usage"
  valueText={ \`\${disk}% used\` }/>

// parent
events = {
  bump: () => this.setData({ disk: Math.min(100, this.getData().disk + 10) }),
  reset: () => this.setData({ disk: 30 }),
};`;

const codeBands = `// low/high split the range into three bands; optimum={ 0 } means
// "lower is better" (the low band is success, the high band is danger).
<Meter value={ 20 } low={ 60 } high={ 85 } optimum={ 0 } label="Success band" />
<Meter value={ 72 } low={ 60 } high={ 85 } optimum={ 0 } label="Warning band" />
<Meter value={ 95 } low={ 60 } high={ 85 } optimum={ 0 } label="Danger band" />`;

const codeCustomRange = `// min/max aren't limited to 0–100 — any measured range works.
<Meter
  value={ 26 }
  min={ 0 }
  max={ 32 }
  low={ 24 }
  high={ 28 }
  optimum={ 0 }
  label="Memory"
  valueText="26 GB / 32 GB" />`;

const codeValueText = `// Meter never formats numbers itself — pass a preformatted valueText.
<Meter
  value={ 7.2 }
  min={ 0 }
  max={ 10 }
  low={ 7 }
  high={ 9 }
  optimum={ 0 }
  label="Battery pack"
  valueText="7.2 kWh / 10 kWh" />`;

const codeSizes = `<Meter value={ 40 } low={ 60 } high={ 85 } optimum={ 0 } size="sm" label="Small" />
<Meter value={ 40 } low={ 60 } high={ 85 } optimum={ 0 } size="md" label="Medium" />`;

export default class MeterDoc extends PuzzleView {
  created() {
    this.setData({ disk: 72 });
  }

  data(params, props) {
    const disk = this.getData().disk;
    return {
      ...this.getData(),
      diskText: `${disk}% used`,
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeBands,
      codeCustomRange,
      codeValueText,
      codeSizes,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Bands', href: '#bands' },
        { label: 'Custom range', href: '#custom-range' },
        { label: 'Formatted value text', href: '#value-text' },
        { label: 'Sizes', href: '#sizes' },
      ],
    };
  }

  events = {
    bump: () => {
      this.setData({ disk: Math.min(100, this.getData().disk + 10) });
      this.refresh();
    },
    reset: () => {
      this.setData({ disk: 30 });
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

MeterDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Meter' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A semantic gauge (' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'role="meter"' }),
            ]),
            new ViewNode('text', { value: ') for a measured value within a range, colored by sentiment against' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'low' }),
            ]),
            new ViewNode('text', { value: '/' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'high' }),
            ]),
            new ViewNode('text', { value: 'thresholds. Distinct from' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'Progress' }),
            ]),
            new ViewNode('text', { value: ', which reports task completion rather than a measurement.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-md space-y-5' }, [
            new ViewNode(Meter, {
              value: __d.disk,
              low: 60,
              high: 85,
              optimum: 0,
              label: 'Disk usage',
              valueText: __d.diskText,
            }, []),
            new ViewNode('div', { class: 'flex justify-center gap-3' }, [
              new ViewNode(Button, {
                variant: 'outline',
                press: ((this.__h ??= {})[0] ??= (event) => this.events.bump(event)),
              }, [
                new ViewNode('text', { value: '+10%' }),
              ]),
              new ViewNode(Button, {
                variant: 'ghost',
                press: ((this.__h ??= {})[1] ??= (event) => this.events.reset(event)),
              }, [
                new ViewNode('text', { value: 'Reset' }),
              ]),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction), including the' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '--color-warning' }),
            ]),
            new ViewNode('text', { value: 'sentiment token used for the caution band.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'bands',
            title: 'Bands',
            code: __d.codeBands,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md space-y-5' }, [
              new ViewNode(Meter, {
                value: 20,
                low: 60,
                high: 85,
                optimum: 0,
                label: 'Success band',
                valueText: '20% — plenty of room',
              }, []),
              new ViewNode(Meter, {
                value: 72,
                low: 60,
                high: 85,
                optimum: 0,
                label: 'Warning band',
                valueText: '72% — getting full',
              }, []),
              new ViewNode(Meter, {
                value: 95,
                low: 60,
                high: 85,
                optimum: 0,
                label: 'Danger band',
                valueText: '95% — nearly full',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'custom-range',
            title: 'Custom range',
            code: __d.codeCustomRange,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Meter, {
                value: 26,
                min: 0,
                max: 32,
                low: 24,
                high: 28,
                optimum: 0,
                label: 'Memory',
                valueText: '26 GB / 32 GB',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'value-text',
            title: 'Formatted value text',
            code: __d.codeValueText,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Meter, {
                value: 7.2,
                min: 0,
                max: 10,
                low: 7,
                high: 9,
                optimum: 0,
                label: 'Battery pack',
                valueText: '7.2 kWh / 10 kWh',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'sizes',
            title: 'Sizes',
            code: __d.codeSizes,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md space-y-5' }, [
              new ViewNode(Meter, {
                value: 40,
                low: 60,
                high: 85,
                optimum: 0,
                size: 'sm',
                label: 'Small',
              }, []),
              new ViewNode(Meter, {
                value: 40,
                low: 60,
                high: 85,
                optimum: 0,
                size: 'md',
                label: 'Medium',
              }, []),
