
import { PuzzleView } from '@magic-spells/puzzle';

// Toc — the "On This Page" column (docs-only). Config-first: items are
// [{ label, href }] where href is a '#section-id' anchor. Clicks are handled in
// JS (scrollIntoView, smooth) rather than left to the raw hash navigation, so
// the SPA router never sees them; the href stays on the <a> for middle-click
// and copy-link semantics. Sections need scroll-mt to clear the sticky header
// (ExampleBox applies scroll-mt-20 to its own <section>).
//
//   <Toc class="hidden xl:block" items={ toc }/>
export default class Toc extends PuzzleView {
  data(params, props) {
    return {
      items: props.items || [],
      rootClass: props.class || '',
    };
  }

  events = {
    jump: (href, event) => {
      const id = typeof href === 'string' && href.startsWith('#') ? href.slice(1) : null;
      if (!id) return;
      event.preventDefault();
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

Toc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('nav', {
    class: __d.rootClass,
    'aria-label': 'On this page',
  }, [
    new ViewNode('p', { class: 'mb-3 text-sm font-medium text-ink' }, [
      new ViewNode('text', { value: 'On This Page' }),
    ]),
    new ViewNode('ul', { class: 'space-y-2 border-l border-border' },
      __d.items.map((item) =>
        new ViewNode('li', { key: item.href }, [
          new ViewNode('a', {
            href: item.href,
            class: '-ml-px block border-l border-transparent pl-4 text-sm text-muted transition-colors hover:border-border-strong hover:text-ink',
            '@click': (event) => this.events.jump(item.href, event),
          }, [
            new ViewNode('text', { value: String(item.label) }),
          ]),
        ])
      )
    ),
  ]);
};
