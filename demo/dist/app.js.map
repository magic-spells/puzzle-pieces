    status: 'brand',
  },
];

// Marker precedence is icon > number > dot, so an explicit `icon` opts one step
// out of numbering — here the finished step shows a checkmark instead of "1".
const mixedFeed = [
  {
    title: 'Account created',
    time: 'Done',
    description: 'Workspace verified and ready.',
    status: 'success',
    icon: 'M20 6 9 17l-5-5',
