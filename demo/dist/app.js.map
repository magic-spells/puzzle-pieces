
import { PuzzleView } from '@magic-spells/puzzle';
import Switch from '@/components/ui/Switch.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece switch';
const usageImport = `import Switch from '@/components/ui/Switch.pzl';`;
const usageMarkup = `<Switch label="Wi-Fi" checked={ wifi } @change={ setWifi } />`;

const codeHero = `<div class="divide-y divide-border">
  <div class="pb-3">
    <Switch label="Wi-Fi" checked={ wifi } @change={ setWifi } />
  </div>
  <div class="py-3">
    <Switch label="Email alerts" hint="Daily digest at 9am" checked={ notify } @change={ setNotify } />
  </div>
</div>`;

const codeHint = `<Switch
  label="Email alerts"
  hint="Daily digest at 9am"
  checked={ notify }
  @change={ setNotify } />`;

const codeDisabled = `<Switch label="Roaming" hint="Unavailable on this plan" checked={ false } disabled />`;

export default class SwitchDoc extends PuzzleView {
  created() {
    this.setData({ wifi: true, notify: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeHint,
      codeDisabled,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'With hint', href: '#hint' },
        { label: 'Disabled', href: '#disabled' },
      ],
    };
  }

  events = {
    setWifi: (v) => {
      this.setData('wifi', v);
      this.refresh();
    },
    setNotify: (v) => {
      this.setData('notify', v);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

SwitchDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Switch' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A toggle built on a native checkbox with' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'role="switch"' }),
            ]),
            new ViewNode('text', { value: '. A labeled Switch is a full-width settings row — text on the left, the control pinned right — so a stack of them under a ' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'divide-y' }),
            ]),
            new ViewNode('text', { value: 'reads as a settings list.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-sm divide-y divide-border' }, [
            new ViewNode('div', { class: 'pb-3' }, [
              new ViewNode(Switch, {
                label: 'Wi-Fi',
                checked: __d.wifi,
                change: ((this.__h ??= {})[0] ??= (event) => this.events.setWifi(event)),
              }, []),
            ]),
            new ViewNode('div', { class: 'py-3' }, [
              new ViewNode(Switch, {
                label: 'Email alerts',
                hint: 'Daily digest at 9am',
                checked: __d.notify,
                change: ((this.__h ??= {})[1] ??= (event) => this.events.setNotify(event)),
              }, []),
            ]),
            new ViewNode('div', { class: 'pt-3' }, [
              new ViewNode(Switch, {
                label: 'Roaming',
                hint: 'Unavailable on this plan',
                checked: false,
                disabled: true,
              }, []),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'hint',
            title: 'With hint',
            code: __d.codeHint,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(Switch, {
                label: 'Email alerts',
                hint: 'Daily digest at 9am',
                checked: __d.notify,
                change: ((this.__h ??= {})[2] ??= (event) => this.events.setNotify(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'disabled',
            title: 'Disabled',
            code: __d.codeDisabled,
            tall: false,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(Switch, {
                label: 'Roaming',
                hint: 'Unavailable on this plan',
                checked: false,
                disabled: true,
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
