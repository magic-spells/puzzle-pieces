        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Purely presentational: the parent owns the message data and passes a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink' }, [
              new ViewNode('text', { value: 'time' }),
            ]),
            new ViewNode('text', { value: 'string already formatted — the piece never touches dates. Wrap a list of rows in Chat Scroller for a full conversation view.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'alignment',
            title: 'Alignment',
            code: __d.codeAlignment,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xl' }, [
              new ViewNode(ChatMessage, {
                author: 'Ada Lovelace',
                time: '9:41 AM',
                avatarName: 'Ada Lovelace',
              }, [
                new ViewNode('text', { value: 'Received messages sit at the start.' }),
              ]),
              new ViewNode(ChatMessage, {
                align: 'end',
                variant: 'sent',
                author: 'You',
                time: '9:42 AM',
                avatarName: 'You',
              }, [
                new ViewNode('text', { value: 'Your own messages mirror to the end.' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'compact',
            title: 'Compact follow-ups',
            code: __d.codeCompact,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xl' }, [
              new ViewNode(ChatMessage, {
                author: 'Grace Hopper',
                time: '11:02 AM',
                avatarName: 'Grace Hopper',
              }, [
                new ViewNode('text', { value: 'First message in a burst shows the full meta.' }),
              ]),
              new ViewNode(ChatMessage, {
                showMeta: false,
                avatarName: 'Grace Hopper',
              }, [
                new ViewNode('text', { value: 'A follow-up drops the avatar and author…' }),
              ]),
              new ViewNode(ChatMessage, {
                showMeta: false,
                avatarName: 'Grace Hopper',
              }, [
                new ViewNode('text', { value: '…and tightens up so the group reads as one.' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'attachments',
            title: 'Attachments',
