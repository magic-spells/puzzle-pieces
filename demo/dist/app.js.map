  <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="1.5" aria-hidden="true">
    <path d="M4 5h16v12H7l-3 3z" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</Empty>`;

export default class EmptyDoc extends PuzzleView {
  data(params, props) {
    return {
