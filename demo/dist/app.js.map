              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Keyboard' }),
                ]),
                new ViewNode('text', { value: ' — the viewport takes ' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[13px] text-ink',
                }, [
                  new ViewNode('text', { value: 'tabindex="0"' }),
                ]),
                new ViewNode('text', { value: ' only while it overflows, so arrow keys, Page Up / Page Down, Space, and Home / End scroll it once focused' }),
