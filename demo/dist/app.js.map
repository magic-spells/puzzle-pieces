
import { PuzzleView } from '@magic-spells/puzzle';
import InputOtp from '@/components/ui/InputOtp.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece input-otp';
const usageImport = `import InputOtp from '@/components/ui/InputOtp.pzl';`;
const usageMarkup = `<InputOtp value={ code } @change={ setCode } />`;

const codeHero = `<InputOtp value={ code } @change={ setCode } />

// parent
events = {
  setCode: (v) => this.setData('code', v),
};`;

const codeGroups = `// groups={[3, 3]} inserts an aria-hidden separator between segments
<InputOtp value={ code } groups={ [3, 3] } @change={ setCode } />`;

const codeAlnum = `// type="alphanumeric" accepts [A-Za-z0-9] and uses inputmode="text"
<InputOtp type="alphanumeric" length={ 5 } value={ code } @change={ setCode } />`;

const codeError = `// error (or invalid) paints the danger border and focus ring
<InputOtp value={ code } error @change={ setCode } />`;

const codeComplete = `<InputOtp value={ otp } @change={ setOtp } @complete={ onComplete } />

// parent — @complete(value) fires once when value.length === length
events = {
  setOtp: (v) => this.setData('otp', v),
  onComplete: (v) => this.verify(v),
};`;

const codeKeyboard = `<InputOtp value={ code } @change={ setCode } />`;

export default class InputOtpDoc extends PuzzleView {
  created() {
    this.setData({ code: '', grouped: '', alnum: '', badCode: '123', otp: '', confirmed: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeGroups,
      codeAlnum,
      codeError,
      codeComplete,
      codeKeyboard,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Groups', href: '#groups' },
        { label: 'Alphanumeric', href: '#alphanumeric' },
        { label: 'Error', href: '#error' },
        { label: 'Complete callback', href: '#complete' },
        { label: 'Keyboard and paste', href: '#keyboard' },
      ],
    };
  }

  events = {
    setCode: (v) => {
      this.setData('code', v);
      this.refresh();
    },
    setGrouped: (v) => {
      this.setData('grouped', v);
      this.refresh();
    },
    setAlnum: (v) => {
      this.setData('alnum', v);
      this.refresh();
    },
    setBadCode: (v) => {
      this.setData('badCode', v);
      this.refresh();
    },
    setOtp: (v) => {
      // A new edit that isn't yet complete clears the confirmation.
      this.setData({ otp: v, confirmed: v.length === 6 ? this.getData().confirmed : false });
      this.refresh();
    },
    onComplete: () => {
      this.setData('confirmed', true);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

InputOtpDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Input OTP' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A segmented one-time-code input — real single-char cells with native caret and mobile keyboard, paste distribution, and full keyboard navigation. Controlled: the parent owns the full' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: 'string and updates it from' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: ', while' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@complete' }),
            ]),
            new ViewNode('text', { value: 'fires once the code is filled.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(InputOtp, {
            value: __d.code,
            change: ((this.__h ??= {})[0] ??= (event) => this.events.setCode(event)),
          }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'No dependencies. Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'groups',
            title: 'Groups',
            code: __d.codeGroups,
          }, [
            new ViewNode(InputOtp, {
              value: __d.grouped,
              groups: [3, 3],
              change: ((this.__h ??= {})[1] ??= (event) => this.events.setGrouped(event)),
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'alphanumeric',
            title: 'Alphanumeric',
            code: __d.codeAlnum,
          }, [
            new ViewNode(InputOtp, {
              type: 'alphanumeric',
              length: 5,
              value: __d.alnum,
              change: ((this.__h ??= {})[2] ??= (event) => this.events.setAlnum(event)),
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'error',
            title: 'Error',
            code: __d.codeError,
          }, [
            new ViewNode(InputOtp, {
              value: __d.badCode,
              error: true,
              change: ((this.__h ??= {})[3] ??= (event) => this.events.setBadCode(event)),
            }, []),
          ]),
          new ViewNode('section', {
            id: 'complete',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Complete callback' }),
            ]),
            new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
              new ViewNode('text', { value: 'There is no auto-submit —' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: '@complete' }),
              ]),
              new ViewNode('text', { value: 'is the parent\'s hook, firing once the moment the value reaches' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'length' }),
              ]),
              new ViewNode('text', { value: '. Type six digits below:' }),
            ]),
            new ViewNode(ExampleBox, { code: __d.codeComplete }, [
              new ViewNode('div', { class: 'flex flex-col items-center gap-4' }, [
                new ViewNode(InputOtp, {
                  value: __d.otp,
                  change: ((this.__h ??= {})[4] ??= (event) => this.events.setOtp(event)),
                  complete: ((this.__h ??= {})[5] ??= (event) => this.events.onComplete(event)),
                }, []),
                ...(__d.confirmed
                  ? [
                      new ViewNode('p', { class: 'text-sm font-medium text-success' }, [
                        new ViewNode('text', { value: 'Code ' + String(__d.otp) + ' submitted' }),
                      ]),
                    ]
                  : [
                      new ViewNode('p', { class: 'text-sm text-muted' }, [
                        new ViewNode('text', { value: 'Waiting for all six digits…' }),
                      ]),
