
import { PuzzleView } from '@magic-spells/puzzle';
import Popconfirm from '@/components/ui/Popconfirm.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece popconfirm';
const usageImport = `import Popconfirm from '@/components/ui/Popconfirm.pzl';`;
const usageMarkup = `<Popconfirm message="Delete this item?" confirmLabel="Delete" @confirm={ onDelete }></Popconfirm>`;

const codeHero = `<Popconfirm message="Delete this item?" confirmLabel="Delete" @confirm={ onDelete }>
  <button slot="trigger" class="…">Delete item</button>
</Popconfirm>

// The consumer supplies their OWN button in the "trigger" slot; clicking it
// opens the confirm bubble. @confirm fires and closes; @cancel (or Escape /
// an outside click) dismisses without confirming.
events = {
  onDelete: () => this.doDelete(),
};`;

const codeDanger = `// variant="danger" tints the confirm button destructive. Pair it with a
// description line for the "cannot be undone" reassurance.
<Popconfirm
  message="Delete this file?"
  description="This permanently removes the file and cannot be undone."
  confirmLabel="Delete"
  variant="danger"
  @confirm={ onDelete }>
  <button slot="trigger" class="…">Delete file</button>
</Popconfirm>`;

const codePlacement = `<Popconfirm message="Confirm this action?" placement="top" align="start">…</Popconfirm>
<Popconfirm message="Confirm this action?" placement="bottom" align="end">…</Popconfirm>

// placement — "top" (default) or "bottom"; flips automatically when the
//              requested edge lacks room for the measured bubble.
// align     — "center" (default), "start", or "end" along the trigger's edge.`;

const codeControlled = `// open is optional-controlled: pass it and the parent owns the state. The
// bubble fires @show / @hide so a controlled parent can stay in sync, and
// @confirm / @cancel for the action itself.
<Popconfirm
  message="Publish these changes?"
  confirmLabel="Publish"
  open={ confirmOpen }
  @show={ onShow }
  @hide={ onHide }
  @confirm={ onPublish }>
  <button slot="trigger" class="…">Publish</button>
</Popconfirm>

events = {
  onShow: () => this.setData('confirmOpen', true),
  onHide: () => this.setData('confirmOpen', false),
};`;

export default class PopconfirmDoc extends PuzzleView {
  created() {
    this.setData({ deleteCount: 0, confirmOpen: false, published: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeDanger,
      codePlacement,
      codeControlled,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Danger variant', href: '#danger' },
        { label: 'Placement', href: '#placement' },
        { label: 'Controlled open', href: '#controlled' },
      ],
    };
  }

  events = {
    onDelete: () => {
      this.setData('deleteCount', this.getData().deleteCount + 1);
      this.refresh();
    },
    onShow: () => {
      this.setData('confirmOpen', true);
      this.refresh();
    },
    onHide: () => {
      this.setData('confirmOpen', false);
      this.refresh();
    },
    onPublish: () => {
      this.setData('published', true);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

PopconfirmDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Popconfirm' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A lightweight inline confirmation popover anchored to its trigger, for low-stakes confirmations that don\'t warrant a full modal. It opens next to the trigger on click; an outside click or Escape cancels it, and it flips sides when the requested edge runs out of room. Reach for Alert Dialog when the choice is consequential enough to demand a focus-trapping modal.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(Popconfirm, {
            message: 'Delete this item?',
            confirmLabel: 'Delete',
            confirm: ((this.__h ??= {})[0] ??= (event) => this.events.onDelete(event)),
          }, [
            new ViewNode('button', {
              slot: 'trigger',
              class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken outline-ring focus-visible:outline-2 focus-visible:outline-offset-2',
            }, [
              new ViewNode('text', { value: 'Delete item' }),
            ]),
          ]),
          new ViewNode('p', { class: 'mt-4 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Deleted ' + String(__d.deleteCount) + ' time' + String(__d.deleteCount === 1 ? '' : 's') + ' this session.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'danger',
            title: 'Danger variant',
            code: __d.codeDanger,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-4' }, [
              new ViewNode(Popconfirm, {
                message: 'Delete this file?',
                description: 'This permanently removes the file and cannot be undone.',
                confirmLabel: 'Delete',
                variant: 'danger',
                confirm: ((this.__h ??= {})[1] ??= (event) => this.events.onDelete(event)),
              }, [
                new ViewNode('button', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg bg-danger px-4 text-sm font-medium text-danger-ink hover:bg-danger-dark outline-ring focus-visible:outline-2 focus-visible:outline-offset-2',
                }, [
                  new ViewNode('text', { value: 'Delete file' }),
                ]),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'placement',
            title: 'Placement',
            code: __d.codePlacement,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-4' }, [
              new ViewNode(Popconfirm, {
                message: 'Confirm this action?',
                placement: 'top',
                align: 'start',
              }, [
                new ViewNode('button', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken outline-ring focus-visible:outline-2 focus-visible:outline-offset-2',
                }, [
                  new ViewNode('text', { value: 'Top start' }),
                ]),
              ]),
              new ViewNode(Popconfirm, {
                message: 'Confirm this action?',
                placement: 'top',
                align: 'center',
              }, [
                new ViewNode('button', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken outline-ring focus-visible:outline-2 focus-visible:outline-offset-2',
                }, [
                  new ViewNode('text', { value: 'Top center' }),
                ]),
              ]),
              new ViewNode(Popconfirm, {
                message: 'Confirm this action?',
                placement: 'bottom',
                align: 'end',
              }, [
                new ViewNode('button', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken outline-ring focus-visible:outline-2 focus-visible:outline-offset-2',
                }, [
                  new ViewNode('text', { value: 'Bottom end' }),
                ]),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'controlled',
            title: 'Controlled open',
            code: __d.codeControlled,
          }, [
            new ViewNode('div', { class: 'flex flex-col items-center gap-4 text-sm text-body' }, [
              new ViewNode(Popconfirm, {
                message: 'Publish these changes?',
                confirmLabel: 'Publish',
                open: __d.confirmOpen,
                show: ((this.__h ??= {})[2] ??= (event) => this.events.onShow(event)),
                hide: ((this.__h ??= {})[3] ??= (event) => this.events.onHide(event)),
                confirm: ((this.__h ??= {})[4] ??= (event) => this.events.onPublish(event)),
              }, [
                new ViewNode('button', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 font-medium text-ink hover:bg-surface-sunken outline-ring focus-visible:outline-2 focus-visible:outline-offset-2',
                }, [
                  new ViewNode('text', { value: 'Publish' }),
                ]),
              ]),
              new ViewNode('p', {}, [
                new ViewNode('text', { value: 'The parent owns ' }),
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'open' }),
                ]),
                new ViewNode('text', { value: ' — it is currently' }),
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: String(__d.confirmOpen ? 'open' : 'closed') }),
                ]),
                new ViewNode('text', { value: '.' + String(__d.published ? ' Changes published.' : '') }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
