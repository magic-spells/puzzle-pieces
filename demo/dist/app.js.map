
import { PuzzleView } from '@magic-spells/puzzle';
import Tabs from '@/components/ui/Tabs.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Tabs — follows the ButtonDoc exemplar shape.
const installCmd = 'puzzle add piece tabs';
const usageImport = `import Tabs from '@/components/ui/Tabs.pzl';`;
const usageMarkup = `<Tabs id="acct" tabs={ tabs } value={ tab } @change={ setTab }/>`;

const codeHero = `const tabs = [
  { value: 'account', label: 'Account' },
  { value: 'password', label: 'Password' },
  { value: 'members', label: 'Members' },
];

// Tabs renders the strip; the parent owns the active value and the panels.
<Tabs id="acct" tabs={ tabs } value={ tab } @change={ setTab }/>
{#if tab === 'account'}
  <div role="tabpanel" id="acct-panel-account"
       aria-labelledby="acct-tab-account" tabindex="0">…</div>
{:else if tab === 'password'}
  <div role="tabpanel" id="acct-panel-password"
       aria-labelledby="acct-tab-password" tabindex="0">…</div>
{/if}

// parent
events = { setTab: (v) => this.setData('tab', v) };`;

const codePills = `const tabs = [
  { value: 'overview', label: 'Overview' },
  { value: 'activity', label: 'Activity' },
  { value: 'settings', label: 'Settings' },
];

<Tabs id="proj" variant="pills" tabs={ tabs } value={ tab } @change={ setTab }/>`;

const codeDisabled = `const tabs = [
  { value: 'active', label: 'Active' },
  { value: 'archived', label: 'Archived' },
  { value: 'deleted', label: 'Deleted', disabled: true },
];

// A disabled tab is skipped by arrow-key nav and can't be activated.
<Tabs id="stat" tabs={ tabs } value={ tab } @change={ setTab }/>`;

export default class TabsDoc extends PuzzleView {
  created() {
    this.setData({ tabHero: 'account', tabPill: 'overview', tabDis: 'active' });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codePills,
      codeDisabled,
      acctTabs: [
        { value: 'account', label: 'Account' },
        { value: 'password', label: 'Password' },
        { value: 'members', label: 'Members' },
      ],
      projTabs: [
        { value: 'overview', label: 'Overview' },
        { value: 'activity', label: 'Activity' },
        { value: 'settings', label: 'Settings' },
      ],
      statTabs: [
        { value: 'active', label: 'Active' },
        { value: 'archived', label: 'Archived' },
        { value: 'deleted', label: 'Deleted', disabled: true },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Pill variant', href: '#pills' },
        { label: 'Disabled tab', href: '#disabled' },
      ],
    };
  }

  events = {
    setTabHero: (v) => this.setData('tabHero', v),
    setTabPill: (v) => this.setData('tabPill', v),
    setTabDis: (v) => this.setData('tabDis', v),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

TabsDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Tabs' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An accessible ARIA tablist with roving tabindex and arrow-key nav. It renders the strip only — panels stay' }),
            new ViewNode('strong', { class: 'font-medium text-ink' }, [
              new ViewNode('text', { value: 'parent-owned' }),
            ]),
            new ViewNode('text', { value: ': the parent tracks the active value and shows the matching panel itself, wired together by id.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-md space-y-4' }, [
            new ViewNode(Tabs, {
              id: 'acct',
              tabs: __d.acctTabs,
              value: __d.tabHero,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setTabHero(event)),
            }, []),
            ...(__d.tabHero === 'account'
              ? [
                  new ViewNode('div', {
                    role: 'tabpanel',
                    id: 'acct-panel-account',
                    'aria-labelledby': 'acct-tab-account',
                    tabindex: '0',
                    class: 'text-sm text-body',
                  }, [
                    new ViewNode('text', { value: 'Manage your account details and profile here.' }),
                  ]),
                ]
              : [
                  ...(__d.tabHero === 'password'
                    ? [
                        new ViewNode('div', {
                          role: 'tabpanel',
                          id: 'acct-panel-password',
                          'aria-labelledby': 'acct-tab-password',
                          tabindex: '0',
                          class: 'text-sm text-body',
                        }, [
                          new ViewNode('text', { value: 'Change your password and security settings.' }),
                        ]),
                      ]
                    : [
                        new ViewNode('div', {
                          role: 'tabpanel',
                          id: 'acct-panel-members',
                          'aria-labelledby': 'acct-tab-members',
                          tabindex: '0',
                          class: 'text-sm text-body',
                        }, [
                          new ViewNode('text', { value: 'Invite teammates and manage their roles.' }),
                        ]),
                      ]),
                ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'pills',
            title: 'Pill variant',
            code: __d.codePills,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md space-y-4' }, [
              new ViewNode(Tabs, {
                id: 'proj',
                variant: 'pills',
                tabs: __d.projTabs,
                value: __d.tabPill,
                change: ((this.__h ??= {})[1] ??= (event) => this.events.setTabPill(event)),
              }, []),
              ...(__d.tabPill === 'overview'
                ? [
                    new ViewNode('div', {
                      role: 'tabpanel',
                      id: 'proj-panel-overview',
                      'aria-labelledby': 'proj-tab-overview',
                      tabindex: '0',
                      class: 'text-sm text-body',
                    }, [
                      new ViewNode('text', { value: 'A high-level overview of the project.' }),
                    ]),
                  ]
                : [
                    ...(__d.tabPill === 'activity'
                      ? [
                          new ViewNode('div', {
                            role: 'tabpanel',
                            id: 'proj-panel-activity',
                            'aria-labelledby': 'proj-tab-activity',
                            tabindex: '0',
                            class: 'text-sm text-body',
                          }, [
                            new ViewNode('text', { value: 'Recent activity and changes.' }),
                          ]),
                        ]
                      : [
                          new ViewNode('div', {
                            role: 'tabpanel',
                            id: 'proj-panel-settings',
                            'aria-labelledby': 'proj-tab-settings',
                            tabindex: '0',
                            class: 'text-sm text-body',
                          }, [
                            new ViewNode('text', { value: 'Project settings.' }),
                          ]),
                        ]),
                  ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'disabled',
            title: 'Disabled tab',
            code: __d.codeDisabled,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md space-y-4' }, [
              new ViewNode(Tabs, {
                id: 'stat',
                tabs: __d.statTabs,
                value: __d.tabDis,
                change: ((this.__h ??= {})[2] ??= (event) => this.events.setTabDis(event)),
              }, []),
              ...(__d.tabDis === 'active'
                ? [
                    new ViewNode('div', {
                      role: 'tabpanel',
                      id: 'stat-panel-active',
                      'aria-labelledby': 'stat-tab-active',
                      tabindex: '0',
                      class: 'text-sm text-body',
                    }, [
                      new ViewNode('text', { value: 'Everything currently in play.' }),
                    ]),
                  ]
                : [
                    new ViewNode('div', {
                      role: 'tabpanel',
                      id: 'stat-panel-archived',
                      'aria-labelledby': 'stat-tab-archived',
                      tabindex: '0',
                      class: 'text-sm text-body',
                    }, [
                      new ViewNode('text', { value: 'Older items kept for reference.' }),
                    ]),
                  ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
