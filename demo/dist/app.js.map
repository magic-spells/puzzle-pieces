          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'Popover\'s hover- and focus-triggered cousin, for supplementary previews like link previews and user cards. It opens on hover or keyboard focus after a delay, stays up while you move onto its panel, and closes shortly after you leave. No click toggle — reach for Popover when the content must be clicked.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
