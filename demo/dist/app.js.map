
import { PuzzleView } from '@magic-spells/puzzle';
import Calendar from '@/components/ui/Calendar.pzl';
import DatePicker from '@/components/ui/DatePicker.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Calendar — follows the ButtonDoc exemplar (header → hero ExampleBox
// → Installation → titled example sections → Toc). Every control is parent-owned:
// the view holds the ISO value and Calendar fires @change back into it (lifted from
// the Calendar section of the old Forms view).

// Two files: the piece plus the shared date helper it imports.
const installCmd = 'puzzle add piece calendar';
const usageImport = `import Calendar from '@/components/ui/Calendar.pzl';`;
const usageMarkup = `<Calendar value={ date } @change={ setDate } />`;

// disabledDates accepts an ISO array OR a predicate (iso, date) => boolean. A stable
// module reference keeps the child prop identity steady across re-renders.
const weekends = (iso, date) => {
  const day = date.getDay();
  return day === 0 || day === 6;
};

const KEY_CLASS =
  'inline-flex min-w-[1.75rem] items-center justify-center rounded border border-border ' +
  'bg-surface-sunken px-1.5 py-0.5 font-mono text-xs text-ink';

const codeHero = `<Calendar value={ date } @change={ setDate } />

// parent — Calendar never mutates value; it asks and you write it back
events = {
  setDate: (iso) => this.setData('date', iso),
};`;

const codeBounds = `// disabledDates: an ISO array, or a predicate (iso, date) => boolean
const weekends = (iso, date) => date.getDay() === 0 || date.getDay() === 6;

<Calendar
  value={ date }
  min="2026-07-01"
  max="2026-08-31"
  disabledDates={ weekends }
  @change={ setDate } />`;

const codeFirstDay = `<!-- firstDayOfWeek: 0 = Sunday (default) … 6 = Saturday -->
<Calendar value={ date } firstDayOfWeek={ 1 } @change={ setDate } />`;

const codeMorph = `// Calendar is inline-only; DatePicker composes it behind a trigger.
// morph animates the trigger into the panel (npm install @magic-spells/morph-engine).
<DatePicker label="Event date" value={ date } morph={ true } @change={ setDate } />`;

export default class CalendarDoc extends PuzzleView {
  created() {
    this.setData({
      date: '2026-07-16',
      boundedDate: '2026-07-16',
      mondayDate: '2026-07-16',
      morphDate: '2026-08-01',
    });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      weekends,
      keyClass: KEY_CLASS,
      codeHero,
      codeBounds,
      codeFirstDay,
      codeMorph,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Bounds and disabled dates', href: '#bounds' },
        { label: 'First day of week', href: '#first-day' },
        { label: 'Keyboard', href: '#keyboard' },
        { label: 'From a trigger, with morph', href: '#from-trigger' },
      ],
    };
  }

  events = {
    setDate: (iso) => this.setData('date', iso),
    setBoundedDate: (iso) => this.setData('boundedDate', iso),
    setMondayDate: (iso) => this.setData('mondayDate', iso),
    setMorphDate: (iso) => this.setData('morphDate', iso),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

CalendarDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Calendar' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An inline month-grid calendar with days / months / years drill-down, full keyboard navigation, min/max bounds plus' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'disabledDates' }),
            ]),
            new ViewNode('text', { value: ', and locale-aware labels via Intl. It is parent-owned: it never mutates' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: ', it fires' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: 'and the parent writes the new ISO date back.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-col items-center gap-4' }, [
            new ViewNode(Calendar, {
              value: __d.date,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setDate(event)),
            }, []),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'Selected: ' }),
              new ViewNode('code', { class: 'font-mono text-ink' }, [
                new ViewNode('text', { value: String(__d.date || 'none') }),
              ]),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece and its date helper into your app — they compile with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'date-math.js is a shared lib file — Calendar imports it as ../../lib/date-math.js. Keep it in app/lib/.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'bounds',
            title: 'Bounds and disabled dates',
            code: __d.codeBounds,
          }, [
            new ViewNode('div', { class: 'flex flex-col items-center gap-4' }, [
              new ViewNode(Calendar, {
                value: __d.boundedDate,
                min: '2026-07-01',
                max: '2026-08-31',
                disabledDates: __d.weekends,
