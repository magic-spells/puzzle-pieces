const NEW_ISSUE_META = {
  bug: { badge: 'Bug', badgeVariant: 'danger', title: 'Untitled bug' },
  feature: { badge: 'Feature', badgeVariant: 'brand', title: 'Untitled feature' },
  chore: { badge: 'Chore', badgeVariant: 'default', title: 'Untitled chore' },
  template: { badge: 'Task', badgeVariant: 'outline', title: 'Untitled from template' },
  task: { badge: 'Task', badgeVariant: 'default', title: 'Untitled issue' },
};

const COLUMN_DOT = {
  todo: 'size-2.5 rounded-full bg-surface-sunken ring-1 ring-border',
  inprogress: 'size-2.5 rounded-full bg-brand',
  inreview: 'size-2.5 rounded-full bg-warning',
  done: 'size-2.5 rounded-full bg-success',
};

const ASSIGNEES = ['Ada Lovelace', 'Grace Hopper', 'Alan Turing', 'Katherine Johnson', 'Linus Torvalds', 'Radia Perlman'];

const countOf = (cols, id) => {
  const c = cols.find((x) => x.id === id);
  return c ? c.cards.length : 0;
};

export default class ProjectDemo extends PuzzleView {
  created() {
    this.setData({
      tab: 'board',
      columns: structuredClone(INITIAL_COLUMNS),
      // toolbar toggle states (parent-owned)
      showSubtasks: true,
      compact: false,
      // projects/teams tree (controlled selection + expansion)
      treeValue: 'web',
      treeExpanded: ['eng'],
      // running counter for generated issue numbers
      nextNum: 170,
    });
  }

  data() {
    const s = this.getData();
    const cols = s.columns;

    const openCount = countOf(cols, 'todo');
    const inProgressCount = countOf(cols, 'inprogress');
    const inReviewCount = countOf(cols, 'inreview');
    const doneCount = countOf(cols, 'done');
    const totalCount = openCount + inProgressCount + inReviewCount + doneCount;
    const completion = totalCount ? Math.round((doneCount / totalCount) * 100) : 0;

    // Sprint capacity: estimate ~3 points of load per active (in-progress + review)
    // issue against a 20-point sprint budget.
    const load = (inProgressCount + inReviewCount) * 3;
    const capacity = Math.min(100, Math.round((load / 20) * 100));

    // List tab: one group per column, cards flattened to rows.
    const listGroups = cols.map((c) => ({
      id: c.id,
      title: c.title,
      count: c.cards.length,
      dotClass: COLUMN_DOT[c.id] || COLUMN_DOT.todo,
      rows: c.cards.map((card) => ({
        id: card.id,
        code: card.code || card.id,
        title: card.title,
        badge: card.badge,
        badgeVariant: card.badgeVariant || 'default',
        assignee: card.assignee || 'Unassigned',
        deleteLabel: `Delete ${card.code || card.id}`,
      })),
    }));

    // Toolbar items rebuilt from owned toggle state so `pressed` reflects it.
    const toolbarItems = [
      { type: 'button', value: 'filter', label: 'Filter', icon: IC_FILTER, iconOnly: true },
      { type: 'button', value: 'group', label: 'Group by', icon: IC_GROUP, iconOnly: true },
      { type: 'button', value: 'sort', label: 'Sort', icon: IC_SORT, iconOnly: true },
      { type: 'separator' },
      { type: 'toggle', value: 'subtasks', label: 'Show subtasks', icon: IC_SUBTASKS, pressed: s.showSubtasks },
      { type: 'toggle', value: 'compact', label: 'Compact', icon: IC_COMPACT, pressed: s.compact },
    ];

    return {
      // chrome
      navItems: NAV_ITEMS,
      teamTree: TEAM_TREE,
      treeValue: s.treeValue,
      treeExpanded: s.treeExpanded,
      crumbs: CRUMBS,
      tabItems: TAB_ITEMS,
      tab: s.tab,
      teamAvatars: TEAM_AVATARS,
      newIssueActions: NEW_ISSUE_ACTIONS,
      boardActions: BOARD_ACTIONS,
      headerMeta: `Product · ${totalCount} issues · ${completion}% complete`,

      // board
      columns: cols,
      toolbarItems,

      // metrics (live)
      openCount: `${openCount}`,
      inProgressCount: `${inProgressCount}`,
      inReviewCount: `${inReviewCount}`,
      doneCount,
      totalCount,
      completion,
      completionLabel: `${completion}% complete`,
      capacity,
      capacityText: `${load} of 20 pts`,
      sparkOpen: [7, 6, 8, 7, 6, 5, openCount],
      sparkProgress: [1, 2, 2, 3, 2, 3, inProgressCount],
      sparkReview: [0, 1, 1, 2, 1, 2, inReviewCount],
      sparkDone: [0, 1, 1, 2, 2, 3, doneCount],

      // list + activity
      listGroups,
      activity: ACTIVITY,
    };
  }

  // Add a fresh card to the To do column and surface a toast.
  _addIssue(kind) {
    const meta = NEW_ISSUE_META[kind] || NEW_ISSUE_META.task;
    const s = this.getData();
    const num = s.nextNum;
    const code = `ENG-${num}`;
    const assignee = ASSIGNEES[num % ASSIGNEES.length];
    const cols = structuredClone(s.columns);
    const todo = cols.find((c) => c.id === 'todo');
    if (!todo) return;
    todo.cards.unshift({
      id: code,
      code,
      title: meta.title,
      badge: meta.badge,
      badgeVariant: meta.badgeVariant,
      meta: `${code} · new`,
      assignee,
    });
    this.setData({ columns: cols, nextNum: num + 1 });
    this.refresh();
    toast({ title: 'Issue created', message: `${code} added to To do`, variant: 'success' });
  }

  events = {
    // ---- tabs ----
    setTab: (value) => {
      this.setData({ tab: value });
      this.refresh();
    },

    // ---- Kanban move: remove the card from its source column, then splice it into
    // the destination at toIndex (splice-into-the-remaining-list semantics), then
    // refresh so the board — and every derived metric — updates. ----
    moveCard: ({ cardId, toColumnId, toIndex }) => {
      const cols = structuredClone(this.getData().columns);
      let card = null;
      for (const c of cols) {
        const i = c.cards.findIndex((k) => k.id === cardId);
        if (i !== -1) {
          card = c.cards.splice(i, 1)[0];
          break;
        }
      }
      if (!card) return;
      const dest = cols.find((c) => c.id === toColumnId);
      if (!dest) return;
      dest.cards.splice(toIndex, 0, card);
      this.setData({ columns: cols });
      this.refresh();
    },

    // ---- New issue (SplitButton) ----
    newIssue: () => this._addIssue('task'),
    onNewIssueType: (value) => this._addIssue(value),

    // ---- Board actions (DropdownMenu) ----
    onBoardAction: (value) => {
      const labels = {
        rename: 'Rename board',
        duplicate: 'Board duplicated',
        csv: 'Exporting as CSV…',
        json: 'Exporting as JSON…',
        archive: 'Board archived',
      };
      toast({ message: labels[value] || 'Action' });
    },

    // ---- Toolbar ----
    toolbarPress: (value) => {
      const labels = { filter: 'Filter', group: 'Group by', sort: 'Sort' };
      toast({ message: `${labels[value] || value} opened` });
    },
    toolbarToggle: ({ value, pressed }) => {
      if (value === 'subtasks') this.setData({ showSubtasks: pressed });
      if (value === 'compact') this.setData({ compact: pressed });
      this.refresh();
      const labels = { subtasks: 'Subtasks', compact: 'Compact mode' };
      toast({ message: `${labels[value] || value} ${pressed ? 'on' : 'off'}` });
    },

    // ---- Archive project (Popconfirm) ----
    archiveProject: () => {
      toast({ title: 'Project archived', message: 'Aurora 2.0 moved to the archive.' });
    },

    // ---- Delete an issue from the List tab (Popconfirm per row) ----
    removeIssue: (id) => {
      const cols = structuredClone(this.getData().columns);
      let removed = null;
      for (const c of cols) {
        const i = c.cards.findIndex((k) => k.id === id);
        if (i !== -1) {
          removed = c.cards.splice(i, 1)[0];
          break;
        }
      }
      if (!removed) return;
      this.setData({ columns: cols });
      this.refresh();
      toast({ title: 'Issue deleted', message: `${removed.code || id} removed`, variant: 'danger' });
    },

    // ---- Teams tree ----
    treeSelect: (id) => {
      this.setData({ treeValue: id });
      this.refresh();
    },
    treeToggle: ({ expanded }) => {
      this.setData({ treeExpanded: expanded });
      this.refresh();
    },
  };
}

