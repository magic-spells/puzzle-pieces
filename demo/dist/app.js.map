          new ViewNode(ExampleBox, {
            id: 'from-trigger',
            title: 'From a trigger, with morph',
            code: __d.codeMorph,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(DatePicker, {
                label: 'Event date',
                value: __d.morphDate,
                morph: true,
                change: ((this.__h ??= {})[3] ??= (event) => this.events.setMorphDate(event)),
              }, []),
              new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
                new ViewNode('text', { value: 'Calendar is inline-only by design. To open it from a button, compose it through DatePicker — with the morph prop, the trigger itself morphs into the calendar panel.' }),
