            }, []),
            new ViewNode('div', { class: 'space-y-2' }, [
              new ViewNode(Skeleton, {
                variant: 'text',
                class: 'w-full',
              }, []),
              new ViewNode(Skeleton, {
                variant: 'text',
                class: 'w-full',
