                }, []),
                new ViewNode('span', { class: 'text-sm text-muted' }, [
                  new ViewNode('text', { value: '3.5' }),
                ]),
              ]),
              new ViewNode('div', { class: 'flex items-center gap-3' }, [
                new ViewNode(Rating, {
                  value: 4.5,
