
import { PuzzleView } from '@magic-spells/puzzle';
import Toggle from '@/components/ui/Toggle.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Toggle — follows the ButtonDoc exemplar shape.
const installCmd = 'puzzle add piece toggle';
const usageImport = `import Toggle from '@/components/ui/Toggle.pzl';`;
const usageMarkup = `<Toggle variant="outline" pressed={ bold } @change={ setBold }>B</Toggle>`;

const codeHero = `<Toggle variant="outline" pressed={ bold } @change={ setBold }>B</Toggle>
<Toggle variant="outline" pressed={ italic } @change={ setItalic }>I</Toggle>

// parent — owns each pressed boolean, flips it from @change
events = {
  setBold: (v) => this.setData('bold', v),
  setItalic: (v) => this.setData('italic', v),
};`;

const codeVariants = `<Toggle pressed={ a } @change={ setA }>Default</Toggle>
<Toggle variant="outline" pressed={ b } @change={ setB }>Outline</Toggle>`;

const codeSizes = `<Toggle size="sm" pressed={ a } @change={ setA }>Small</Toggle>
<Toggle size="md" pressed={ b } @change={ setB }>Medium</Toggle>
<Toggle size="lg" pressed={ c } @change={ setC }>Large</Toggle>`;

export default class ToggleDoc extends PuzzleView {
  created() {
    this.setData({
      bold: true,
      italic: false,
      vDefault: true,
      vOutline: true,
      sSm: false,
      sMd: true,
      sLg: false,
    });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeVariants,
      codeSizes,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Variants', href: '#variants' },
        { label: 'Sizes', href: '#sizes' },
      ],
    };
  }

  events = {
    setBold: (v) => this.setData('bold', v),
    setItalic: (v) => this.setData('italic', v),
    setVDefault: (v) => this.setData('vDefault', v),
    setVOutline: (v) => this.setData('vOutline', v),
    setSSm: (v) => this.setData('sSm', v),
    setSMd: (v) => this.setData('sMd', v),
    setSLg: (v) => this.setData('sLg', v),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ToggleDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Toggle' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A two-state' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'aria-pressed' }),
            ]),
            new ViewNode('text', { value: 'button for tool states like bold or italic — not a call to action. Controlled: the parent owns' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'pressed' }),
            ]),
            new ViewNode('text', { value: 'and flips it from @change.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
            new ViewNode(Toggle, {
              variant: 'outline',
              pressed: __d.bold,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setBold(event)),
            }, [
              new ViewNode('text', { value: 'B' }),
            ]),
            new ViewNode(Toggle, {
              variant: 'outline',
              pressed: __d.italic,
              change: ((this.__h ??= {})[1] ??= (event) => this.events.setItalic(event)),
            }, [
              new ViewNode('text', { value: 'I' }),
            ]),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'Bold: ' + String(__d.bold ? 'on' : 'off') + ' · Italic: ' + String(__d.italic ? 'on' : 'off') }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'variants',
            title: 'Variants',
            code: __d.codeVariants,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(Toggle, {
                pressed: __d.vDefault,
                change: ((this.__h ??= {})[2] ??= (event) => this.events.setVDefault(event)),
              }, [
                new ViewNode('text', { value: 'Default' }),
              ]),
              new ViewNode(Toggle, {
                variant: 'outline',
                pressed: __d.vOutline,
                change: ((this.__h ??= {})[3] ??= (event) => this.events.setVOutline(event)),
              }, [
                new ViewNode('text', { value: 'Outline' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'sizes',
            title: 'Sizes',
            code: __d.codeSizes,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(Toggle, {
                variant: 'outline',
                size: 'sm',
                pressed: __d.sSm,
                change: ((this.__h ??= {})[4] ??= (event) => this.events.setSSm(event)),
              }, [
                new ViewNode('text', { value: 'Small' }),
              ]),
              new ViewNode(Toggle, {
                variant: 'outline',
                size: 'md',
                pressed: __d.sMd,
                change: ((this.__h ??= {})[5] ??= (event) => this.events.setSMd(event)),
              }, [
                new ViewNode('text', { value: 'Medium' }),
              ]),
              new ViewNode(Toggle, {
                variant: 'outline',
                size: 'lg',
                pressed: __d.sLg,
                change: ((this.__h ??= {})[6] ??= (event) => this.events.setSLg(event)),
              }, [
                new ViewNode('text', { value: 'Large' }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
