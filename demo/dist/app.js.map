              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Space / Enter' }),
                ]),
                new ViewNode('text', { value: ' — select the focused star' }),
              ]),
            ]),
            new ViewNode(ExampleBox, { code: __d.codeKeyboard }, [
              new ViewNode('div', { class: 'flex flex-col items-center gap-3' }, [
