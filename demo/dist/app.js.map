// Docs page for Badge — follows the Button exemplar shape (header → hero
// ExampleBox → Installation → titled example sections → Toc).
const installCmd = 'puzzle add piece badge';
const usageImport = `import Badge from '@/components/ui/Badge.pzl';`;
const usageMarkup = `<Badge>Default</Badge>`;

const codeHero = `<Badge>Default</Badge>
<Badge variant="brand">Brand</Badge>
<Badge variant="danger">Danger</Badge>
<Badge variant="outline">Outline</Badge>`;

const codeContext = `<div class="flex items-center gap-2">
  <h3 class="text-base font-semibold text-ink">Billing plan</h3>
  <Badge variant="brand">Pro</Badge>
</div>

<div class="flex items-center justify-between ...">
  <span>Invoice #1042</span>
  <Badge variant="danger">Overdue</Badge>
</div>`;

export default class BadgeDoc extends PuzzleView {
  data(params, props) {
    return {
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeContext,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'In context', href: '#in-context' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

BadgeDoc.prototype.render = function () {
