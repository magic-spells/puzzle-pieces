
import { PuzzleView } from '@magic-spells/puzzle';
import DescriptionList from '@/components/ui/DescriptionList.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece description-list';
const usageImport = `import DescriptionList from '@/components/ui/DescriptionList.pzl';`;
const usageMarkup = `<DescriptionList items={ items } />`;

const codeHero = `const items = [
  { term: 'Status', description: 'Paid' },
  { term: 'Customer', description: 'Ada Lovelace' },
  { term: 'Placed', description: 'Jan 3, 2026' },
];

<DescriptionList items={ items } />`;

const codeInline = `const items = [
  { term: 'Full name', description: 'Jordan Lee' },
  { term: 'Email', description: 'jordan.lee@example.com' },
  { term: 'Role', description: 'Engineer' },
];

// Two-column grid — the term column stays a fixed-ish width and the
// description column fills. Collapses to one stacked column below sm.
<DescriptionList items={ items } layout="inline" />`;

const codeDividers = `// A hairline border-border rule between rows (never above the first row).
<DescriptionList items={ items } divider />`;

const codeSizes = `<DescriptionList items={ items } layout="inline" divider size="sm" />
<DescriptionList items={ items } layout="inline" divider size="md" />`;

export default class DescriptionListDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeInline,
      codeDividers,
      codeSizes,
      orderItems: [
        { term: 'Status', description: 'Paid' },
        { term: 'Customer', description: 'Ada Lovelace' },
        { term: 'Placed', description: 'Jan 3, 2026' },
      ],
      profileItems: [
        { term: 'Full name', description: 'Jordan Lee' },
        { term: 'Email', description: 'jordan.lee@example.com' },
        { term: 'Role', description: 'Engineer' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Inline layout', href: '#inline' },
        { label: 'Dividers', href: '#dividers' },
        { label: 'Sizes', href: '#sizes' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

DescriptionListDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Description List' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A semantic key-value list rendered from an' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'items' }),
            ]),
            new ViewNode('text', { value: 'array — for detail panels, summaries, and spec sheets. Stacked or inline layout, an optional row divider, and two sizes.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-sm' }, [
            new ViewNode(DescriptionList, { items: __d.orderItems }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Purely presentational — no callbacks, no interactive state. Own any editing UI in the parent and feed a finished' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink' }, [
              new ViewNode('text', { value: 'items' }),
            ]),
            new ViewNode('text', { value: 'array in.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'inline',
            title: 'Inline layout',
            code: __d.codeInline,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(DescriptionList, {
                items: __d.profileItems,
                layout: 'inline',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'dividers',
            title: 'Dividers',
            code: __d.codeDividers,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(DescriptionList, {
                items: __d.orderItems,
                divider: true,
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'sizes',
            title: 'Sizes',
            code: __d.codeSizes,
          }, [
            new ViewNode('div', { class: 'flex w-full max-w-md flex-col gap-8' }, [
              new ViewNode('div', {}, [
                new ViewNode('p', { class: 'mb-2 text-xs font-medium text-muted' }, [
                  new ViewNode('text', { value: 'sm' }),
                ]),
                new ViewNode(DescriptionList, {
                  items: __d.profileItems,
                  layout: 'inline',
                  divider: true,
                  size: 'sm',
                }, []),
              ]),
              new ViewNode('div', {}, [
                new ViewNode('p', { class: 'mb-2 text-xs font-medium text-muted' }, [
                  new ViewNode('text', { value: 'md (default)' }),
                ]),
                new ViewNode(DescriptionList, {
                  items: __d.profileItems,
                  layout: 'inline',
                  divider: true,
                  size: 'md',
                }, []),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
