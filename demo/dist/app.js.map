
import { PuzzleView } from '@magic-spells/puzzle';
import Button from '@/components/ui/Button.pzl';
import Command from '@/components/ui/Command.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';
import { toast } from '@/components/ui/toast.js';

const installCmd = 'puzzle add piece command';
const usageImport = `import Command from '@/components/ui/Command.pzl';`;
const usageMarkup = `<Command open={ commandOpen } items={ commandItems } @select={ runCommand } @close={ closeCommand } />`;

const codeHero = `<Button variant="outline" @press={ openCommand }>Open command palette</Button>
<Command
  open={ commandOpen }
  items={ commandItems }
  @select={ runCommand }
  @close={ closeCommand } />

// items: { value, label, group?, keywords?, hint?, disabled? }
// @select does NOT auto-close — the parent decides what to do next.
events = {
  openCommand: () => this.setData('commandOpen', true),
  closeCommand: () => this.setData('commandOpen', false),
  runCommand: (value) => {
    this.setData('commandOpen', false);
    run(value);
  },
};`;

export default class CommandDoc extends PuzzleView {
  created() {
    this.setData({ commandOpen: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      commandItems: [
        { value: 'new-file', label: 'New file', group: 'General', hint: '⌘ N' },
        { value: 'new-window', label: 'New window', group: 'General' },
        { value: 'open', label: 'Open…', group: 'General', hint: '⌘ O' },
        { value: 'undo', label: 'Undo', group: 'Edit', hint: '⌘ Z' },
        { value: 'redo', label: 'Redo', group: 'Edit' },
        { value: 'copy', label: 'Copy', group: 'Edit', hint: '⌘ C' },
        { value: 'paste', label: 'Paste', group: 'Edit', hint: '⌘ V' },
        { value: 'sidebar', label: 'Toggle sidebar', group: 'View' },
        { value: 'palette', label: 'Command palette', group: 'View', hint: '⌘ K' },
        { value: 'zoom-in', label: 'Zoom in', group: 'View' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Keyboard', href: '#keyboard' },
      ],
    };
  }

  events = {
    openCommand: () => this.setData('commandOpen', true),
    closeCommand: () => this.setData('commandOpen', false),
    runCommand: (value) => {
      this.setData('commandOpen', false);
      toast({ message: 'Ran command: ' + value, variant: 'success' });
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

CommandDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Command' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A command palette — filtered, grouped, keyboard-driven quick actions in a modal on the native dialog element. The parent owns the open flag and decides what each selection does.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(Button, {
            variant: 'outline',
            press: ((this.__h ??= {})[0] ??= (event) => this.events.openCommand(event)),
          }, [
            new ViewNode('text', { value: 'Open command palette' }),
          ]),
          new ViewNode(Command, {
            open: __d.commandOpen,
            items: __d.commandItems,
            select: ((this.__h ??= {})[1] ??= (event) => this.events.runCommand(event)),
            close: ((this.__h ??= {})[2] ??= (event) => this.events.closeCommand(event)),
          }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode('section', {
            id: 'keyboard',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Keyboard' }),
            ]),
            new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
              new ViewNode('text', { value: 'The input holds focus the moment the palette opens. Type to filter — matching is a word-prefix first, then a loose substring, and each item\'s keywords count too. The arrow keys move the active row, Enter runs it, and Escape closes the palette. Open the palette above and try it.' }),
            ]),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'The global hotkey to open the palette is the parent\'s job — bind Cmd/Ctrl+K in a layout and flip the open flag there. Command never binds a page-wide shortcut itself.' }),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
