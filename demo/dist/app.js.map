
import { PuzzleView } from '@magic-spells/puzzle';
import BarChart from '@/components/ui/BarChart.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece bar-chart';
const usageImport = `import BarChart from '@/components/ui/BarChart.pzl';`;
const usageMarkup = `<BarChart data={ salesData } xKey="month" series={ [{ key: 'sales', label: 'Sales' }] } label="Monthly sales" />`;

const codeHero = `const salesData = [
  { month: 'Jan', sales: 4200 },
  { month: 'Feb', sales: 5100 },
  { month: 'Mar', sales: 4800 },
  { month: 'Apr', sales: 6300 },
  { month: 'May', sales: 7100 },
  { month: 'Jun', sales: 6800 },
  { month: 'Jul', sales: 8200 },
  { month: 'Aug', sales: 7600 },
];

// A single series needs no legend — the label says what is plotted.
<BarChart data={ salesData } xKey="month" series={ [{ key: 'sales', label: 'Sales' }] } label="Monthly sales" />`;

const codeGrouped = `const compareData = [
  { quarter: 'Q1', current: 3200, previous: 2400 },
  { quarter: 'Q2', current: 4100, previous: 3300 },
  { quarter: 'Q3', current: 3800, previous: 4000 },
  { quarter: 'Q4', current: 5200, previous: 4300 },
];
const series = [
  { key: 'current', label: '2026' },
  { key: 'previous', label: '2025' },
];

// Two or more series render grouped by default; the legend appears automatically.
<BarChart data={ compareData } xKey="quarter" series={ series } label="Revenue by quarter" />`;

const codeStacked = `const revenueData = [
  { month: 'Jan', product: 3200, services: 1800, other: 900 },
  { month: 'Feb', product: 3600, services: 2100, other: 1100 },
  { month: 'Mar', product: 4100, services: 2400, other: 1000 },
  { month: 'Apr', product: 4800, services: 2600, other: 1300 },
  { month: 'May', product: 5200, services: 3000, other: 1500 },
];
const series = [
  { key: 'product', label: 'Product' },
  { key: 'services', label: 'Services' },
  { key: 'other', label: 'Other' },
];

// A 2px surface gap separates each segment; only the top of the stack is rounded.
<BarChart data={ revenueData } xKey="month" series={ series } stacked label="Revenue by segment" />`;

export default class BarChartDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeGrouped,
      codeStacked,
      salesData: [
        { month: 'Jan', sales: 4200 },
        { month: 'Feb', sales: 5100 },
        { month: 'Mar', sales: 4800 },
        { month: 'Apr', sales: 6300 },
        { month: 'May', sales: 7100 },
        { month: 'Jun', sales: 6800 },
        { month: 'Jul', sales: 8200 },
        { month: 'Aug', sales: 7600 },
      ],
      salesSeries: [{ key: 'sales', label: 'Sales' }],
      compareData: [
        { quarter: 'Q1', current: 3200, previous: 2400 },
        { quarter: 'Q2', current: 4100, previous: 3300 },
        { quarter: 'Q3', current: 3800, previous: 4000 },
        { quarter: 'Q4', current: 5200, previous: 4300 },
      ],
      compareSeries: [
        { key: 'current', label: '2026' },
        { key: 'previous', label: '2025' },
      ],
      revenueData: [
        { month: 'Jan', product: 3200, services: 1800, other: 900 },
        { month: 'Feb', product: 3600, services: 2100, other: 1100 },
        { month: 'Mar', product: 4100, services: 2400, other: 1000 },
        { month: 'Apr', product: 4800, services: 2600, other: 1300 },
        { month: 'May', product: 5200, services: 3000, other: 1500 },
      ],
      revenueSeries: [
        { key: 'product', label: 'Product' },
        { key: 'services', label: 'Services' },
        { key: 'other', label: 'Other' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Grouped', href: '#grouped' },
        { label: 'Stacked', href: '#stacked' },
        { label: 'Accessibility', href: '#accessibility' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

BarChartDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Bar Chart' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A config-first categorical bar chart. Hand it row objects, an' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'xKey' }),
            ]),
            new ViewNode('text', { value: ', and a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'series' }),
            ]),
            new ViewNode('text', { value: 'list — it renders responsive SVG bars with a legend, per-bar hover tooltips, and an accessible data table. One series draws a plain bar chart; multiple series render grouped, or stacked with' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'stacked' }),
            ]),
            new ViewNode('text', { value: '.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full' }, [
            new ViewNode(BarChart, {
              data: __d.salesData,
              xKey: 'month',
              series: __d.salesSeries,
              label: 'Monthly sales',
            }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece and its math helper into your app — they compile with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Bars are true SVG paths with 4px-rounded tops and a flat baseline; colors are assigned in fixed slot order (first series → chart-1). The chart is presentational — own the data in the parent and feed it in. Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'grouped',
            title: 'Grouped',
            code: __d.codeGrouped,
          }, [
            new ViewNode('div', { class: 'w-full' }, [
              new ViewNode(BarChart, {
                data: __d.compareData,
                xKey: 'quarter',
                series: __d.compareSeries,
                label: 'Revenue by quarter, year over year',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'stacked',
            title: 'Stacked',
            code: __d.codeStacked,
          }, [
            new ViewNode('div', { class: 'w-full' }, [
              new ViewNode(BarChart, {
                data: __d.revenueData,
                xKey: 'month',
                series: __d.revenueSeries,
                stacked: true,
                label: 'Revenue by segment',
              }, []),
            ]),
          ]),
          new ViewNode('section', {
            id: 'accessibility',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Accessibility' }),
            ]),
            new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
              new ViewNode('text', { value: 'The root is a' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: String('<figure>') }),
              ]),
              new ViewNode('text', { value: 'with an' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'aria-label' }),
              ]),
              new ViewNode('text', { value: 'from the' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'label' }),
              ]),
              new ViewNode('text', { value: 'prop, and the decorative SVG is marked' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'aria-hidden="true"' }),
              ]),
              new ViewNode('text', { value: '. Every value is also emitted as a visually hidden' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: String('<table>') }),
              ]),
              new ViewNode('text', { value: 'after the plot, so the data is reachable by screen readers and never gated behind a hover tooltip. Colors carry series identity, but the legend and table carry it too — nothing depends on color alone.' }),
            ]),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'Always pass a descriptive' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'label' }),
              ]),
              new ViewNode('text', { value: '— it names both the figure and the data table.' }),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
