// Docs page for Marquee — follows the CarouselDoc / ScrollAreaDoc exemplar shape.
const installCmd = 'puzzle add piece marquee';
const usageImport = `import Marquee from '@/components/ui/Marquee.pzl';`;
const usageMarkup = `<Marquee class="w-full rounded-xl border border-border bg-surface py-4"></Marquee>`;

const codeHero = `// Items are the default-slot children — the piece clones them to loop.
<Marquee class="w-full rounded-xl border border-border bg-surface py-4">
  <span class="px-4 text-lg font-semibold text-ink">Acme</span>
  <span class="px-4 text-lg font-semibold text-ink">Globex</span>
  <span class="px-4 text-lg font-semibold text-ink">Initech</span>
  <span class="px-4 text-lg font-semibold text-ink">Umbrella</span>
</Marquee>`;

const codeDirection = `// direction: 'left' (default) | 'right' | 'up' | 'down'.
// up/down switch the track to a vertical column.
<Marquee direction="right" class="w-full ...">
  <span>One</span>
  <span>Two</span>
  <span>Three</span>
</Marquee>`;

const codeAnnouncement = `// A single-line announcement ticker.
<Marquee class="w-full rounded-xl bg-brand py-2.5 text-brand-ink">
  <span class="px-6 text-sm font-medium">Free shipping on orders over $50</span>
  <span class="px-6 text-sm font-medium">New winter collection now live</span>
  <span class="px-6 text-sm font-medium">Members get 20% off this week</span>
</Marquee>`;

const codePause = `// pauseOnHover defaults to true; set false to keep scrolling.
<Marquee pauseOnHover={ false } class="w-full ...">
  <span>Keeps scrolling even under the pointer</span>
  <span>Set pauseOnHover to false</span>
</Marquee>`;

const codeSpeed = `// speed is pixels per second (default 40; larger = faster).
<Marquee speed={ 20 } class="w-full ...">…slow…</Marquee>
<Marquee speed={ 90 } class="w-full ...">…fast…</Marquee>`;

