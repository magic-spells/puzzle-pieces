
import { PuzzleView } from '@magic-spells/puzzle';
import DatePicker from '@/components/ui/DatePicker.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for DatePicker — follows the ButtonDoc exemplar (header → hero ExampleBox
// → Installation → titled example sections → Toc). Parent-owned: the view holds each
// ISO value and DatePicker forwards Calendar's @change back into it (lifted from the
// DatePicker section of the old Forms view).

// Three files: the picker, the Calendar it composes, and the shared date helper.
const installCmd = 'puzzle add piece date-picker';
const usageImport = `import DatePicker from '@/components/ui/DatePicker.pzl';`;
const usageMarkup = `<DatePicker label="Ship date" hint="We deliver Monday through Friday." value={ shipDate } @change={ setShipDate } />`;

const morphInstall = 'npm install @magic-spells/morph-engine';

const codeHero = `<DatePicker
  label="Ship date"
  hint="We deliver Monday through Friday."
  value={ shipDate }
  @change={ setShipDate } />

// parent
events = {
  setShipDate: (iso) => this.setData('shipDate', iso),
};`;

const codeError = `<DatePicker
  label="Deadline"
  error="Please choose a date."
  value={ date }
  @change={ setDate } />`;

const codeMorph = `// npm install @magic-spells/morph-engine
<DatePicker
  label="Event date"
  value={ date }
  morph={ true }
  @change={ setDate } />`;

const codeBounds = `<DatePicker
  label="Within July"
  min="2026-07-01"
  max="2026-07-31"
  value={ date }
  @change={ setDate } />`;

const codeFormats = `<!-- format: short | medium (default) | long | full -->
<DatePicker label="Meeting" format="short" value={ date } @change={ setDate } />
<DatePicker label="Meeting" format="long" value={ date } @change={ setDate } />`;

export default class DatePickerDoc extends PuzzleView {
  created() {
    this.setData({
      shipDate: '',
      errorDate: '',
      morphDate: '2026-08-01',
      boundedDate: '2026-07-16',
      fmtDate: '2026-07-16',
    });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      morphInstall,
      codeHero,
      codeError,
      codeMorph,
      codeBounds,
      codeFormats,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Error state', href: '#error' },
        { label: 'Morph', href: '#morph' },
        { label: 'Bounds', href: '#bounds' },
        { label: 'Formats', href: '#formats' },
      ],
    };
  }

  events = {
    setShipDate: (iso) => this.setData('shipDate', iso),
    setErrorDate: (iso) => this.setData('errorDate', iso),
    setMorphDate: (iso) => this.setData('morphDate', iso),
    setBoundedDate: (iso) => this.setData('boundedDate', iso),
    setFmtDate: (iso) => this.setData('fmtDate', iso),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

DatePickerDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Date Picker' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A Field-shaped trigger and popover that composes the Calendar piece: a controlled ISO' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: ', a locale-aware trigger label, label / hint / error, and an optional trigger↔panel morph. It is parent-owned — it forwards Calendar\'s' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: 'up, closes, and returns focus to the trigger.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-xs' }, [
            new ViewNode(DatePicker, {
              label: 'Ship date',
              hint: 'We deliver Monday through Friday.',
              value: __d.shipDate,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setShipDate(event)),
            }, []),
          ]),
        ]),
        new ViewNode('p', { class: 'mt-4 text-sm text-muted' }, [
          new ViewNode('text', { value: 'DatePicker composes the Calendar piece inside a popover and auto-flips it above the trigger when the trigger sits near the bottom of the viewport.' }),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the picker, the Calendar it composes, and the date helper they share:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'date-math.js is a shared lib file — both pieces import it as ../../lib/date-math.js. Keep it in app/lib/.' }),
          ]),
          new ViewNode(CodeBlock, {
            code: __d.morphInstall,
            class: 'mt-4',
          }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Only needed for the morph prop — DatePicker imports @magic-spells/morph-engine lazily and degrades to a plain popover without it (or under reduced motion).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'error',
            title: 'Error state',
            code: __d.codeError,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(DatePicker, {
                label: 'Deadline',
                error: 'Please choose a date.',
                value: __d.errorDate,
                change: ((this.__h ??= {})[1] ??= (event) => this.events.setErrorDate(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'morph',
            title: 'Morph',
            code: __d.codeMorph,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(DatePicker, {
                label: 'Event date',
                value: __d.morphDate,
                morph: true,
                change: ((this.__h ??= {})[2] ??= (event) => this.events.setMorphDate(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'bounds',
            title: 'Bounds',
            code: __d.codeBounds,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(DatePicker, {
                label: 'Within July',
                min: '2026-07-01',
                max: '2026-07-31',
                value: __d.boundedDate,
                change: ((this.__h ??= {})[3] ??= (event) => this.events.setBoundedDate(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'formats',
            title: 'Formats',
            code: __d.codeFormats,
          }, [
            new ViewNode('div', { class: 'grid w-full max-w-lg gap-4 sm:grid-cols-2' }, [
              new ViewNode(DatePicker, {
                label: 'short',
                format: 'short',
                value: __d.fmtDate,
                change: ((this.__h ??= {})[4] ??= (event) => this.events.setFmtDate(event)),
              }, []),
              new ViewNode(DatePicker, {
                label: 'medium',
                format: 'medium',
                value: __d.fmtDate,
                change: ((this.__h ??= {})[5] ??= (event) => this.events.setFmtDate(event)),
              }, []),
              new ViewNode(DatePicker, {
                label: 'long',
                format: 'long',
                value: __d.fmtDate,
                change: ((this.__h ??= {})[6] ??= (event) => this.events.setFmtDate(event)),
              }, []),
              new ViewNode(DatePicker, {
                label: 'full',
                format: 'full',
                value: __d.fmtDate,
                change: ((this.__h ??= {})[7] ??= (event) => this.events.setFmtDate(event)),
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
