
import { PuzzleView } from '@magic-spells/puzzle';
import PieChart from '@/components/ui/PieChart.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece pie-chart';
const usageImport = `import PieChart from '@/components/ui/PieChart.pzl';`;
const usageMarkup = `<PieChart data={ trafficData } label="Traffic by source" totalLabel="Sessions" />`;

const codeHero = `const trafficData = [
  { label: 'Organic', value: 4200 },
  { label: 'Direct', value: 3100 },
  { label: 'Referral', value: 1900 },
  { label: 'Social', value: 1400 },
  { label: 'Email', value: 800 },
];

// donut defaults to true; totalLabel fills the center with the summed total.
<PieChart data={ trafficData } label="Traffic by source" totalLabel="Sessions" />`;

const codePlain = `// donut={ false } draws a solid pie instead of a ring.
<PieChart data={ trafficData } donut={ false } label="Traffic by source" />`;

const codeFolding = `const countryData = [
  { label: 'United States', value: 5200 },
  { label: 'Germany', value: 3100 },
  { label: 'India', value: 2600 },
  { label: 'Brazil', value: 1800 },
  { label: 'Japan', value: 1500 },
  { label: 'France', value: 1200 },
  { label: 'Canada', value: 950 },
  { label: 'Australia', value: 700 },
  { label: 'Spain', value: 520 },
  { label: 'Italy', value: 410 },
];

// 10 slices → the 7 largest stay; the rest fold into "Other" (always chart-8).
<PieChart data={ countryData } label="Users by country" totalLabel="Users" />`;

export default class PieChartDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codePlain,
      codeFolding,
      trafficData: [
        { label: 'Organic', value: 4200 },
        { label: 'Direct', value: 3100 },
        { label: 'Referral', value: 1900 },
        { label: 'Social', value: 1400 },
        { label: 'Email', value: 800 },
      ],
      countryData: [
        { label: 'United States', value: 5200 },
        { label: 'Germany', value: 3100 },
        { label: 'India', value: 2600 },
        { label: 'Brazil', value: 1800 },
        { label: 'Japan', value: 1500 },
        { label: 'France', value: 1200 },
        { label: 'Canada', value: 950 },
        { label: 'Australia', value: 700 },
        { label: 'Spain', value: 520 },
        { label: 'Italy', value: 410 },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Plain pie', href: '#plain' },
        { label: 'Legend and folding', href: '#folding' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

PieChartDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Pie Chart' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A config-first part-to-whole donut. Hand it an array of' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: String(__d.label, __d.value) }),
            ]),
            new ViewNode('text', { value: 'and it renders slices in fixed slot colors, an always-present legend, per-slice hover tooltips with percent-of-total, and an accessible data table. Pass' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'totalLabel' }),
            ]),
            new ViewNode('text', { value: 'to fill the donut center with the summed total.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(PieChart, {
            data: __d.trafficData,
            label: 'Traffic by source',
            totalLabel: 'Sessions',
          }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece and its math helper into your app — they compile with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'A pie shows positive parts of a whole, so zero and negative values are dropped. Reach for it only for at-a-glance proportions with a handful of slices — for comparing close values, a bar chart is clearer. Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'plain',
            title: 'Plain pie',
            code: __d.codePlain,
          }, [
            new ViewNode(PieChart, {
              data: __d.trafficData,
              donut: false,
              label: 'Traffic by source',
            }, []),
          ]),
          new ViewNode('section', {
            id: 'folding',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Legend and folding' }),
            ]),
            new ViewNode('p', { class: 'mb-4 text-sm text-body' }, [
              new ViewNode('text', { value: 'The legend is always present — slices are the series, so color-matching alone is never required. When the data has more than eight slices, the seven largest are kept and the rest fold into a single ' }),
              new ViewNode('span', { class: 'font-medium text-ink' }, [
                new ViewNode('text', { value: 'Other' }),
              ]),
              new ViewNode('text', { value: ' slice, so the palette is never cycled past its eight validated slots.' }),
            ]),
            new ViewNode(ExampleBox, { code: __d.codeFolding }, [
              new ViewNode(PieChart, {
                data: __d.countryData,
                label: 'Users by country',
                totalLabel: 'Users',
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
