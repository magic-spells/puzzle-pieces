
import { PuzzleView } from '@magic-spells/puzzle';
import Popover from '@/components/ui/Popover.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece popover';
const usageImport = `import Popover from '@/components/ui/Popover.pzl';`;
const usageMarkup = `<Popover align="start"></Popover>`;

const codeHero = `<Popover align="start">
  <span slot="trigger" class="…">Show details</span>
  <div class="space-y-2">
    <p class="font-medium text-ink">Dimensions</p>
    <p>A popover holds any content — text, controls, a small form.</p>
  </div>
</Popover>`;

const codePlacement = `<Popover side="bottom" align="start">…</Popover>
<Popover side="bottom" align="center">…</Popover>
<Popover side="top" align="end">…</Popover>

// side  — "bottom" (default) or "top"; flips automatically when the
//          requested edge lacks room for the measured panel.
// align — "start" (default), "center", or "end" along the trigger's edge.`;

export default class PopoverDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codePlacement,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Placement', href: '#placement' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

PopoverDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Popover' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A click-toggled floating panel holding arbitrary content. It is not modal and does not trap focus; an outside click or Escape closes it, and it flips sides when the requested edge runs out of room.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(Popover, { align: 'start' }, [
            new ViewNode('span', {
              slot: 'trigger',
              class: 'inline-flex h-9 items-center gap-1 rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken',
            }, [
              new ViewNode('text', { value: 'Show details' }),
            ]),
            new ViewNode('div', { class: 'space-y-2' }, [
              new ViewNode('p', { class: 'font-medium text-ink' }, [
                new ViewNode('text', { value: 'Dimensions' }),
              ]),
              new ViewNode('p', {}, [
                new ViewNode('text', { value: 'A popover holds any content — text, controls, a small form. It is not modal and does not trap focus.' }),
              ]),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'placement',
            title: 'Placement',
            code: __d.codePlacement,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-4' }, [
              new ViewNode(Popover, {
                side: 'bottom',
                align: 'start',
              }, [
                new ViewNode('span', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken',
                }, [
                  new ViewNode('text', { value: 'Bottom start' }),
                ]),
                new ViewNode('p', {}, [
                  new ViewNode('text', { value: 'Opens below, left-aligned to the trigger.' }),
                ]),
              ]),
              new ViewNode(Popover, {
                side: 'bottom',
                align: 'center',
              }, [
                new ViewNode('span', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken',
                }, [
                  new ViewNode('text', { value: 'Bottom center' }),
                ]),
                new ViewNode('p', {}, [
                  new ViewNode('text', { value: 'Opens below, centered on the trigger.' }),
                ]),
              ]),
              new ViewNode(Popover, {
                side: 'top',
                align: 'end',
              }, [
                new ViewNode('span', {
                  slot: 'trigger',
                  class: 'inline-flex h-9 items-center rounded-lg border border-border bg-surface px-4 text-sm font-medium text-ink hover:bg-surface-sunken',
                }, [
                  new ViewNode('text', { value: 'Top end' }),
                ]),
                new ViewNode('p', {}, [
                  new ViewNode('text', { value: 'Opens above, right-aligned to the trigger.' }),
                ]),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
