                new ViewNode('text', { value: ' — fills the cell and advances to the next' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Paste a code' }),
                ]),
                new ViewNode('text', { value: ' — distributes left-to-right from the focused cell, landing on the next empty cell' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Backspace' }),
                ]),
                new ViewNode('text', { value: ' — clears the current cell, or on an empty cell moves back and clears the previous one' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Delete' }),
                ]),
                new ViewNode('text', { value: ' — clears the current cell in place' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Left / Right arrows' }),
                ]),
                new ViewNode('text', { value: ' — move between cells' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Home / End' }),
                ]),
                new ViewNode('text', { value: ' — jump to the first or last cell' }),
              ]),
            ]),
            new ViewNode(ExampleBox, { code: __d.codeKeyboard }, [
              new ViewNode(InputOtp, {
                value: __d.code,
                change: ((this.__h ??= {})[6] ??= (event) => this.events.setCode(event)),
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
