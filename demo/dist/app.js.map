
import { PuzzleView } from '@magic-spells/puzzle';
import TimePicker from '@/components/ui/TimePicker.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for TimePicker — follows the DatePickerDoc exemplar (header → hero
// ExampleBox → Installation → titled example sections → Keyboard table → Toc).
// Parent-owned: the view holds each "HH:MM[:SS]" value and TimePicker forwards its
// @change back into it.

const installCmd = 'puzzle add piece time-picker';
const usageImport = `import TimePicker from '@/components/ui/TimePicker.pzl';`;
const usageMarkup = `<TimePicker label="Meeting time" hint="24-hour clock." value={ meeting } @change={ setMeeting } />`;

const codeHero = `<TimePicker
  label="Meeting time"
  hint="24-hour clock."
  value={ meeting }
  @change={ setMeeting } />

// parent
events = {
  setMeeting: (value) => this.setData('meeting', value),
};`;

const codeTwelve = `<!-- hourCycle 12 adds an am/pm column; value stays 24h canonical -->
<TimePicker
  label="Reminder"
  hourCycle={ 12 }
  value={ time }
  @change={ setTime } />`;

const codeSeconds = `<TimePicker
  label="Lap time"
  seconds={ true }
  value={ time }
  @change={ setTime } />   <!-- emits "HH:MM:SS" -->`;

const codeStep = `<!-- thin the minutes column to :00 :15 :30 :45 -->
<TimePicker
  label="Slot"
  minuteStep={ 15 }
  value={ time }
  @change={ setTime } />`;

const codeControlled = `<TimePicker
  label="Departure"
  value={ time }
  open={ open }
  @change={ setTime }
  @show={ () => this.setData('open', true) }
  @hide={ () => this.setData('open', false) } />`;

const codeError = `<TimePicker
  label="Start"
  error="Please choose a start time."
  value={ time }
  @change={ setTime } />`;

export default class TimePickerDoc extends PuzzleView {
  created() {
    this.setData({
      meeting: '09:30',
      reminder: '14:15',
      lap: '00:01:30',
      slot: '10:45',
      departure: '18:20',
      depOpen: false,
      startTime: '',
    });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeTwelve,
      codeSeconds,
      codeStep,
      codeControlled,
      codeError,
      keys: [
        { key: '↑ / ↓', desc: 'Move the highlighted option within the focused column.' },
        { key: '← / →', desc: 'Move focus between the hour, minute, second, and am/pm columns.' },
        { key: 'Home / End', desc: 'Jump to the first / last option in the focused column.' },
        { key: 'Enter / Space', desc: 'Confirm the current time and close, returning focus to the trigger.' },
        { key: 'Escape', desc: 'Close the popover and return focus to the trigger.' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: '12-hour (am/pm)', href: '#twelve-hour' },
        { label: 'With seconds', href: '#seconds' },
        { label: 'Minute step', href: '#step' },
        { label: 'Controlled open', href: '#controlled' },
        { label: 'Error state', href: '#error' },
        { label: 'Keyboard', href: '#keyboard' },
      ],
    };
  }

  events = {
    setMeeting: (value) => this.setData('meeting', value),
    setReminder: (value) => this.setData('reminder', value),
    setLap: (value) => this.setData('lap', value),
    setSlot: (value) => this.setData('slot', value),
    setDeparture: (value) => this.setData('departure', value),
    openDeparture: () => this.setData('depOpen', true),
    closeDeparture: () => this.setData('depOpen', false),
    setStartTime: (value) => this.setData('startTime', value),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

TimePickerDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Time Picker' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A Field-shaped trigger and popover for choosing a time: scrolling hour / minute (and optional seconds) listbox columns, with a 12-hour am/pm or 24-hour display. The controlled' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: 'is always stored as a 24-hour' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '"HH:MM"' }),
            ]),
            new ViewNode('text', { value: 'string — display format never leaks into it. It is parent-owned: it emits' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: 'on every column pick.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-xs' }, [
            new ViewNode(TimePicker, {
              label: 'Meeting time',
              hint: '24-hour clock.',
              value: __d.meeting,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setMeeting(event)),
            }, []),
          ]),
        ]),
        new ViewNode('p', { class: 'mt-4 text-sm text-muted' }, [
          new ViewNode('text', { value: 'Focus lands in the hours column on open. Arrow up/down moves within a column, arrow left/right jumps between columns, and the popover auto-flips above the trigger near the bottom of the viewport.' }),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the picker into your components directory — it ships self-contained (no lib dependency, no npm packages):' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'twelve-hour',
            title: '12-hour (am/pm)',
            code: __d.codeTwelve,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(TimePicker, {
                label: 'Reminder',
                hourCycle: 12,
                value: __d.reminder,
                change: ((this.__h ??= {})[1] ??= (event) => this.events.setReminder(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'seconds',
            title: 'With seconds',
            code: __d.codeSeconds,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(TimePicker, {
                label: 'Lap time',
                seconds: true,
                value: __d.lap,
                change: ((this.__h ??= {})[2] ??= (event) => this.events.setLap(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'step',
            title: 'Minute step',
            code: __d.codeStep,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(TimePicker, {
                label: 'Slot',
                minuteStep: 15,
                value: __d.slot,
                change: ((this.__h ??= {})[3] ??= (event) => this.events.setSlot(event)),
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'controlled',
            title: 'Controlled open',
            code: __d.codeControlled,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(TimePicker, {
                label: 'Departure',
                value: __d.departure,
                open: __d.depOpen,
                change: ((this.__h ??= {})[4] ??= (event) => this.events.setDeparture(event)),
                show: ((this.__h ??= {})[5] ??= (event) => this.events.openDeparture(event)),
                hide: ((this.__h ??= {})[6] ??= (event) => this.events.closeDeparture(event)),
              }, []),
              new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
                new ViewNode('text', { value: 'Panel is ' + String(__d.depOpen ? 'open' : 'closed') + ' · value ' + String(__d.departure || '—') }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'error',
            title: 'Error state',
            code: __d.codeError,
          }, [
            new ViewNode('div', { class: 'w-full max-w-xs' }, [
              new ViewNode(TimePicker, {
                label: 'Start',
                error: 'Please choose a start time.',
                value: __d.startTime,
                change: ((this.__h ??= {})[7] ??= (event) => this.events.setStartTime(event)),
              }, []),
            ]),
          ]),
          new ViewNode('section', {
            id: 'keyboard',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Keyboard' }),
            ]),
            new ViewNode('div', { class: 'overflow-hidden rounded-xl border border-border' }, [
              new ViewNode('table', { class: 'w-full text-sm' }, [
                new ViewNode('tbody', { class: 'divide-y divide-border' },
                  __d.keys.map((row) =>
                    new ViewNode('tr', { key: ViewNode.keyOf(row) }, [
                      new ViewNode('td', { class: 'w-40 whitespace-nowrap px-4 py-2.5 align-top' }, [
                        new ViewNode('kbd', {
                          class: 'rounded border border-border bg-surface-sunken px-1.5 py-0.5 font-mono text-xs text-ink',
                        }, [
                          new ViewNode('text', { value: String(row.key) }),
                        ]),
                      ]),
                      new ViewNode('td', { class: 'px-4 py-2.5 text-body' }, [
                        new ViewNode('text', { value: String(row.desc) }),
                      ]),
                    ])
                  )
                ),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
