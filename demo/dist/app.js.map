
import { PuzzleView } from '@magic-spells/puzzle';
import ChatAttachment from '@/components/ui/ChatAttachment.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece chat-attachment';
const usageImport = `import ChatAttachment from '@/components/ui/ChatAttachment.pzl';`;
const usageMarkup = `<ChatAttachment name="proposal.pdf" size="2.4 MB" />`;

const codeHero = `<ChatAttachment name="proposal.pdf" size="2.4 MB" />
<ChatAttachment name="hero.png" size="840 KB" />
<ChatAttachment name="assets.zip" size="18 MB" />`;

const codeRemovable = `// The chip is value-first: it fires @remove(name, event). The parent owns
// the list and filters the removed file out.
data() {
  return { files: [
    { name: 'proposal.pdf', size: '2.4 MB' },
    { name: 'hero.png', size: '840 KB' },
    { name: 'assets.zip', size: '18 MB' },
  ] };
}
events = {
  removeFile: (name) =>
    this.setData({ files: this.getData().files.filter((f) => f.name !== name) }),
};

{#for file in files}
  <ChatAttachment name={ file.name } size={ file.size } removable
                  @remove={ removeFile } />
{/for}`;

const codeTypes = `// type is inferred from the extension: image / video / audio / archive,
// else the generic 'file' document icon. Pass type explicitly for
// extensionless names.
<ChatAttachment name="report.pdf" size="1.1 MB" />      <!-- file -->
<ChatAttachment name="screenshot.png" size="620 KB" />  <!-- image -->
<ChatAttachment name="demo.mp4" size="42 MB" />         <!-- video -->
<ChatAttachment name="voice-memo.m4a" size="3.2 MB" />  <!-- audio -->
<ChatAttachment name="release.zip" size="18 MB" />      <!-- archive -->
<ChatAttachment name="build" type="archive" size="9 MB" />`;

const codeLinks = `// href wraps the chip body in a download link. disabled dims it and
// blocks both the link and the remove button.
<ChatAttachment name="invoice.pdf" size="212 KB" href="/files/invoice.pdf" />
<ChatAttachment name="brand-kit.zip" size="24 MB" href="/files/brand-kit.zip" />
<ChatAttachment name="archived.pdf" size="1 MB" disabled />`;

const INITIAL_FILES = [
  { name: 'proposal.pdf', size: '2.4 MB' },
  { name: 'hero.png', size: '840 KB' },
  { name: 'assets.zip', size: '18 MB' },
];

export default class ChatAttachmentDoc extends PuzzleView {
  data(params, props) {
    const prev = this.getData();
    return {
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeRemovable,
      codeTypes,
      codeLinks,
      files: prev && prev.files ? prev.files : INITIAL_FILES.slice(),
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Removable', href: '#removable' },
        { label: 'Types', href: '#types' },
        { label: 'Download links', href: '#links' },
      ],
    };
  }

  events = {
    removeFile: (name) =>
      this.setData({ files: this.getData().files.filter((f) => f.name !== name) }),
    resetFiles: () => this.setData({ files: INITIAL_FILES.slice() }),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ChatAttachmentDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Chat Attachment' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A file chip for message attachments and upload previews. The leading icon is inferred from the filename extension, the name truncates with a hover title, and' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'href' }),
            ]),
            new ViewNode('text', { value: '/' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'removable' }),
            ]),
            new ViewNode('text', { value: 'turn it into a download link or a dismissible chip.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-wrap gap-2' }, [
            new ViewNode(ChatAttachment, {
              name: 'proposal.pdf',
              size: '2.4 MB',
            }, []),
            new ViewNode(ChatAttachment, {
              name: 'hero.png',
              size: '840 KB',
            }, []),
            new ViewNode(ChatAttachment, {
              name: 'assets.zip',
              size: '18 MB',
            }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'The' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink' }, [
              new ViewNode('text', { value: 'size' }),
            ]),
            new ViewNode('text', { value: 'prop is a preformatted string — the chip does no byte math. Removal is delegated: the chip never mutates a list itself, it fires' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink' }, [
              new ViewNode('text', { value: '@remove(name)' }),
            ]),
            new ViewNode('text', { value: 'and the parent drops the file.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'removable',
            title: 'Removable',
            code: __d.codeRemovable,
          }, [
            new ViewNode('div', { class: 'flex min-h-[3rem] flex-wrap items-start gap-2' }, [
              ...__d.files.map((file) =>
                new ViewNode(ChatAttachment, {
                  key: ViewNode.keyOf(file),
                  name: file.name,
                  size: file.size,
                  removable: true,
                  remove: ((this.__h ??= {})[0] ??= (event) => this.events.removeFile(event)),
                }, [])
              ),
              ...(__d.files.length === 0
                ? [
                    new ViewNode('p', { class: 'text-sm text-muted' }, [
                      new ViewNode('text', { value: 'All attachments removed.' }),
                      new ViewNode('button', {
                        type: 'button',
                        class: 'text-brand underline cursor-pointer',
                        '@click': ((this.__h ??= {})[1] ??= (event) => this.events.resetFiles(event)),
                      }, [
                        new ViewNode('text', { value: 'Reset' }),
                      ]),
                    ]),
                  ]
                : [
                    new ViewNode('#'),
                  ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'types',
            title: 'Types',
            code: __d.codeTypes,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap gap-2' }, [
              new ViewNode(ChatAttachment, {
                name: 'report.pdf',
                size: '1.1 MB',
              }, []),
              new ViewNode(ChatAttachment, {
                name: 'screenshot.png',
                size: '620 KB',
              }, []),
              new ViewNode(ChatAttachment, {
                name: 'demo.mp4',
                size: '42 MB',
              }, []),
              new ViewNode(ChatAttachment, {
                name: 'voice-memo.m4a',
                size: '3.2 MB',
              }, []),
              new ViewNode(ChatAttachment, {
                name: 'release.zip',
                size: '18 MB',
              }, []),
              new ViewNode(ChatAttachment, {
                name: 'build',
                type: 'archive',
                size: '9 MB',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'links',
            title: 'Download links',
            code: __d.codeLinks,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap gap-2' }, [
              new ViewNode(ChatAttachment, {
                name: 'invoice.pdf',
                size: '212 KB',
                href: '#invoice',
              }, []),
              new ViewNode(ChatAttachment, {
                name: 'brand-kit.zip',
                size: '24 MB',
                href: '#brand-kit',
              }, []),
              new ViewNode(ChatAttachment, {
                name: 'archived.pdf',
                size: '1 MB',
                disabled: true,
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
