
import { PuzzleView } from '@magic-spells/puzzle';
import AvatarGroup from '@/components/ui/AvatarGroup.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for AvatarGroup — follows the Avatar exemplar shape (header →
// hero ExampleBox → Installation → titled example sections → Toc). Purely
// presentational piece, so no interactive state — data() just returns the
// example avatar arrays, code consts, and toc.
const installCmd = 'puzzle add piece avatar-group';
const usageImport = `import AvatarGroup from '@/components/ui/AvatarGroup.pzl';`;
const usageMarkup = `<AvatarGroup avatars={[ { name: 'Ada Lovelace' }, { src: '/grace.jpg', name: 'Grace Hopper' }, { name: 'Alan Turing' }, { name: 'Katherine Johnson' }, { name: 'Linus Torvalds' }, ]} max={ 4 } size="lg" label="5 collaborators" />`;

const codeHero = `<AvatarGroup
  avatars={[
    { name: 'Ada Lovelace' },
    { src: '/grace.jpg', name: 'Grace Hopper' },
    { name: 'Alan Turing' },
    { name: 'Katherine Johnson' },
    { name: 'Linus Torvalds' },
  ]}
  max={ 4 }
  size="lg"
  label="5 collaborators"
/>`;

const codeOverflow = `// 5 avatars, max=3 — the remaining 2 fold into a "+2" chip.
<AvatarGroup avatars={ team } max={ 3 } />`;

const codeNoOverflow = `// avatars.length <= max — every avatar renders, no chip.
<AvatarGroup avatars={[
  { name: 'Ada Lovelace' },
  { name: 'Grace Hopper' },
]} max={ 4 } />`;

const codeSizes = `<AvatarGroup avatars={ team } max={ 4 } size="sm" />
<AvatarGroup avatars={ team } max={ 4 } size="md" />
<AvatarGroup avatars={ team } max={ 4 } size="lg" />`;

const codeLargeTeam = `// 16 avatars, max=4 — the chip reads "+12".
<AvatarGroup avatars={ largeTeam } max={ 4 } label="16 collaborators" />`;

const NAMES = [
  'Ada Lovelace', 'Grace Hopper', 'Alan Turing', 'Katherine Johnson',
  'Linus Torvalds', 'Barbara Liskov', 'Margaret Hamilton', 'Dennis Ritchie',
  'Radia Perlman', 'Tim Berners-Lee', 'Hedy Lamarr', 'John McCarthy',
  'Frances Allen', 'Vint Cerf', 'Shafi Goldwasser', 'Donald Knuth',
];

export default class AvatarGroupDoc extends PuzzleView {
  data(params, props) {
    return {
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeOverflow,
      codeNoOverflow,
      codeSizes,
      codeLargeTeam,
      team: [
        { name: 'Ada Lovelace' },
        { src: 'https://i.pravatar.cc/80?img=13', name: 'Grace Hopper' },
        { name: 'Alan Turing' },
        { name: 'Katherine Johnson' },
        { name: 'Linus Torvalds' },
      ],
      pair: [
        { name: 'Ada Lovelace' },
        { name: 'Grace Hopper' },
      ],
      largeTeam: NAMES.map((name) => ({ name })),
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Overflow chip', href: '#overflow' },
        { label: 'No overflow', href: '#no-overflow' },
        { label: 'Sizes', href: '#sizes' },
        { label: 'Large team', href: '#large-team' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

AvatarGroupDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Avatar Group' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An overlapping stack of avatars rendered from an array, with a "+N" overflow chip once the count exceeds a max. Composes the Avatar piece for each disc, so image/initials/glyph fallback behavior matches Avatar exactly.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, {
          code: __d.codeHero,
          tall: false,
        }, [
          new ViewNode(AvatarGroup, {
            avatars: __d.team,
            max: 4,
            size: 'lg',
            label: '5 collaborators',
          }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours. AvatarGroup composes the Avatar piece, so copy both:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'overflow',
            title: 'Overflow chip',
            code: __d.codeOverflow,
            tall: false,
          }, [
            new ViewNode(AvatarGroup, {
              avatars: __d.team,
              max: 3,
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'no-overflow',
            title: 'No overflow',
            code: __d.codeNoOverflow,
            tall: false,
          }, [
            new ViewNode(AvatarGroup, {
              avatars: __d.pair,
              max: 4,
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'sizes',
            title: 'Sizes',
            code: __d.codeSizes,
            tall: false,
          }, [
            new ViewNode('div', { class: 'flex flex-col items-start gap-4' }, [
              new ViewNode(AvatarGroup, {
                avatars: __d.team,
                max: 4,
                size: 'sm',
              }, []),
              new ViewNode(AvatarGroup, {
                avatars: __d.team,
                max: 4,
                size: 'md',
              }, []),
              new ViewNode(AvatarGroup, {
                avatars: __d.team,
                max: 4,
                size: 'lg',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'large-team',
            title: 'Large team',
            code: __d.codeLargeTeam,
            tall: false,
          }, [
            new ViewNode(AvatarGroup, {
              avatars: __d.largeTeam,
              max: 4,
              label: '16 collaborators',
            }, []),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
