];

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

// Full "$1,234.56" (with sign) for human-facing labels.
function usd(n) {
  const sign = n < 0 ? '-' : '';
  const abs = Math.abs(Number(n) || 0);
  return `${sign}$${abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}

// Compact axis money format for the chart ("$47k").
function fmtMoney(n) {
  const v = Number(n) || 0;
  return v >= 1000 || v <= -1000 ? `$${Math.round(v / 1000)}k` : `$${v}`;
}

// "Jul 18" from an ISO date, avoiding timezone drift by parsing the parts.
function shortDate(iso) {
  const [, m, d] = String(iso).split('-').map(Number);
  return `${MONTHS[(m || 1) - 1]} ${d}`;
}

const badgeForStatus = (status) =>
  status === 'Failed' ? 'danger' : status === 'Pending' ? 'brand' : 'default';

export default class BankingDemo extends PuzzleView {
  created() {
    this.setData({
      tab: 'overview',
      // DataTable controlled sort + page.
      txSort: { key: 'date', dir: 'desc' },
      txPage: 1,
      // DateRangePicker controlled value.
      range: { start: '', end: '' },
      // Transfer dialog + form.
      transferOpen: false,
      transferFrom: 'operating',
      transferTo: null,
      transferAmount: null,
      transferMemo: '',
      // Top-bar account switcher.
      activeAccount: 'operating',
    });
  }

  data() {
    const s = this.getData();

    // --- date-range filter over the transactions (inclusive; ISO strings compare
    // lexically = chronologically) ---
    const { start, end } = s.range;
    const hasRangeFilter = !!(start || end);
    const filtered = TRANSACTIONS.filter((t) => {
      if (start && t.date < start) return false;
      if (end && t.date > end) return false;
      return true;
    });

    // DataTable rows: amount as a signed 2dp string so the comparator sorts it
    // numerically while the cell still shows cents.
    const txRows = filtered.map((t) => ({
      id: t.id,
      date: t.date,
      merchant: t.merchant,
      category: t.category,
      status: t.status,
      amount: t.amount.toFixed(2),
    }));

    // Richer recent-activity list (Avatar + Badge + colored amount).
    const recentRows = TRANSACTIONS.slice(0, 6).map((t) => ({
      id: t.id,
      merchant: t.merchant,
      category: t.category,
      dateLabel: shortDate(t.date),
      status: t.status,
      badgeVariant: badgeForStatus(t.status),
      amountLabel: (t.amount >= 0 ? '+' : '') + usd(t.amount),
      amountClass: t.amount >= 0 ? 'text-success' : 'text-ink',
    }));

    // Transfer validation.
    const amt = typeof s.transferAmount === 'number' ? s.transferAmount : 0;
    const available = 128430;
    const overBalance = amt > available;
    const transferValid = amt > 0 && !overBalance && !!s.transferTo;
    const amountError = overBalance ? 'Exceeds available balance' : '';
    const amountHint = overBalance ? '' : `Available: ${usd(available)}`;
    const sendLabel = amt > 0 ? `Send ${usd(amt)}` : 'Send';

    return {
      // nav / chrome
      navItems: NAV_ITEMS,
      accountOptions: ACCOUNT_OPTIONS,
      activeAccount: s.activeAccount,
      teamAvatars: TEAM_AVATARS,
      sendActions: SEND_ACTIONS,

      // tabs
      tabItems: TAB_ITEMS,
      tab: s.tab,

      // stat cards
      totalBalance: '$284,120.40',
      sparkTotal: [231, 240, 236, 252, 261, 258, 270, 274, 279, 284],
      sparkOperating: [119, 124, 121, 128, 126, 131, 129, 127, 130, 128],
      sparkReserve: [138, 140, 139, 141, 142, 141, 143, 142, 143, 143],
      sparkSpend: [44, 42, 45, 41, 43, 40, 41, 39, 40, 39],

      // overview
      cashflowRows: CASHFLOW_ROWS,
      cashflowSeries: CASHFLOW_SERIES,
      fmtMoney,
      recentRows,
      accountDetails: ACCOUNT_DETAILS,
      budgets: BUDGETS,

      // transactions
      txColumns: TX_COLUMNS,
      txRows,
      txSort: s.txSort,
      txPage: s.txPage,
      range: s.range,
      rangePresets: RANGE_PRESETS,
      hasRangeFilter,
      txCountLabel: `${filtered.length} transaction${filtered.length === 1 ? '' : 's'}`,

      // cards
      cards: CARDS,

      // transfer dialog
      transferOpen: s.transferOpen,
      transferFrom: s.transferFrom,
      transferTo: s.transferTo,
      transferAmount: s.transferAmount,
      transferMemo: s.transferMemo,
      recipientOptions: RECIPIENT_OPTIONS,
      transferValid,
      amountError,
      amountHint,
      sendLabel,
    };
  }

  events = {
    // ---- tabs ----
    setTab: (value) => {
      this.setData({ tab: value });
      this.refresh();
    },
    goToTransactions: () => {
      this.setData({ tab: 'transactions' });
      this.refresh();
    },

    // ---- top bar ----
    setActiveAccount: (value) => {
      this.setData({ activeAccount: value });
      this.refresh();
    },
    onSendAction: (value) => {
      const labels = { request: 'Request money', wire: 'Wire transfer', schedule: 'Schedule transfer' };
      toast({ title: labels[value] || 'Action', message: 'Opening flow…' });
    },

    // ---- transactions table ----
    setSort: (next) => {
      this.setData({ txSort: next, txPage: 1 });
      this.refresh();
    },
    setPage: (n) => {
      this.setData({ txPage: n });
      this.refresh();
    },
    setRange: (range) => {
      // Reset to page 1 so the filtered set never lands on an empty page.
      this.setData({ range, txPage: 1 });
      this.refresh();
    },
    clearRange: () => {
      this.setData({ range: { start: '', end: '' }, txPage: 1 });
      this.refresh();
    },

    // ---- transfer dialog ----
    openTransfer: () => {
      this.setData({ transferOpen: true });
      this.refresh();
    },
    closeTransfer: () => {
      this.setData({ transferOpen: false });
      this.refresh();
    },
    setTransferFrom: (value) => {
      this.setData({ transferFrom: value });
      this.refresh();
    },
    setTransferTo: (value) => {
      this.setData({ transferTo: value });
      this.refresh();
    },
    setTransferAmount: (value) => {
      this.setData({ transferAmount: value });
      this.refresh();
    },
    setTransferMemo: (value) => {
      this.setData({ transferMemo: value });
      this.refresh();
    },
    submitTransfer: () => {
      const s = this.getData();
      const amt = typeof s.transferAmount === 'number' ? s.transferAmount : 0;
      if (!(amt > 0) || !s.transferTo) return;
      const recipient = (RECIPIENT_OPTIONS.find((r) => r.value === s.transferTo) || {}).label || 'recipient';
      toast({ title: 'Transfer sent', message: `${usd(amt)} to ${recipient}`, variant: 'success' });
      this.setData({ transferOpen: false, transferTo: null, transferAmount: null, transferMemo: '' });
      this.refresh();
    },

    noop: () => {},
  };
}

