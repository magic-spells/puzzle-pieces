
import { PuzzleView } from '@magic-spells/puzzle';
import DataTable from '@/components/ui/DataTable.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece data-table';
const usageImport = `import DataTable from '@/components/ui/DataTable.pzl';`;
const usageMarkup = `<DataTable columns={ columns } rows={ rows } rowKey="invoice" selectable pageSize={ 5 } />`;

const codeHero = `const columns = [
  { key: 'invoice', label: 'Invoice', sortable: true },
  { key: 'client', label: 'Client', sortable: true },
  { key: 'status', label: 'Status' },
  { key: 'amount', label: 'Amount', align: 'right', sortable: true },
];

// rowKey is the stable id used for selection; pageSize turns on pagination.
<DataTable columns={ columns } rows={ rows } rowKey="invoice"
           selectable pageSize={ 5 } />`;

const codeSorting = `// Sort is optional-controlled: the parent owns the descriptor and
// @sortChange hands back the next state on each header click. The table
// applies it to the full row set (numeric compare when both cells read as
// finite numbers, else localeCompare). Omit sort to let the table own it.
<DataTable columns={ columns } rows={ rows } rowKey="invoice"
           sort={ sort } @sortChange={ setSort } />

events = {
  setSort: (next) => this.setData({ sort: next }),   // { key, dir } | null
};`;

const codeSelection = `// selected is an array of rowKey values; @select fires the next array.
// Keys are row ids, so a selection survives sorting and paging. The header
// checkbox selects/clears the current page and goes indeterminate when
// the page is partially selected.
<DataTable columns={ columns } rows={ rows } rowKey="invoice"
           selectable selected={ selected } @select={ setSelected } />
<p>{ selected.length } selected</p>

events = {
  setSelected: (keys) => this.setData({ selected: keys }),
};`;

const codePagination = `// pageSize enables pagination (rows are sorted, THEN paged); the footer
// shows "x–y of z" and the Pagination strip. page is optional-controlled —
// omit it to let the table track the page itself.
<DataTable columns={ columns } rows={ rows } rowKey="invoice"
           pageSize={ 4 } page={ page } @pageChange={ setPage } />

events = {
  setPage: (n) => this.setData({ page: n }),
};`;

const INVOICE_COLUMNS = [
  { key: 'invoice', label: 'Invoice', sortable: true },
  { key: 'client', label: 'Client', sortable: true },
  { key: 'status', label: 'Status' },
  { key: 'amount', label: 'Amount', align: 'right', sortable: true },
];

const INVOICE_ROWS = [
  { invoice: 'INV-1042', client: 'Acme Inc.', status: 'Paid', amount: 1200 },
  { invoice: 'INV-1043', client: 'Globex', status: 'Pending', amount: 980 },
  { invoice: 'INV-1044', client: 'Initech', status: 'Paid', amount: 3450 },
  { invoice: 'INV-1045', client: 'Umbrella Co.', status: 'Overdue', amount: 540 },
  { invoice: 'INV-1046', client: 'Soylent', status: 'Draft', amount: 120 },
  { invoice: 'INV-1047', client: 'Hooli', status: 'Paid', amount: 2760 },
  { invoice: 'INV-1048', client: 'Vehement Capital', status: 'Pending', amount: 1890 },
  { invoice: 'INV-1049', client: 'Massive Dynamic', status: 'Paid', amount: 4300 },
  { invoice: 'INV-1050', client: 'Stark Industries', status: 'Overdue', amount: 760 },
  { invoice: 'INV-1051', client: 'Wayne Enterprises', status: 'Draft', amount: 315 },
  { invoice: 'INV-1052', client: 'Cyberdyne', status: 'Paid', amount: 2050 },
  { invoice: 'INV-1053', client: 'Wonka Industries', status: 'Pending', amount: 640 },
];

export default class DataTableDoc extends PuzzleView {
  created() {
    this.setData({ sortState: { key: 'amount', dir: 'desc' }, selectedKeys: [], pageNum: 1 });
  }

  data(params, props) {
    const d = this.getData();
    const sortState = d.sortState || null;
    return {
      ...d,
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeSorting,
      codeSelection,
      codePagination,
      invoiceColumns: INVOICE_COLUMNS,
      invoiceRows: INVOICE_ROWS,
      shortRows: INVOICE_ROWS.slice(0, 5),
      selectedCount: (d.selectedKeys || []).length,
      sortLabel: sortState ? `${sortState.key} · ${sortState.dir}` : 'none',
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Sorting', href: '#sorting' },
        { label: 'Selection', href: '#selection' },
        { label: 'Pagination', href: '#pagination' },
        { label: 'Accessibility', href: '#accessibility' },
      ],
    };
  }

  events = {
    setSort: (next) => {
      this.setData('sortState', next);
      this.refresh();
    },
    setSelected: (keys) => {
      this.setData('selectedKeys', keys);
      this.refresh();
    },
    setPageNum: (n) => {
      this.setData('pageNum', n);
      this.refresh();
    },
  };
}

