
import { PuzzleView } from '@magic-spells/puzzle';

// Textarea — Field's composite pattern for multi-line text: label, hint/error,
// and ARIA wiring come built in. Controlled: the parent owns `value` and
// updates it from `@change`. An `error` string replaces the `hint`, flips
// aria-invalid, and paints the border/ring danger. A stable id is generated
// when `id` is absent so the label can target the control. `rows` sets the
// initial height; the box grows with resize-y.
//
//   <Textarea label="Bio" value={ bio } @change={ setBio } />
//   <Textarea label="Notes" rows={ 6 } hint="Markdown supported" />
//   <Textarea label="Message" value={ msg } error="Message is required" />
let uid = 0;

const INPUT_BASE =
  'block w-full rounded-lg border bg-surface px-3 py-2 text-sm text-ink placeholder:text-muted ' +
  'resize-y ' +
  'transition-colors ' +
  'focus-visible:outline-2 focus-visible:outline-offset-2 ' +
  'disabled:opacity-50';
const INPUT_OK = 'border-border outline-ring focus-visible:outline-ring';
const INPUT_ERROR = 'border-danger outline-danger focus-visible:outline-danger';

export default class Textarea extends PuzzleView {
  data(params, props) {
    // Fallback id is generated once per instance so it survives re-renders; an
    // explicit `id` prop always wins.
    const id = props.id || (this._fallbackId ??= `pp-textarea-${++uid}`);
    const error = props.error || '';
    const hint = props.hint || '';
    const described = !!(error || hint);
    return {
      id,
      descId: `${id}-desc`,
      value: props.value ?? '',
      placeholder: props.placeholder,
      name: props.name,
      rows: props.rows || 4,
      label: props.label,
      hint,
      error,
      disabled: !!props.disabled,
      required: !!props.required,
      invalid: error ? 'true' : false,
      describedby: described ? `${id}-desc` : false,
      rootClass: props.class || '',
      inputClass: [INPUT_BASE, error ? INPUT_ERROR : INPUT_OK].join(' '),
    };
  }

  events = {
    handleInput: (event) => {
      const { change } = this.props;
      if (typeof change === 'function') change(event.target.value, event);
    },
    handleBlur: (event) => {
      const { blur } = this.props;
      if (typeof blur === 'function') blur(event);
    },
    handleFocus: (event) => {
      const { focus } = this.props;
      if (typeof focus === 'function') focus(event);
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

Textarea.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('div', { class: __d.rootClass }, [
    ...(__d.label
      ? [
          new ViewNode('label', {
            for: __d.id,
            class: 'mb-1.5 block text-sm font-medium text-ink',
          }, [
            new ViewNode('text', { value: String(__d.label) }),
          ]),
        ]
      : [
          new ViewNode('#'),
        ]),
    new ViewNode('textarea', {
      id: __d.id,
      class: __d.inputClass,
      rows: __d.rows,
      placeholder: __d.placeholder,
      name: __d.name,
      disabled: __d.disabled,
      required: __d.required,
      'aria-invalid': __d.invalid,
      'aria-describedby': __d.describedby,
      '@input': ((this.__h ??= {})[0] ??= (event) => this.events.handleInput(event)),
      '@blur': ((this.__h ??= {})[1] ??= (event) => this.events.handleBlur(event)),
      '@focus': ((this.__h ??= {})[2] ??= (event) => this.events.handleFocus(event)),
    }, [
      new ViewNode('text', { value: String(__d.value) }),
    ]),
    ...(__d.error
      ? [
          new ViewNode('p', {
            id: __d.descId,
            class: 'mt-1.5 text-sm text-danger',
          }, [
            new ViewNode('text', { value: String(__d.error) }),
          ]),
        ]
      : [
          ...(__d.hint
            ? [
                new ViewNode('p', {
                  id: __d.descId,
                  class: 'mt-1.5 text-sm text-muted',
                }, [
                  new ViewNode('text', { value: String(__d.hint) }),
                ]),
              ]
            : [
                new ViewNode('#'),
              ]),
        ]),
  ]);
};
