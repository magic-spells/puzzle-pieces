
import { PuzzleView } from '@magic-spells/puzzle';
import Rating from '@/components/ui/Rating.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece rating';
const usageImport = `import Rating from '@/components/ui/Rating.pzl';`;
const usageMarkup = `<Rating value={ score } size="lg" @change={ setScore } />`;

const codeHero = `<Rating value={ score } size="lg" @change={ setScore } />

// parent — input mode commits whole-star values
events = {
  setScore: (v) => this.setData('score', v),
};`;

const codeDisplay = `// readOnly renders a static row; the value rounds to the nearest half.
<Rating value={ 3.5 } readOnly />
<Rating value={ 4.5 } readOnly />`;

const codeSizes = `<Rating value={ 4 } readOnly size="sm" />
<Rating value={ 4 } readOnly size="md" />
<Rating value={ 4 } readOnly size="lg" />`;

const codeColors = `// Filled stars inherit the root text color — pass any text-* token to retint.
<Rating value={ 4 } readOnly class="text-amber-500" />
<Rating value={ 4 } readOnly class="text-danger" />
<Rating value={ 4 } readOnly class="text-success" />`;

const codeForms = `// name emits a hidden input carrying the whole-star value for form posts.
<Rating value={ formScore } name="rating" @change={ setFormScore } />`;

const codeKeyboard = `<Rating value={ kbdScore } @change={ setKbd } />

// Focus a star, then Arrow keys move the value, Home/End jump to the ends,
// Space/Enter selects. Halves are display-only; input commits whole stars.`;

export default class RatingDoc extends PuzzleView {
  created() {
    this.setData({ score: 3, formScore: 4, kbdScore: 2 });
  }

  data(params, props) {
    const d = this.getData();
    return {
      ...d,
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeDisplay,
      codeSizes,
      codeColors,
      codeForms,
      codeKeyboard,
      scoreLabel: d.score > 0 ? `${d.score} of 5` : 'unrated',
      kbdLabel: d.kbdScore > 0 ? `${d.kbdScore} of 5` : 'unrated',
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Display', href: '#display' },
        { label: 'Sizes', href: '#sizes' },
        { label: 'Colors', href: '#colors' },
        { label: 'Forms', href: '#forms' },
        { label: 'Keyboard', href: '#keyboard' },
      ],
    };
  }

  events = {
    setScore: (v) => {
      this.setData('score', v);
      this.refresh();
    },
    setFormScore: (v) => {
      this.setData('formScore', v);
      this.refresh();
    },
    setKbd: (v) => {
      this.setData('kbdScore', v);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

RatingDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Rating' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A star rating in two modes. Read-only' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'display' }),
            ]),
            new ViewNode('text', { value: 'supports half stars; interactive input is an accessible radiogroup with arrow-key navigation and a hover preview. It is controlled — the parent owns' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
