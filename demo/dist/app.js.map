
import { PuzzleView } from '@magic-spells/puzzle';
import Collapsible from '@/components/ui/Collapsible.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Collapsible — follows the ButtonDoc exemplar shape.
const installCmd = 'puzzle add piece collapsible';
const usageImport = `import Collapsible from '@/components/ui/Collapsible.pzl';`;
const usageMarkup = `<Collapsible label="Shipping and returns" open={ open } @change={ setOpen }></Collapsible>`;

const codeHero = `<Collapsible label="Shipping and returns" open={ open } @change={ setOpen }>
  <div class="space-y-2">
    <p>Free standard shipping on orders over 50 dollars.</p>
    <ul class="list-disc pl-5">
      <li>Delivered in 3–5 business days</li>
      <li>Returns accepted within 30 days</li>
    </ul>
  </div>
</Collapsible>

// parent — owns the open boolean, flips it from @change
events = { setOpen: (open) => this.setData('open', open) };`;

const codeExclusivity = `const richFaq = [
  { id: 'r1', label: 'When should I reach for Accordion?', body: '…' },
  { id: 'r2', label: 'And when Collapsible?', body: '…' },
  { id: 'r3', label: 'Can I have both?', body: '…' },
];

// One parent-owned open id → rich content AND one-open-at-a-time.
<div class="divide-y divide-border border-y border-border">
  {#for item in richFaq}
    <Collapsible label={ item.label }
                 open={ openId === item.id }
                 @change={ toggleGroup(item.id) }>
      <p>{ item.body }</p>
    </Collapsible>
  {/for}
</div>

// parent — clicking the open one closes it, otherwise switches
events = {
  toggleGroup: (id) =>
    this.setData('openId', this.getData().openId === id ? null : id),
};`;

export default class CollapsibleDoc extends PuzzleView {
  created() {
    this.setData({ heroOpen: false, groupId: 'r1' });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeExclusivity,
      richFaq: [
        { id: 'r1', label: 'When should I reach for Accordion?', body: 'When a set of plain-text panels should coordinate — opening one closes the rest.' },
        { id: 'r2', label: 'And when Collapsible?', body: 'For one-off disclosures, or when the panel body needs real markup — Collapsible takes rich slot content.' },
        { id: 'r3', label: 'Can I have both?', body: 'This group is Collapsibles composed with a parent-owned open id — rich content AND exclusivity.' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Composed exclusivity', href: '#exclusivity' },
      ],
    };
  }

  events = {
    setHeroOpen: (open) => this.setData('heroOpen', open),
    toggleGroup: (id) => this.setData('groupId', this.getData().groupId === id ? null : id),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

CollapsibleDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Collapsible' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An animated disclosure whose body height eases 0 to measured over a' }),
            new ViewNode('strong', { class: 'font-medium text-ink' }, [
              new ViewNode('text', { value: 'speed-based' }),
            ]),
            new ViewNode('text', { value: ' duration. Closed, it carries' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'inert' }),
            ]),
            new ViewNode('text', { value: 'and aria-hidden, so its content leaves the tab order. The parent owns' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'open' }),
            ]),
            new ViewNode('text', { value: '.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-md rounded-xl border border-border bg-surface p-4' }, [
            new ViewNode(Collapsible, {
              label: 'Shipping and returns',
              open: __d.heroOpen,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setHeroOpen(event)),
            }, [
              new ViewNode('div', { class: 'space-y-2' }, [
                new ViewNode('p', {}, [
                  new ViewNode('text', { value: 'Free standard shipping on orders over 50 dollars. Expedited options are shown at checkout.' }),
                ]),
                new ViewNode('ul', { class: 'list-disc space-y-1 pl-5 text-muted' }, [
                  new ViewNode('li', {}, [
                    new ViewNode('text', { value: 'Delivered in 3–5 business days' }),
                  ]),
                  new ViewNode('li', {}, [
                    new ViewNode('text', { value: 'Returns accepted within 30 days' }),
                  ]),
                ]),
              ]),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'exclusivity',
            title: 'Composed exclusivity',
            code: __d.codeExclusivity,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode('p', { class: 'mb-3 text-xs font-medium text-muted' }, [
                new ViewNode('text', { value: 'Rich content AND one-open-at-a-time: Collapsibles sharing a parent-owned open id.' }),
              ]),
              new ViewNode('div', { class: 'divide-y divide-border border-y border-border' },
                __d.richFaq.map((item) =>
                  new ViewNode(Collapsible, {
                    key: ViewNode.keyOf(item),
                    label: item.label,
                    open: __d.groupId === item.id,
                    change: (event) => this.events.toggleGroup(item.id),
                  }, [
                    new ViewNode('p', {}, [
                      new ViewNode('text', { value: String(item.body) }),
                    ]),
                  ])
                )
              ),
            ]),
          ]),
        ]),
        new ViewNode('section', { class: 'mt-8 max-w-3xl' }, [
          new ViewNode('p', { class: 'text-sm text-body' }, [
            new ViewNode('text', { value: 'No Accordion component is needed for exclusivity — track one open id in the parent and pass each Collapsible a derived boolean. This keeps rich slot markup per panel while still closing the others. When your panels are plain text, reach for' }),
            new ViewNode('strong', { class: 'font-medium text-ink' }, [
              new ViewNode('text', { value: 'Accordion' }),
            ]),
            new ViewNode('text', { value: ' instead: it renders the whole set from one config array.' }),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
