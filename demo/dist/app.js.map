
import { PuzzleView } from '@magic-spells/puzzle';
import Stepper from '@/components/ui/Stepper.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece stepper';
const usageImport = `import Stepper from '@/components/ui/Stepper.pzl';`;
const usageMarkup = `<Stepper steps={ checkout } value={ 1 } />`;

const codeHero = `const checkout = [
  { label: 'Cart' },
  { label: 'Details' },
  { label: 'Payment' },
  { label: 'Review' },
];

// value is the current step index — the parent owns it.
<Stepper steps={ checkout } value={ 1 } />`;

const codeVertical = `const onboarding = [
  { label: 'Create account', description: 'Your name and a password.' },
  { label: 'Verify email', description: 'Confirm the link we sent.' },
  { label: 'Invite team', description: 'Add teammates by email.' },
  { label: 'Done', description: 'Start using the workspace.' },
];

<Stepper steps={ onboarding } value={ 1 } orientation="vertical" />`;

const codeClickable = `// Completed/current steps become buttons; @stepChange fires on activation.
<Stepper steps={ checkout } value={ step } clickable @stepChange={ setStep } />

// parent
events = {
  setStep: (i) => this.setData('step', i),
  next: () => this.setData('step', Math.min(this.getData().step + 1, 3)),
  back: () => this.setData('step', Math.max(this.getData().step - 1, 0)),
};`;

const codeStates = `// Steps before value are complete, value is current, the rest are upcoming.
<Stepper steps={ steps } value={ 2 } />`;

export default class StepperDoc extends PuzzleView {
  created() {
    this.setData({ stepHero: 1, stepVert: 1, stepClick: 1 });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeVertical,
      codeClickable,
      codeStates,
      checkout: [
        { label: 'Cart' },
        { label: 'Details' },
        { label: 'Payment' },
        { label: 'Review' },
      ],
      onboarding: [
        { label: 'Create account', description: 'Your name and a password.' },
        { label: 'Verify email', description: 'Confirm the link we sent.' },
        { label: 'Invite team', description: 'Add teammates by email.' },
        { label: 'Done', description: 'Start using the workspace.' },
      ],
      states: [
        { label: 'Complete' },
        { label: 'Complete' },
        { label: 'Current' },
        { label: 'Upcoming' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Vertical orientation', href: '#vertical' },
        { label: 'Clickable steps', href: '#clickable' },
        { label: 'States', href: '#states' },
      ],
    };
  }

  events = {
    setStepClick: (i) => this.setData('stepClick', i),
    nextClick: () => this.setData('stepClick', Math.min(this.getData().stepClick + 1, 3)),
    backClick: () => this.setData('stepClick', Math.max(this.getData().stepClick - 1, 0)),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

StepperDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Stepper' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A numbered step-progress indicator for wizards and checkouts. It renders from a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'steps' }),
            ]),
            new ViewNode('text', { value: 'array and marks each step complete, current, or upcoming — horizontally or vertically, with optionally clickable steps.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-2xl' }, [
            new ViewNode(Stepper, {
              steps: __d.checkout,
              value: __d.stepHero,
            }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'vertical',
            title: 'Vertical orientation',
            code: __d.codeVertical,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(Stepper, {
                steps: __d.onboarding,
                value: __d.stepVert,
                orientation: 'vertical',
              }, []),
            ]),
          ]),
          new ViewNode('p', { class: 'text-sm text-body' }, [
            new ViewNode('text', { value: 'Pass an optional' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'description' }),
            ]),
            new ViewNode('text', { value: 'on any step and it renders beneath the label. Vertical is the natural fit when steps carry longer descriptions.' }),
          ]),
          new ViewNode(ExampleBox, {
            id: 'clickable',
            title: 'Clickable steps',
            code: __d.codeClickable,
          }, [
            new ViewNode('div', { class: 'w-full max-w-2xl space-y-6' }, [
              new ViewNode(Stepper, {
                steps: __d.checkout,
                value: __d.stepClick,
                clickable: true,
                stepChange: ((this.__h ??= {})[0] ??= (event) => this.events.setStepClick(event)),
              }, []),
              new ViewNode('div', { class: 'flex items-center gap-2' }, [
                new ViewNode('button', {
                  type: 'button',
                  class: 'rounded-md border border-border bg-surface px-3 py-1.5 text-sm font-medium text-ink transition-colors hover:bg-surface-sunken disabled:pointer-events-none disabled:opacity-50 focus-visible:outline-2 focus-visible:outline-offset-2 outline-ring focus-visible:outline-ring',
                  disabled: __d.stepClick === 0,
                  '@click': ((this.__h ??= {})[1] ??= (event) => this.events.backClick(event)),
                }, [
                  new ViewNode('text', { value: 'Back' }),
                ]),
                new ViewNode('button', {
                  type: 'button',
                  class: 'rounded-md bg-brand px-3 py-1.5 text-sm font-medium text-brand-ink transition-colors hover:opacity-90 disabled:pointer-events-none disabled:opacity-50 focus-visible:outline-2 focus-visible:outline-offset-2 outline-ring focus-visible:outline-ring',
                  disabled: __d.stepClick === 3,
                  '@click': ((this.__h ??= {})[2] ??= (event) => this.events.nextClick(event)),
                }, [
                  new ViewNode('text', { value: 'Next' }),
                ]),
              ]),
            ]),
          ]),
          new ViewNode('p', { class: 'text-sm text-body' }, [
            new ViewNode('text', { value: 'In' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'clickable' }),
            ]),
            new ViewNode('text', { value: 'mode every reachable step (completed or current) is a real' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: String('<button>') }),
            ]),
            new ViewNode('text', { value: 'and activating one fires' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@stepChange(index)' }),
            ]),
            new ViewNode('text', { value: '. Upcoming steps stay non-interactive — advance them from your own controls, like the Back / Next buttons here.' }),
          ]),
          new ViewNode(ExampleBox, {
            id: 'states',
            title: 'States',
            code: __d.codeStates,
          }, [
            new ViewNode('div', { class: 'w-full max-w-2xl' }, [
              new ViewNode(Stepper, {
                steps: __d.states,
                value: 2,
              }, []),
            ]),
          ]),
          new ViewNode('p', { class: 'text-sm text-body' }, [
            new ViewNode('text', { value: 'Each step is derived from' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: ': steps before it are complete (filled, with a check), the step at' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: 'is current (ringed, carrying' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'aria-current="step"' }),
            ]),
            new ViewNode('text', { value: '), and later steps are upcoming (muted).' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: 'is optional-controlled: omit it and a clickable Stepper tracks the current step itself.' }),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
