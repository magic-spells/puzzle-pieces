                '@click': ((this.__h ??= {})[10] ??= (event) => this.events.openMorph(event)),
              }, [
                new ViewNode('p', { class: 'text-xs font-medium uppercase tracking-wide text-muted' }, [
                  new ViewNode('text', { value: 'Container transform' }),
