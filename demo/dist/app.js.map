              new ViewNode(Rating, {
                value: 4,
                readOnly: true,
                size: 'md',
              }, []),
              new ViewNode(Rating, {
                value: 4,
                readOnly: true,
                size: 'lg',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'colors',
