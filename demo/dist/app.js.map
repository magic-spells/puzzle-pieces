
import { PuzzleView } from '@magic-spells/puzzle';
import Field from '@/components/ui/Field.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Field — follows the ButtonDoc exemplar shape.
const installCmd = 'puzzle add piece field';
const usageImport = `import Field from '@/components/ui/Field.pzl';`;
const usageMarkup = `<Field label="Full name" placeholder="Ada Lovelace" value={ name } @change={ setName } />`;

const codeHero = `<Field label="Full name" placeholder="Ada Lovelace" value={ name } @change={ setName } />

// parent
events = {
  setName: (v) => this.setData('name', v),
};`;

const codeHint = `<Field label="Company" hint="As it appears on your invoice" placeholder="Acme Inc." />`;

const codeError = `<Field label="Email" value="taken@example.com" error="That address is already in use" />`;

const codeDisabled = `<Field label="Read-only" value="Locked field" disabled />`;

export default class FieldDoc extends PuzzleView {
  created() {
    this.setData({ name: '' });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeHint,
      codeError,
      codeDisabled,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Hint', href: '#hint' },
        { label: 'Error', href: '#error' },
        { label: 'Disabled', href: '#disabled' },
      ],
    };
  }

  events = {
    setName: (v) => this.setData('name', v),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

FieldDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Field' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'The workhorse labeled text input — label, hint or error helper text, and ARIA wiring come built in. Controlled: the parent owns the value and updates it from' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: '.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-sm' }, [
            new ViewNode(Field, {
              label: 'Full name',
              placeholder: 'Ada Lovelace',
              value: __d.name,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setName(event)),
            }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'hint',
            title: 'Hint',
            code: __d.codeHint,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(Field, {
                label: 'Company',
                hint: 'As it appears on your invoice',
                placeholder: 'Acme Inc.',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'error',
            title: 'Error',
            code: __d.codeError,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(Field, {
                label: 'Email',
                value: 'taken@example.com',
                error: 'That address is already in use',
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'disabled',
            title: 'Disabled',
            code: __d.codeDisabled,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm' }, [
              new ViewNode(Field, {
                label: 'Read-only',
                value: 'Locked field',
                disabled: true,
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
