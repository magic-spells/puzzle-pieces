
import { PuzzleView } from '@magic-spells/puzzle';
import { GETTING_STARTED, SECTIONS } from '../../docs/nav.js';

// SideNav — the left component navigation (docs-only). Reads the generated
// nav.js config: a "Getting started" block, then one labeled section per
// component category (Forms / Overlays / Feedback / Content). Section labels
// are text-ink so the groups read at a glance; the entry matching the current
// path (passed by the layout) gets the active pill. Links are plain <a href>
// so the SPA router handles them.
//
//   <SideNav path={ path }/>
const LINK =
  'block rounded-md px-3 py-1.5 text-sm transition-colors ' +
  'outline-ring focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-ring';
const IDLE = `${LINK} text-muted hover:bg-surface-sunken hover:text-ink`;
const ACTIVE = `${LINK} bg-surface-sunken font-medium text-ink`;

export default class SideNav extends PuzzleView {
  data(params, props) {
    const path = props.path || '/';
    const mark = (items) =>
      items.map((item) => ({
        ...item,
        class: item.path === path ? ACTIVE : IDLE,
      }));
    return {
      started: mark(GETTING_STARTED),
      sections: SECTIONS.map((s) => ({ label: s.label, items: mark(s.items) })),
      rootClass: props.class || '',
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

SideNav.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('nav', {
    class: __d.rootClass,
    'aria-label': 'Components',
  }, [
    new ViewNode('p', { class: 'mb-2 px-3 text-xs font-semibold uppercase tracking-[0.16em] text-ink' }, [
      new ViewNode('text', { value: 'Getting started' }),
    ]),
    new ViewNode('ul', { class: 'space-y-0.5' },
      __d.started.map((item) =>
        new ViewNode('li', { key: item.path }, [
          new ViewNode('a', {
            href: item.path,
            class: item.class,
          }, [
            new ViewNode('text', { value: String(item.title) }),
          ]),
        ])
      )
    ),
    ...__d.sections.map((section) =>
      new ViewNode('div', {
        key: section.label,
        class: 'mt-6',
      }, [
        new ViewNode('p', { class: 'mb-2 px-3 text-xs font-semibold uppercase tracking-[0.16em] text-ink' }, [
          new ViewNode('text', { value: String(section.label) }),
        ]),
        new ViewNode('ul', { class: 'space-y-0.5' },
          section.items.map((item) =>
            new ViewNode('li', { key: item.path }, [
              new ViewNode('a', {
                href: item.path,
                class: item.class,
              }, [
                new ViewNode('text', { value: String(item.title) }),
              ]),
            ])
          )
        ),
      ])
    ),
  ]);
};
