
import { PuzzleView } from '@magic-spells/puzzle';
import ChatScroller from '../components/ui/ChatScroller.pzl';
import ChatMessage from '../components/ui/ChatMessage.pzl';
import ChatAttachment from '../components/ui/ChatAttachment.pzl';
import Button from '../components/ui/Button.pzl';

// Seeded conversation. align/variant/showMeta are derived in data() so the
// message data stays clean (showMeta drops when the previous row shares the
// same author — the compact follow-up treatment).
const SEED = [
  { author: 'Grace Hopper', time: '9:12 AM', body: 'Morning! Charts pack is merged — dashboards are live.' },
  { author: 'Grace Hopper', time: '9:12 AM', body: 'The stat cards look really sharp in dark mode.' },
  { author: 'Ada Lovelace', time: '9:14 AM', body: 'Nice. I pulled the Q3 numbers into the new data table for the review.', attachments: true },
  { author: 'You', time: '9:16 AM', body: 'These are great. Donut chart center total was a good call.' },
  { author: 'Ada Lovelace', time: '9:17 AM', body: 'Agreed — and the sr-only tables mean the numbers read out properly too.' },
  { author: 'Grace Hopper', time: '9:18 AM', body: 'Shipping the chat pieces next. Very meta of us to be testing them right now.' },
];

const REPLIES = [
  { author: 'Grace Hopper', body: 'Good point — noted for the next round.' },
  { author: 'Ada Lovelace', body: 'Agreed! I will fold that into the review doc.' },
  { author: 'Grace Hopper', body: 'Ha — the scroller is following along perfectly, by the way.' },
  { author: 'Ada Lovelace', body: 'Same here. Pinning behavior feels right.' },
];

export default class ChatDemo extends PuzzleView {
  created() {
    this._replyTimer = null;
    this._replyIndex = 0;
    this.setData({ messages: SEED.slice(), draft: '' });
  }

  destroyed() {
    if (this._replyTimer) clearTimeout(this._replyTimer);
  }

  data() {
    const { messages, draft } = this.getData();
    const rows = messages.map((m, i) => {
      const prev = messages[i - 1];
      const mine = m.author === 'You';
      return {
        key: `m-${i}`,
        author: m.author,
        time: m.time,
        body: m.body,
        attachments: !!m.attachments,
        align: mine ? 'end' : 'start',
        variant: mine ? 'sent' : 'received',
        showMeta: !prev || prev.author !== m.author,
      };
    });
    return { rows, draft, canSend: draft.trim().length > 0 };
  }

  events = {
    onDraft: (event) => {
      this.setData({ draft: event.target.value });
      this.refresh();
    },

    onDraftKey: (event) => {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        this.events.send();
      }
    },

    send: () => {
      const { messages, draft } = this.getData();
      const text = draft.trim();
      if (!text) return;
      this.setData({ messages: [...messages, { author: 'You', time: 'Just now', body: text }], draft: '' });
      this.refresh();

      if (this._replyTimer) clearTimeout(this._replyTimer);
      this._replyTimer = setTimeout(() => {
        this._replyTimer = null;
        const reply = REPLIES[this._replyIndex % REPLIES.length];
        this._replyIndex += 1;
        const { messages: current } = this.getData();
        this.setData({ messages: [...current, { author: reply.author, time: 'Just now', body: reply.body }] });
        this.refresh();
      }, 1100);
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ChatDemo.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-2xl' }, [
      new ViewNode('header', { class: 'mb-8' }, [
        new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
          new ViewNode('text', { value: 'Chat' }),
        ]),
        new ViewNode('p', { class: 'mt-2 text-body' }, [
          new ViewNode('text', { value: 'The chat pieces working together — Chat Scroller, Chat Message, and Chat Attachment, plus a live composer. Send a message and a teammate replies; scroll up mid-conversation to see the jump-to-latest pill take over.' }),
        ]),
      ]),
      new ViewNode('section', { class: 'mb-12 overflow-hidden rounded-xl border border-border bg-surface shadow-sm' }, [
        new ViewNode('div', { class: 'flex items-center gap-3 border-b border-border px-4 py-3' }, [
          new ViewNode('span', {
            class: 'flex size-9 shrink-0 items-center justify-center rounded-full bg-brand-tint text-sm font-semibold text-brand',
          }, [
            new ViewNode('text', { value: 'PT' }),
          ]),
          new ViewNode('div', { class: 'min-w-0 flex-1' }, [
            new ViewNode('p', { class: 'truncate text-sm font-semibold text-ink' }, [
              new ViewNode('text', { value: 'Puzzle Team' }),
            ]),
            new ViewNode('p', { class: 'flex items-center gap-1.5 text-xs text-muted' }, [
              new ViewNode('span', {
                class: 'size-1.5 rounded-full bg-success',
                'aria-hidden': 'true',
              }, []),
              new ViewNode('text', { value: '3 online' }),
            ]),
          ]),
        ]),
        new ViewNode(ChatScroller, {
          height: 440,
          label: 'Team conversation',
          class: 'bg-page px-3',
        },
          __d.rows.map((m) =>
            new ViewNode('div', {
              class: 'contents',
              key: m.key,
            }, [
              ...(m.attachments
                ? [
                    new ViewNode(ChatMessage, {
                      author: m.author,
                      avatarName: m.author,
                      time: m.time,
                      align: m.align,
                      variant: m.variant,
                      showMeta: m.showMeta,
                    }, [
                      new ViewNode('text', { value: String(m.body) }),
                      new ViewNode(ChatAttachment, {
                        slot: 'attachments',
                        name: 'q3-dashboard.png',
                        size: '1.1 MB',
                      }, []),
                      new ViewNode(ChatAttachment, {
                        slot: 'attachments',
                        name: 'metrics.csv',
                        size: '48 KB',
                      }, []),
                    ]),
                  ]
                : [
                    new ViewNode(ChatMessage, {
                      author: m.author,
                      avatarName: m.author,
                      time: m.time,
                      align: m.align,
                      variant: m.variant,
                      showMeta: m.showMeta,
                    }, [
                      new ViewNode('text', { value: String(m.body) }),
                    ]),
                  ]),
            ])
          )
        ),
        new ViewNode('div', { class: 'flex items-center gap-2 border-t border-border p-3' }, [
          new ViewNode('input', {
            type: 'text',
            value: __d.draft,
            placeholder: 'Message Puzzle Team…',
            'aria-label': 'Message',
            class: 'min-w-0 flex-1 rounded-md border border-border bg-surface px-3 py-2 text-sm text-ink outline-ring placeholder:text-muted focus-visible:outline-2 focus-visible:-outline-offset-1',
            '@input': ((this.__h ??= {})[0] ??= (event) => this.events.onDraft(event)),
            '@keydown': ((this.__h ??= {})[1] ??= (event) => this.events.onDraftKey(event)),
          }, []),
          new ViewNode(Button, {
            press: ((this.__h ??= {})[2] ??= (event) => this.events.send(event)),
            disabled: !__d.canSend,
          }, [
            new ViewNode('text', { value: 'Send' }),
          ]),
        ]),
      ]),
    ]),
  ]);
};
