
import { PuzzleView } from '@magic-spells/puzzle';
import Sparkline from '@/components/ui/Sparkline.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece sparkline';
const usageImport = `import Sparkline from '@/components/ui/Sparkline.pzl';`;
const usageMarkup = `<Sparkline data={ data } width={ 160 } height={ 40 } />`;

const codeHero = `const data = [4, 6, 5, 8, 7, 10, 9, 12];

<Sparkline data={ data } width={ 160 } height={ 40 } />`;

const codeBasic = `// Defaults to 120×32 and text-chart-1. Nulls in the data become gaps.
<Sparkline data={ [4, 6, 5, 8, 7, 10, 9, 12] } />
<Sparkline data={ [8, 3, 9, 4, 11, 5, 12, 6] } />
<Sparkline data={ [12, 10, 11, 8, 9, 6, 7, 4] } />`;

const codeArea = `// area adds a soft fill under the line at 15% of the current color.
<Sparkline data={ series } area width={ 200 } height={ 48 } />`;

const codeColor = `// The stroke is currentColor — set any text-* color token via class.
<Sparkline data={ series } class="text-chart-3" width={ 200 } height={ 48 } />
<Sparkline data={ series } area class="text-chart-5" width={ 200 } height={ 48 } />`;

export default class SparklineDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeBasic,
      codeArea,
      codeColor,
      trendUp: [4, 6, 5, 8, 7, 10, 9, 12],
      trendVol: [8, 3, 9, 4, 11, 5, 12, 6],
      trendDown: [12, 10, 11, 8, 9, 6, 7, 4],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Basic', href: '#basic' },
        { label: 'Area fill', href: '#area' },
        { label: 'Custom color and size', href: '#color' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

SparklineDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Sparkline' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A tiny inline trend line — no axes, grid, or tooltip. Pass a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'data' }),
            ]),
            new ViewNode('text', { value: 'number array and it draws one 2px path sized to fit. Color inherits from the text color, so a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'text-chart-*' }),
            ]),
            new ViewNode('text', { value: 'token on the element (or its parent) sets the stroke.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex items-center gap-3' }, [
            new ViewNode(Sparkline, {
              data: __d.trendUp,
              width: 160,
              height: 40,
            }, []),
            new ViewNode('span', { class: 'text-2xl font-semibold text-ink' }, [
              new ViewNode('text', { value: '12.4k' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece and its math helper into your app — they compile with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Geometry is computed in the view with' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'lib/chart-math.js' }),
            ]),
            new ViewNode('text', { value: ', so the shared helper is a required dependency.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'basic',
            title: 'Basic',
            code: __d.codeBasic,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center gap-6' }, [
              new ViewNode(Sparkline, { data: __d.trendUp }, []),
              new ViewNode(Sparkline, { data: __d.trendVol }, []),
              new ViewNode(Sparkline, { data: __d.trendDown }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'area',
            title: 'Area fill',
            code: __d.codeArea,
          }, [
            new ViewNode(Sparkline, {
              data: __d.trendVol,
              area: true,
              width: 200,
              height: 48,
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'color',
            title: 'Custom color and size',
            code: __d.codeColor,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center gap-6' }, [
              new ViewNode(Sparkline, {
                data: __d.trendUp,
                class: 'text-chart-3',
                width: 200,
                height: 48,
              }, []),
              new ViewNode(Sparkline, {
                data: __d.trendUp,
                area: true,
                class: 'text-chart-5',
