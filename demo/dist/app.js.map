
import { PuzzleView } from '@magic-spells/puzzle';
import Button from '@/components/ui/Button.pzl';
import Tooltip from '@/components/ui/Tooltip.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece tooltip';
const usageImport = `import Tooltip from '@/components/ui/Tooltip.pzl';`;
const usageMarkup = `<Tooltip text="Save your changes"><Button variant="outline">Save</Button></Tooltip>`;

const codeHero = `<Tooltip text="Save your changes"><Button variant="outline">Save</Button></Tooltip>
<Tooltip text="Copy to clipboard"><Button variant="outline">Copy</Button></Tooltip>
<Tooltip text="Delete permanently"><Button variant="destructive">Delete</Button></Tooltip>`;

const codePlacement = `<Tooltip text="Appears above" side="top"><Button variant="outline">Top</Button></Tooltip>
<Tooltip text="Appears to the right" side="right"><Button variant="outline">Right</Button></Tooltip>
<Tooltip text="Appears below" side="bottom"><Button variant="outline">Bottom</Button></Tooltip>
<Tooltip text="Appears to the left" side="left"><Button variant="outline">Left</Button></Tooltip>

// side — "top" (default), "bottom", "left", or "right". The arrow follows the
// chip; a top or bottom tooltip auto-flips to the other edge when it would
// overflow the viewport.`;

const codeDelay = `<Tooltip text="Shows instantly" delay={ 0 }><Button variant="outline">No delay</Button></Tooltip>
<Tooltip text="Waits 300ms"><Button variant="outline">Default delay</Button></Tooltip>

// delay — hover open delay in ms (default 300). Keyboard focus always shows
// immediately; hide is always immediate.`;

export default class TooltipDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codePlacement,
      codeDelay,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Placement', href: '#placement' },
        { label: 'Delay', href: '#delay' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

TooltipDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Tooltip' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A text hint that wraps its target and appears on hover or keyboard focus. Text-only by design — pass the required text prop; for richer content reach for Popover instead.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
            new ViewNode(Tooltip, { text: 'Save your changes' }, [
              new ViewNode(Button, { variant: 'outline' }, [
                new ViewNode('text', { value: 'Save' }),
              ]),
            ]),
            new ViewNode(Tooltip, { text: 'Copy to clipboard' }, [
              new ViewNode(Button, { variant: 'outline' }, [
                new ViewNode('text', { value: 'Copy' }),
              ]),
            ]),
            new ViewNode(Tooltip, { text: 'Delete permanently' }, [
              new ViewNode(Button, { variant: 'destructive' }, [
                new ViewNode('text', { value: 'Delete' }),
              ]),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'placement',
            title: 'Placement',
            code: __d.codePlacement,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-4' }, [
              new ViewNode(Tooltip, {
                text: 'Appears above',
                side: 'top',
              }, [
                new ViewNode(Button, { variant: 'outline' }, [
                  new ViewNode('text', { value: 'Top' }),
                ]),
              ]),
              new ViewNode(Tooltip, {
                text: 'Appears to the right',
                side: 'right',
              }, [
                new ViewNode(Button, { variant: 'outline' }, [
                  new ViewNode('text', { value: 'Right' }),
                ]),
              ]),
              new ViewNode(Tooltip, {
                text: 'Appears below',
                side: 'bottom',
              }, [
                new ViewNode(Button, { variant: 'outline' }, [
                  new ViewNode('text', { value: 'Bottom' }),
                ]),
              ]),
              new ViewNode(Tooltip, {
                text: 'Appears to the left',
                side: 'left',
              }, [
                new ViewNode(Button, { variant: 'outline' }, [
                  new ViewNode('text', { value: 'Left' }),
                ]),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'delay',
            title: 'Delay',
            code: __d.codeDelay,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(Tooltip, {
                text: 'Shows instantly',
                delay: 0,
              }, [
                new ViewNode(Button, { variant: 'outline' }, [
                  new ViewNode('text', { value: 'No delay' }),
                ]),
              ]),
              new ViewNode(Tooltip, { text: 'Waits 300ms' }, [
                new ViewNode(Button, { variant: 'outline' }, [
                  new ViewNode('text', { value: 'Default delay' }),
                ]),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
