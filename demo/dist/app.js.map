
import { PuzzleView } from '@magic-spells/puzzle';
import ContextMenu from '@/components/ui/ContextMenu.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';
import { toast } from '@/components/ui/toast.js';

const installCmd = 'puzzle add piece context-menu';
const usageImport = `import ContextMenu from '@/components/ui/ContextMenu.pzl';`;
const usageMarkup = `<ContextMenu items={ fileItems } @select={ onSelect }></ContextMenu>`;

const codeHero = `<ContextMenu items={ fileItems } @select={ onSelect }>
  <div class="…">Right-click anywhere in this box</div>
</ContextMenu>

// items: interactive rows, { group } headings, { divider } separators
fileItems: [
  { label: 'Open', value: 'open' },
  { label: 'Rename', value: 'rename' },
  { label: 'Duplicate', value: 'duplicate' },
];

events = {
  onSelect: (value, event) => console.log('picked', value),
};`;

const codeGroups = `<ContextMenu items={ editItems } @select={ onSelect }>
  <div class="…">Right-click for a grouped menu</div>
</ContextMenu>

// { group: 'Heading' } is a non-interactive label; { divider: true } draws a
// hairline; danger: true paints the row in the danger token.
editItems: [
  { group: 'Edit' },
  { label: 'Cut', value: 'cut' },
  { label: 'Copy', value: 'copy' },
  { label: 'Paste', value: 'paste' },
  { divider: true },
  { label: 'Delete', value: 'delete', danger: true },
];`;

const codeDisabled = `// disabled short-circuits the contextmenu handler: the piece never opens
// and the browser's own right-click menu is shown instead.
<ContextMenu disabled={ true } items={ fileItems } @select={ onSelect }>
  <div class="…">Menu disabled</div>
</ContextMenu>`;

const codeKeyboard = `// Opening focuses the first enabled item; arrows move (wrapping, skipping
// groups/dividers), Enter/Space choose, Escape closes. It also closes on an
// outside click, any scroll, or a right-click elsewhere.
<ContextMenu items={ fileItems } @select={ onSelect }>
  <div class="…">Right-click, then use the arrow keys</div>
</ContextMenu>`;

export default class ContextMenuDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeGroups,
      codeDisabled,
      codeKeyboard,
      fileItems: [
        { label: 'Open', value: 'open' },
        { label: 'Rename', value: 'rename' },
        { label: 'Duplicate', value: 'duplicate' },
        { divider: true },
        { label: 'Delete', value: 'delete', danger: true },
      ],
      editItems: [
        { group: 'Edit' },
        { label: 'Cut', value: 'cut' },
        { label: 'Copy', value: 'copy' },
        { label: 'Paste', value: 'paste', disabled: true },
        { divider: true },
        { group: 'Danger zone' },
        { label: 'Delete', value: 'delete', danger: true },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Groups and danger items', href: '#groups' },
        { label: 'Disabled', href: '#disabled' },
        { label: 'Keyboard', href: '#keyboard' },
      ],
    };
  }

  events = {
    onSelect: (value) => toast({ message: 'Menu: ' + value }),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ContextMenuDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Context Menu' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A right-click menu built on Dropdown Menu\'s guts — the same grouped items, danger rows, and keyboard navigation — but summoned at the pointer instead of toggled by a button. Config-first: pass an items array and handle @select.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(ContextMenu, {
            items: __d.fileItems,
            select: ((this.__h ??= {})[0] ??= (event) => this.events.onSelect(event)),
          }, [
            new ViewNode('div', {
              class: 'flex h-40 w-72 select-none items-center justify-center rounded-xl border-2 border-dashed border-border bg-surface text-center text-sm text-muted',
            }, [
              new ViewNode('text', { value: 'Right-click anywhere' }),
              new ViewNode('br', {}, []),
              new ViewNode('text', { value: 'in this box' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'groups',
            title: 'Groups and danger items',
            code: __d.codeGroups,
          }, [
            new ViewNode(ContextMenu, {
              items: __d.editItems,
              select: ((this.__h ??= {})[1] ??= (event) => this.events.onSelect(event)),
            }, [
              new ViewNode('div', {
                class: 'flex h-40 w-72 select-none items-center justify-center rounded-xl border-2 border-dashed border-border bg-surface text-center text-sm text-muted',
              }, [
                new ViewNode('text', { value: 'Right-click for a grouped menu' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'disabled',
            title: 'Disabled',
            code: __d.codeDisabled,
          }, [
            new ViewNode(ContextMenu, {
              disabled: true,
              items: __d.fileItems,
              select: ((this.__h ??= {})[2] ??= (event) => this.events.onSelect(event)),
            }, [
              new ViewNode('div', {
                class: 'flex h-40 w-72 select-none items-center justify-center rounded-xl border-2 border-dashed border-border bg-surface text-center text-sm text-muted',
              }, [
                new ViewNode('text', { value: 'Menu disabled — the native browser menu shows instead' }),
              ]),
            ]),
          ]),
          new ViewNode('section', {
            id: 'keyboard',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Keyboard' }),
            ]),
            new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
              new ViewNode('text', { value: 'Opening focuses the first enabled item; from there the menu owns these keys:' }),
            ]),
            new ViewNode('ul', { class: 'mb-4 space-y-1.5 text-sm text-body' }, [
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Up / Down arrows' }),
                ]),
                new ViewNode('text', { value: ' — move between enabled items (wrapping, skipping groups and dividers)' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Home / End' }),
                ]),
                new ViewNode('text', { value: ' — jump to the first or last item' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Enter / Space' }),
                ]),
                new ViewNode('text', { value: ' — choose the focused item' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Escape' }),
                ]),
                new ViewNode('text', { value: ' — close the menu' }),
              ]),
            ]),
            new ViewNode('p', { class: 'mb-3 text-sm text-muted' }, [
              new ViewNode('text', { value: 'The menu also closes on an outside click, any scroll, or a right-click elsewhere. Touch long-press is not implemented in v1 — most browsers still synthesize a' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'contextmenu' }),
              ]),
              new ViewNode('text', { value: 'event on long-press, which opens the menu.' }),
            ]),
            new ViewNode(ExampleBox, { code: __d.codeKeyboard }, [
              new ViewNode(ContextMenu, {
                items: __d.fileItems,
                select: ((this.__h ??= {})[3] ??= (event) => this.events.onSelect(event)),
              }, [
                new ViewNode('div', {
                  class: 'flex h-40 w-72 select-none items-center justify-center rounded-xl border-2 border-dashed border-border bg-surface text-center text-sm text-muted',
                }, [
                  new ViewNode('text', { value: 'Right-click, then use the arrow keys' }),
                ]),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
