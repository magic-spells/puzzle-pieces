          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A desktop-application-style horizontal menu bar (File / Edit / View / Help). Each top label opens a dropdown of actions on click; hovering another label switches menus, and full keyboard navigation moves between and inside menus. Config-first: pass a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
