
import { PuzzleView } from '@magic-spells/puzzle';
import Checkbox from '@/components/ui/Checkbox.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece checkbox';
const usageImport = `import Checkbox from '@/components/ui/Checkbox.pzl';`;
const usageMarkup = `<Checkbox label="Subscribe to the newsletter" checked={ subscribe } @change={ setSubscribe } />`;

const codeHero = `<Checkbox label="Subscribe to the newsletter" checked={ subscribe } @change={ setSubscribe } />

// parent
events = {
  setSubscribe: (v) => this.setData('subscribe', v),
};`;

const codeHint = `<Checkbox
  label="Ship it"
  hint="Applies to every item in the order"
  checked={ shipIt }
  @change={ setShipIt } />`;

const codeDisabled = `<Checkbox label="Gift wrapping" hint="Not available for this order" checked={ false } disabled />`;

export default class CheckboxDoc extends PuzzleView {
  created() {
    this.setData({ subscribe: true, shipIt: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeHint,
      codeDisabled,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'With hint', href: '#hint' },
        { label: 'Disabled', href: '#disabled' },
      ],
    };
  }

  events = {
    setSubscribe: (v) => {
      this.setData('subscribe', v);
      this.refresh();
    },
    setShipIt: (v) => {
      this.setData('shipIt', v);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

CheckboxDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Checkbox' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A checkbox built on a native input element, with an optional label and hint. The whole row is a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'label' }),
            ]),
            new ViewNode('text', { value: ', so a click anywhere toggles it; state is controlled through a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: 'callback.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(Checkbox, {
            label: 'Subscribe to the newsletter',
            checked: __d.subscribe,
            change: ((this.__h ??= {})[0] ??= (event) => this.events.setSubscribe(event)),
          }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'hint',
            title: 'With hint',
            code: __d.codeHint,
          }, [
            new ViewNode(Checkbox, {
              label: 'Ship it',
              hint: 'Applies to every item in the order',
              checked: __d.shipIt,
              change: ((this.__h ??= {})[1] ??= (event) => this.events.setShipIt(event)),
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'disabled',
            title: 'Disabled',
            code: __d.codeDisabled,
            tall: false,
          }, [
            new ViewNode(Checkbox, {
              label: 'Gift wrapping',
              hint: 'Not available for this order',
              checked: false,
              disabled: true,
            }, []),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
