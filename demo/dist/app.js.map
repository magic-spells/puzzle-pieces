
import { PuzzleView } from '@magic-spells/puzzle';
import SearchField from '@/components/ui/SearchField.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';
import { toast } from '@/components/ui/toast.js';

// Docs page for SearchField — follows the ButtonDoc exemplar shape.
const installCmd = 'puzzle add piece search-field';
const usageImport = `import SearchField from '@/components/ui/SearchField.pzl';`;
const usageMarkup = `<SearchField value={ query } placeholder="Filter results…" @change={ setQuery } />`;

const codeHero = `<SearchField value={ query } placeholder="Filter results…" @change={ setQuery } />
<p>Query: { query }</p>

// parent
events = {
  setQuery: (v) => this.setData('query', v),
};`;

const codeSubmit = `<SearchField value={ term } @change={ setTerm } @submit={ runSearch } />

// parent
events = {
  setTerm: (v) => this.setData('term', v),
  runSearch: (v) => toast({ message: 'Searching for: ' + v }),
};`;

export default class SearchFieldDoc extends PuzzleView {
  created() {
    this.setData({ query: '', term: '' });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeSubmit,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Submit on Enter', href: '#submit' },
      ],
    };
  }

  events = {
    setQuery: (v) => this.setData('query', v),
    setTerm: (v) => this.setData('term', v),
    runSearch: (v) => toast({ message: 'Searching for: ' + (v || 'nothing'), variant: 'success' }),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

SearchFieldDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Search Field' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A search input with a leading magnifier and a trailing clear button that appears only while there\'s a value. Value is controlled via' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: '; pressing Enter fires' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@submit' }),
            ]),
            new ViewNode('text', { value: '.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-sm space-y-2' }, [
            new ViewNode(SearchField, {
              value: __d.query,
              placeholder: 'Filter results…',
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setQuery(event)),
            }, []),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'Query: ' + String(__d.query || '—') }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'submit',
            title: 'Submit on Enter',
            code: __d.codeSubmit,
          }, [
            new ViewNode('div', { class: 'w-full max-w-sm space-y-2' }, [
              new ViewNode(SearchField, {
                value: __d.term,
                placeholder: 'Type and press Enter…',
                change: ((this.__h ??= {})[1] ??= (event) => this.events.setTerm(event)),
                submit: ((this.__h ??= {})[2] ??= (event) => this.events.runSearch(event)),
              }, []),
              new ViewNode('p', { class: 'text-sm text-muted' }, [
                new ViewNode('text', { value: 'Press Enter to fire a search.' }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
