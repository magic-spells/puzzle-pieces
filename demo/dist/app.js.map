
import { PuzzleView } from '@magic-spells/puzzle';
import Pagination from '@/components/ui/Pagination.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece pagination';
const usageImport = `import Pagination from '@/components/ui/Pagination.pzl';`;
const usageMarkup = `<Pagination page={ page } count={ 12 } @change={ setPage } />`;

const codeHero = `<Pagination page={ page } count={ 12 } @change={ setPage } />
<p>Page { page } of 12</p>

// parent
events = {
  setPage: (p) => this.setData({ page: p }),
};`;

const codeWindowing = `// Always shows the first and last page; a run of siblings hugs the
// current page, and gaps of two or more pages collapse to an ellipsis.
// Mid-range on a long count, both gaps show: 1 … 9 10 11 … 20.
<Pagination page={ page } count={ 20 } @change={ setPage } />`;

const codeSmall = `// Counts of seven or fewer never gap — every page renders, no ellipsis.
<Pagination page={ page } count={ 5 } @change={ setPage } />`;

export default class PaginationDoc extends PuzzleView {
  created() {
    this.setData({ page: 1, pageWide: 10, pageSmall: 1 });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeWindowing,
      codeSmall,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Windowing', href: '#windowing' },
        { label: 'Small counts', href: '#small' },
      ],
    };
  }

  events = {
    setPage: (p) => {
      this.setData('page', p);
      this.refresh();
    },
    setPageWide: (p) => {
      this.setData('pageWide', p);
      this.refresh();
    },
    setPageSmall: (p) => {
      this.setData('pageSmall', p);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

PaginationDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Pagination' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A controlled page navigator. The parent owns' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'page' }),
            ]),
            new ViewNode('text', { value: 'and updates it from' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@change' }),
            ]),
            new ViewNode('text', { value: '; the piece renders a windowed strip of page numbers with prev/next buttons and ellipses.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-col items-center gap-4' }, [
            new ViewNode(Pagination, {
              page: __d.page,
              count: 12,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setPage(event)),
            }, []),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'Page ' + String(__d.page) + ' of 12' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'windowing',
            title: 'Windowing',
            code: __d.codeWindowing,
          }, [
            new ViewNode(Pagination, {
              page: __d.pageWide,
              count: 20,
              change: ((this.__h ??= {})[1] ??= (event) => this.events.setPageWide(event)),
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'small',
            title: 'Small counts',
            code: __d.codeSmall,
          }, [
            new ViewNode(Pagination, {
              page: __d.pageSmall,
              count: 5,
              change: ((this.__h ??= {})[2] ??= (event) => this.events.setPageSmall(event)),
            }, []),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
