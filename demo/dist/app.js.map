
import { PuzzleView } from '@magic-spells/puzzle';
import LineChart from '@/components/ui/LineChart.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for LineChart — follows the TableDoc / CalendarDoc exemplar (header →
// hero ExampleBox → Installation → titled example sections → Toc). The chart is
// pure presentation, so the data lives as static module consts fed straight in.

const installCmd = 'puzzle add piece line-chart';
const usageImport = `import LineChart from '@/components/ui/LineChart.pzl';`;
const usageMarkup = `<LineChart data={ data } xKey="month" series={ series } />`;

// A stable module reference keeps the child prop identity steady across re-renders.
const money = (n) => '$' + Number(n).toLocaleString();

const codeHero = `const data = [
  { month: 'Jan', revenue: 42000, target: 40000 },
  { month: 'Feb', revenue: 45000, target: 44000 },
  { month: 'Mar', revenue: 48000, target: 46000 },
  // …one row per x label, one numeric field per series
];
const series = [
  { key: 'revenue', label: 'Revenue' },
  { key: 'target',  label: 'Target' },
];

<LineChart data={ data } xKey="month" series={ series } />`;

const codeSingle = `// One series → no legend (there is only one color).
const series = [{ key: 'revenue', label: 'Revenue' }];

<LineChart data={ data } xKey="month" series={ series } />`;

const codeFormatting = `// height sets the plot height in px; formatValue formats tooltip + table values.
const money = (n) => '$' + n.toLocaleString();

<LineChart
  data={ data }
  xKey="month"
  series={ series }
  height={ 360 }
  formatValue={ money } />`;

const revenueData = [
  { month: 'Jan', revenue: 42000, target: 40000 },
  { month: 'Feb', revenue: 45000, target: 44000 },
  { month: 'Mar', revenue: 48000, target: 46000 },
  { month: 'Apr', revenue: 51000, target: 50000 },
  { month: 'May', revenue: 49000, target: 52000 },
  { month: 'Jun', revenue: 55000, target: 54000 },
  { month: 'Jul', revenue: 61000, target: 58000 },
  { month: 'Aug', revenue: 64000, target: 60000 },
  { month: 'Sep', revenue: 62000, target: 63000 },
  { month: 'Oct', revenue: 70000, target: 66000 },
  { month: 'Nov', revenue: 76000, target: 72000 },
  { month: 'Dec', revenue: 83000, target: 78000 },
];
const revenueSeries = [
  { key: 'revenue', label: 'Revenue' },
  { key: 'target', label: 'Target' },
];
const singleSeries = [{ key: 'revenue', label: 'Revenue' }];

export default class LineChartDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      money,
      codeHero,
      codeSingle,
      codeFormatting,
      revenueData,
      revenueSeries,
      singleSeries,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Single series', href: '#single-series' },
        { label: 'Custom height and value formatting', href: '#formatting' },
        { label: 'Accessibility', href: '#accessibility' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

LineChartDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Line Chart' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A config-first, responsive multi-series line chart. A' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'data' }),
            ]),
            new ViewNode('text', { value: 'array and a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'series' }),
            ]),
            new ViewNode('text', { value: 'schema render 2px lines against a hairline horizontal grid, with a nearest-x hover crosshair and tooltip. Series colors are assigned in fixed slot order; a legend appears automatically for two or more series.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full' }, [
            new ViewNode(LineChart, {
              data: __d.revenueData,
              xKey: 'month',
              series: __d.revenueSeries,
            }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece and its math helper into your app — they compile with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'chart-math.js is a shared lib file — LineChart imports it as ../../lib/chart-math.js. It ships alongside the piece; keep it in app/lib/.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode('div', {}, [
            new ViewNode(ExampleBox, {
              id: 'single-series',
              title: 'Single series',
              code: __d.codeSingle,
            }, [
              new ViewNode('div', { class: 'w-full' }, [
                new ViewNode(LineChart, {
                  data: __d.revenueData,
                  xKey: 'month',
                  series: __d.singleSeries,
                }, []),
              ]),
            ]),
            new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
              new ViewNode('text', { value: 'One series gets no legend — there is only one color, so the surrounding title already says what is plotted. The rule holds even if you pass showLegend explicitly.' }),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'formatting',
            title: 'Custom height and value formatting',
            code: __d.codeFormatting,
          }, [
            new ViewNode('div', { class: 'w-full' }, [
              new ViewNode(LineChart, {
                data: __d.revenueData,
                xKey: 'month',
                series: __d.revenueSeries,
                height: 360,
                formatValue: __d.money,
              }, []),
            ]),
          ]),
          new ViewNode('section', {
            id: 'accessibility',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Accessibility' }),
            ]),
            new ViewNode('p', { class: 'mb-4 text-sm text-body' }, [
              new ViewNode('text', { value: 'The hover crosshair and tooltip are a progressive enhancement — every value they reveal is also reachable without a pointer. The chart is built so assistive tech never depends on the drawing:' }),
            ]),
            new ViewNode('ul', { class: 'space-y-2.5 text-sm text-body' }, [
              new ViewNode('li', {}, [
                new ViewNode('text', { value: 'The root is a' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink',
                }, [
                  new ViewNode('text', { value: 'figure' }),
                ]),
                new ViewNode('text', { value: 'with an' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink',
                }, [
                  new ViewNode('text', { value: 'aria-label' }),
                ]),
                new ViewNode('text', { value: '(the label prop, or the series labels joined), so the whole chart announces as one named figure.' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('text', { value: 'The SVG itself is' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink',
                }, [
                  new ViewNode('text', { value: 'aria-hidden' }),
                ]),
                new ViewNode('text', { value: '— the marks carry no semantics a screen reader could use.' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('text', { value: 'A visually-hidden' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink',
                }, [
                  new ViewNode('text', { value: 'sr-only' }),
                ]),
                new ViewNode('text', { value: 'table twins the plot: x values are row headers and each series is a column, so the exact numbers are read in order without ever hovering.' }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
