
import { PuzzleView } from '@magic-spells/puzzle';
import Carousel from '@/components/ui/Carousel.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Carousel — follows the TabsDoc / ScrollAreaDoc exemplar shape.
const installCmd = 'puzzle add piece carousel';
const usageImport = `import Carousel from '@/components/ui/Carousel.pzl';`;
const usageMarkup = `<Carousel class="w-full max-w-xl"></Carousel>`;

const codeHero = `// Slides are the default-slot children — one direct child per slide.
// Uncontrolled: the carousel owns its own index.
<Carousel class="w-full max-w-xl">
  <div class="flex h-56 w-full items-center justify-center bg-brand-tint text-ink">Mountains</div>
  <div class="flex h-56 w-full items-center justify-center bg-surface-sunken text-ink">Forests</div>
  <div class="flex h-56 w-full items-center justify-center bg-success-tint text-ink">Rivers</div>
</Carousel>`;

const codeAutoplay = `// autoplay is an ms interval; loop wraps past the ends.
// Autoplay pauses on hover / focus-within and honors prefers-reduced-motion.
<Carousel autoplay={ 3500 } loop={ true } class="w-full max-w-xl">
  <div>…</div>
  <div>…</div>
  <div>…</div>
  <div>…</div>
</Carousel>`;

const codeLoop = `// Controlled index: the parent owns \`value\`, props in / @change out.
<Carousel loop={ true } value={ i } @change={ setI } class="w-full max-w-xl">
  <div>Alpha</div>
  <div>Bravo</div>
  <div>Charlie</div>
</Carousel>

// parent
created() { this.setData('i', 0); }
events = { setI: (index) => this.setData('i', index) };`;

const codeDots = `// controls={ false } hides the arrows and leaves the dot row.
// (dots={ false } would do the opposite.)
<Carousel controls={ false } class="w-full max-w-xl">
  <div>Red</div>
  <div>Green</div>
  <div>Blue</div>
</Carousel>`;

export default class CarouselDoc extends PuzzleView {
  created() {
    this.setData({ loopIdx: 0 });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeAutoplay,
      codeLoop,
      codeDots,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Autoplay', href: '#autoplay' },
        { label: 'Loop + controlled', href: '#loop' },
        { label: 'Dots only', href: '#dots' },
        { label: 'Keyboard', href: '#keyboard' },
      ],
    };
  }

  events = {
    setLoopIdx: (index) => this.setData('loopIdx', index),
  };
}

