
import { PuzzleView } from '@magic-spells/puzzle';
import Avatar from '@/components/ui/Avatar.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Avatar — follows the Button exemplar shape (header → hero
// ExampleBox → Installation → titled example sections → Toc).
const installCmd = 'puzzle add piece avatar';
const usageImport = `import Avatar from '@/components/ui/Avatar.pzl';`;
const usageMarkup = `<Avatar src={ user.photo } name="Ada Lovelace" size="lg" />`;

const codeHero = `<Avatar src={ user.photo } name="Ada Lovelace" size="lg" />
<Avatar name="Grace Hopper" size="lg" />
<Avatar size="lg" />`;

const codeColors = `// The disc color is derived from the name — the hue is the
// summed char codes mod 360 — so a given name always maps to
// the same color, no palette prop needed.
<Avatar name="Ada Lovelace" />
<Avatar name="Grace Hopper" />
<Avatar name="Alan Turing" />`;

const codeSizes = `<Avatar name="Ada Lovelace" size="sm" />
<Avatar name="Ada Lovelace" size="md" />
<Avatar name="Ada Lovelace" size="lg" />`;

export default class AvatarDoc extends PuzzleView {
  data(params, props) {
    return {
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeColors,
      codeSizes,
      people: ['Ada Lovelace', 'Grace Hopper', 'Alan Turing', 'Katherine Johnson', 'Linus Torvalds', 'Barbara Liskov'],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Fallback colors', href: '#fallback-colors' },
        { label: 'Sizes', href: '#sizes' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

AvatarDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Avatar' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An image with a graceful fallback. A valid image renders directly; if it fails to load it falls back to the name\'s initials on a colored disc, and with no name at all it shows a neutral person glyph.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, {
          code: __d.codeHero,
          tall: false,
        }, [
          new ViewNode('div', { class: 'flex items-center gap-4' }, [
            new ViewNode(Avatar, {
              src: 'https://i.pravatar.cc/80?img=13',
              name: 'Ada Lovelace',
              size: 'lg',
            }, []),
            new ViewNode(Avatar, {
              name: 'Grace Hopper',
              size: 'lg',
            }, []),
            new ViewNode(Avatar, { size: 'lg' }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'fallback-colors',
            title: 'Fallback colors',
            code: __d.codeColors,
            tall: false,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-2' },
              __d.people.map((person) =>
                new ViewNode(Avatar, {
                  key: ViewNode.keyOf(person),
                  name: person,
                  size: 'lg',
                }, [])
              )
            ),
          ]),
          new ViewNode(ExampleBox, {
            id: 'sizes',
            title: 'Sizes',
            code: __d.codeSizes,
            tall: false,
          }, [
            new ViewNode('div', { class: 'flex items-center gap-4' }, [
              new ViewNode(Avatar, {
                name: 'Ada Lovelace',
                size: 'sm',
              }, []),
              new ViewNode(Avatar, {
                name: 'Ada Lovelace',
                size: 'md',
              }, []),
              new ViewNode(Avatar, {
                name: 'Ada Lovelace',
                size: 'lg',
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
