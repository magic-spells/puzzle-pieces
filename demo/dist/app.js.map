const codeWithLabel = `<CopyButton value={ shareUrl } label="Copy link" @copy={ onCopied }/>`;

const codeVariants = `<CopyButton value={ apiKey } label="Ghost" variant="ghost" @copy={ onCopied }/>
<CopyButton value={ apiKey } label="Outline" variant="outline" @copy={ onCopied }/>
<CopyButton value={ apiKey } label="Secondary" variant="secondary" @copy={ onCopied }/>`;

const codeSizes = `<CopyButton value={ apiKey } size="sm" @copy={ onCopied }/>
<CopyButton value={ apiKey } size="md" @copy={ onCopied }/>
<CopyButton value={ apiKey } size="lg" @copy={ onCopied }/>`;

const codeSnippet = `<div class="flex items-center justify-between rounded-lg border border-border bg-surface-sunken px-3 py-2">
  <code>{ installSnippet }</code>
  <CopyButton value={ installSnippet } @copy={ onCopied }/>
</div>`;

const codeDisabled = `<CopyButton value={ apiKey } label="Copy" disabled/>`;

export default class CopyButtonDoc extends PuzzleView {
