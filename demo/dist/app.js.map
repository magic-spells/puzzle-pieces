
import { PuzzleView } from '@magic-spells/puzzle';
import Card from '@/components/ui/Card.pzl';
import Button from '@/components/ui/Button.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';
import { toast } from '@/components/ui/toast.js';

const installCmd = 'puzzle add piece card';
const usageImport = `import Card from '@/components/ui/Card.pzl';`;
const usageMarkup = `<Card title="Team workspace" description="Manage members, roles, and billing for this project."></Card>`;

const codeHero = `<Card title="Team workspace" description="Manage members, roles, and billing for this project.">
  <p>Nine people currently have access. Invites expire after seven days.</p>
  <Button slot="footer" variant="ghost" @press={ manage }>Manage</Button>
  <Button slot="footer" variant="primary" @press={ invite }>Invite</Button>
</Card>`;

const codePlain = `<Card>
  <p>A plain card — no header, no footer. Just a padded, bordered surface.</p>
</Card>`;

const codeFooter = `<Card title="Delete project?">
  <p>This permanently removes the project and all of its data.</p>
  <Button slot="footer" variant="ghost" @press={ cancel }>Cancel</Button>
  <Button slot="footer" variant="destructive" @press={ remove }>Delete</Button>
</Card>`;

export default class CardDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codePlain,
      codeFooter,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Plain card', href: '#plain' },
        { label: 'Footer slot', href: '#footer' },
      ],
    };
  }

  events = {
    manage: () => toast({ message: 'Opening workspace settings…' }),
    invite: () => toast({ title: 'Invite sent', message: 'They will get an email shortly.', variant: 'success' }),
    cancel: () => toast({ message: 'Cancelled.' }),
    remove: () => toast({ title: 'Project deleted', message: 'The project and its data are gone.', variant: 'danger' }),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

CardDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Card' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A presentational container with an optional title/description header, a default body slot, and a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'footer' }),
            ]),
            new ViewNode('text', { value: 'slot for actions. Every region collapses when unused, so it drops in 1:1.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(Card, {
            class: 'w-full max-w-sm',
            title: 'Team workspace',
            description: 'Manage members, roles, and billing for this project.',
          }, [
            new ViewNode('p', { class: 'text-sm text-body' }, [
              new ViewNode('text', { value: 'Nine people currently have access. Invites expire after seven days.' }),
            ]),
            new ViewNode(Button, {
              slot: 'footer',
              variant: 'ghost',
              press: ((this.__h ??= {})[0] ??= (event) => this.events.manage(event)),
            }, [
              new ViewNode('text', { value: 'Manage' }),
            ]),
            new ViewNode(Button, {
              slot: 'footer',
              variant: 'primary',
              press: ((this.__h ??= {})[1] ??= (event) => this.events.invite(event)),
            }, [
              new ViewNode('text', { value: 'Invite' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'plain',
            title: 'Plain card',
            code: __d.codePlain,
          }, [
            new ViewNode(Card, { class: 'w-full max-w-sm' }, [
              new ViewNode('p', { class: 'text-sm text-body' }, [
                new ViewNode('text', { value: 'A plain card — no header, no footer. Just a padded, bordered surface that matches the rest of the showcase 1:1.' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'footer',
            title: 'Footer slot',
            code: __d.codeFooter,
          }, [
            new ViewNode(Card, {
              class: 'w-full max-w-sm',
              title: 'Delete project?',
            }, [
              new ViewNode('p', { class: 'text-sm text-body' }, [
                new ViewNode('text', { value: 'This permanently removes the project and all of its data. This action cannot be undone.' }),
              ]),
              new ViewNode(Button, {
                slot: 'footer',
                variant: 'ghost',
                press: ((this.__h ??= {})[2] ??= (event) => this.events.cancel(event)),
              }, [
                new ViewNode('text', { value: 'Cancel' }),
              ]),
              new ViewNode(Button, {
                slot: 'footer',
                variant: 'destructive',
                press: ((this.__h ??= {})[3] ??= (event) => this.events.remove(event)),
              }, [
                new ViewNode('text', { value: 'Delete' }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
