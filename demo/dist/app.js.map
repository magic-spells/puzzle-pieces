
import { PuzzleView } from '@magic-spells/puzzle';
import Select from '@/components/ui/Select.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece select';
const usageImport = `import Select from '@/components/ui/Select.pzl';`;
const usageMarkup = `<Select options={ fruitOptions } value={ fruit } @change={ setFruit } />`;

const codeHero = `const fruitOptions = [
  { value: 'apple', label: 'Apple' },
  { value: 'banana', label: 'Banana' },
  { value: 'cherry', label: 'Cherry' },
];

<Select options={ fruitOptions } value={ fruit } @change={ setFruit } />`;

const codeGroups = `const foodOptions = [
  { group: 'Savory' },
  { value: 'pizza', label: 'Pizza' },
  { value: 'tacos', label: 'Tacos' },
  { divider: true },
  { group: 'Sweet' },
  { value: 'cake', label: 'Cake' },
  { value: 'sorbet', label: 'Sorbet', disabled: true },
];

<Select options={ foodOptions } value={ food } @change={ setFood } />`;

const codeMorph = `// requires: npm install @magic-spells/morph-engine
// A morph select opens centered: the selected option sits right over the
// trigger (macOS-style), so clicking the same spot again closes it.
<Select options={ colorOptions } value={ color } morph={ true } @change={ setColor } />`;

const codePosition = `// position: 'down' | 'up' | 'center'
// unset — morph selects center; plain selects flip to whichever side has room
<Select options={ fruitOptions } value={ fruit } position="center" @change={ setFruit } />
<Select options={ fruitOptions } value={ fruit } position="up" @change={ setFruit } />`;

const codeIndicator = `// indicator: 'triangle' (default) | 'chevrons' | 'caret'
// 'chevrons' shows the classic up/down selection-list arrows (never rotates).
<Select options={ fruitOptions } value={ fruit } @change={ setFruit } />
<Select options={ fruitOptions } value={ fruit } indicator="chevrons" @change={ setFruit } />
<Select options={ fruitOptions } value={ fruit } indicator="caret" @change={ setFruit } />`;

const codeKeyboard = `<Select options={ fruitOptions } value={ fruit } @change={ setFruit } />`;

export default class SelectDoc extends PuzzleView {
  created() {
    this.setData({ fruit: '', food: 'pizza', color: 'blue' });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeGroups,
      codeMorph,
      codePosition,
      codeIndicator,
      codeKeyboard,
      fruitOptions: [
        { value: 'apple', label: 'Apple' },
        { value: 'banana', label: 'Banana' },
        { value: 'cherry', label: 'Cherry' },
      ],
      foodOptions: [
        { group: 'Savory' },
        { value: 'pizza', label: 'Pizza' },
        { value: 'tacos', label: 'Tacos' },
        { divider: true },
        { group: 'Sweet' },
        { value: 'cake', label: 'Cake' },
        { value: 'sorbet', label: 'Sorbet', disabled: true },
      ],
      colorOptions: [
        { value: 'red', label: 'Red' },
        { value: 'blue', label: 'Blue' },
        { value: 'green', label: 'Green' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Groups and dividers', href: '#groups' },
        { label: 'Morph', href: '#morph' },
        { label: 'Position', href: '#position' },
        { label: 'Indicator', href: '#indicator' },
        { label: 'Keyboard', href: '#keyboard' },
      ],
    };
  }

  events = {
    setFruit: (v) => {
      this.setData('fruit', v);
      this.refresh();
    },
    setFood: (v) => {
      this.setData('food', v);
      this.refresh();
    },
    setColor: (v) => {
      this.setData('color', v);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

