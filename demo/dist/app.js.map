
import { PuzzleView } from '@magic-spells/puzzle';
import DateRangePicker from '@/components/ui/DateRangePicker.pzl';
import Button from '@/components/ui/Button.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for DateRangePicker — follows the DatePickerDoc exemplar (header → hero
// ExampleBox → Installation → titled example sections → Toc). Parent-owned: the view holds
// each { start, end } range and the picker emits @change on every committed endpoint.

// Three files: the range picker, the Calendar it composes, and the shared date helper.
const installCmd = 'puzzle add piece date-range-picker';
const usageImport = `import DateRangePicker from '@/components/ui/DateRangePicker.pzl';`;
const usageMarkup = `<DateRangePicker label="Stay dates" hint="Pick a check-in and check-out day." value={ range } @change={ setRange } />`;

const codeHero = `<DateRangePicker
  label="Stay dates"
  hint="Pick a check-in and check-out day."
  value={ range }
  @change={ setRange } />

// parent — value is { start, end } ISO strings
created() {
  this.setData({ range: { start: '', end: '' } });
}
events = {
  setRange: (range) => this.setData('range', range),
};`;

const codeTwo = `<!-- two side-by-side month grids sharing the range band -->
<DateRangePicker
  label="Trip dates"
  months={ 2 }
  value={ range }
  @change={ setRange } />`;

const codePresets = `const presets = [
  { label: 'This week',   start: '2026-07-13', end: '2026-07-19' },
  { label: 'Last 7 days', start: '2026-07-12', end: '2026-07-18' },
  { label: 'This month',  start: '2026-07-01', end: '2026-07-31' },
  { label: 'This weekend', start: '2026-07-18', end: '2026-07-19' },
];

<DateRangePicker
  label="Report window"
  value={ range }
  presets={ presets }
  @change={ setRange } />`;

const codeBounds = `<DateRangePicker
  label="Within July"
  min="2026-07-01"
  max="2026-07-31"
  value={ range }
  @change={ setRange } />`;

const codeControlled = `<!-- pass open + @show/@hide to own the open state -->
<DateRangePicker
  label="Booking"
  value={ range }
  open={ open }
  @change={ setRange }
  @show={ onShow }
  @hide={ onHide } />

events = {
  onShow: () => this.setData('open', true),
  onHide: () => this.setData('open', false),
};`;

const codeError = `<DateRangePicker
  label="Contract term"
  error="Please choose a start and end date."
  value={ range }
  @change={ setRange } />`;

const presets = [
  { label: 'This week', start: '2026-07-13', end: '2026-07-19' },
  { label: 'Last 7 days', start: '2026-07-12', end: '2026-07-18' },
  { label: 'This month', start: '2026-07-01', end: '2026-07-31' },
  { label: 'This weekend', start: '2026-07-18', end: '2026-07-19' },
];

export default class DateRangePickerDoc extends PuzzleView {
  created() {
    this.setData({
      heroRange: { start: '', end: '' },
      twoRange: { start: '2026-07-14', end: '2026-07-22' },
      presetRange: { start: '', end: '' },
      boundedRange: { start: '2026-07-08', end: '2026-07-16' },
      controlledRange: { start: '', end: '' },
      controlledOpen: false,
      errorRange: { start: '', end: '' },
    });
  }

  data(params, props) {
    const d = this.getData();
    return {
      ...d,
      presets,
      openLabel: d.controlledOpen ? 'Close picker' : 'Open picker',
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeTwo,
      codePresets,
      codeBounds,
      codeControlled,
      codeError,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Two months', href: '#two-months' },
        { label: 'Presets', href: '#presets' },
        { label: 'Bounds', href: '#bounds' },
        { label: 'Controlled open', href: '#controlled-open' },
        { label: 'Error state', href: '#error' },
      ],
    };
  }

  events = {
    setHeroRange: (range) => this.setData('heroRange', range),
    setTwoRange: (range) => this.setData('twoRange', range),
    setPresetRange: (range) => this.setData('presetRange', range),
    setBoundedRange: (range) => this.setData('boundedRange', range),
    setErrorRange: (range) => this.setData('errorRange', range),
    setControlledRange: (range) => this.setData('controlledRange', range),
    toggleOpen: () => {
      this.setData('controlledOpen', !this.getData().controlledOpen);
      this.refresh();
    },
    onShow: () => {
      this.setData('controlledOpen', true);
      this.refresh();
    },
    onHide: () => {
      this.setData('controlledOpen', false);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

