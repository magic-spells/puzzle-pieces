              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Landmark' }),
                ]),
                new ViewNode('text', { value: ' — pass ' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[13px] text-ink',
                }, [
                  new ViewNode('text', { value: 'label' }),
                ]),
                new ViewNode('text', { value: ' and the viewport becomes a ' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[13px] text-ink',
                }, [
                  new ViewNode('text', { value: 'role="region"' }),
                ]),
                new ViewNode('text', { value: ' a screen-reader user can enter by name' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Decorative thumb' }),
                ]),
                new ViewNode('text', { value: ' — the bar is ' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[13px] text-ink',
                }, [
                  new ViewNode('text', { value: 'aria-hidden' }),
                ]),
                new ViewNode('text', { value: '; it is draggable with a pointer but never focusable' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Reduced motion' }),
                ]),
                new ViewNode('text', { value: ' — the fade-in / fade-out honors ' }),
                new ViewNode('code', {
                  class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[13px] text-ink',
                }, [
                  new ViewNode('text', { value: 'prefers-reduced-motion' }),
