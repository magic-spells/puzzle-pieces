
import { PuzzleView } from '@magic-spells/puzzle';
import HoverCard from '@/components/ui/HoverCard.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece hover-card';
const usageImport = `import HoverCard from '@/components/ui/HoverCard.pzl';`;
const usageMarkup = `<HoverCard></HoverCard>`;

const codeHero = `<HoverCard>
  <a slot="trigger" href="/u/ada" class="…">@ada</a>
  <div class="flex items-start gap-3">
    <span class="…">A</span>
    <div>
      <p class="font-medium text-ink">Ada Lovelace</p>
      <p class="text-muted">@ada</p>
      <p class="mt-1.5">Mathematician. Writing the first algorithm.</p>
    </div>
  </div>
</HoverCard>`;

const codeDelays = `// openDelay (default 600ms) — how long a hover must dwell before the card opens
// closeDelay (default 300ms) — grace period after leaving, so you can reach the panel
<HoverCard openDelay={ 100 } closeDelay={ 100 }>…</HoverCard>
<HoverCard openDelay={ 900 }>…</HoverCard>`;

const codeControlled = `// open is optional-controlled: pass it and the parent owns the state.
// Hover still fires @show / @hide so a controlled parent can keep in sync.
<HoverCard open={ cardOpen } @show={ onShow } @hide={ onHide }>
  <a slot="trigger" href="#" class="…">reference</a>
  <p>…preview…</p>
</HoverCard>

events = {
  onShow: () => this.setData('cardOpen', true),
  onHide: () => this.setData('cardOpen', false),
};`;

const codeA11y = `// A hover card is supplementary — the trigger works without it.
// The link is a real destination; the card only previews it on hover/focus.
<HoverCard>
  <a slot="trigger" href="/docs" class="…">the docs</a>
  <p>…preview…</p>
</HoverCard>`;

export default class HoverCardDoc extends PuzzleView {
  created() {
    this.setData({ cardOpen: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeDelays,
      codeControlled,
      codeA11y,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Delays', href: '#delays' },
        { label: 'Controlled open', href: '#controlled' },
        { label: 'Accessibility', href: '#accessibility' },
      ],
    };
  }

  events = {
    toggleCard: () => {
      this.setData('cardOpen', !this.getData().cardOpen);
      this.refresh();
    },
    onShow: () => {
      this.setData('cardOpen', true);
      this.refresh();
    },
    onHide: () => {
      this.setData('cardOpen', false);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

HoverCardDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
