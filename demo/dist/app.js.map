
import { PuzzleView } from '@magic-spells/puzzle';
import Button from '@/components/ui/Button.pzl';
import AlertDialog from '@/components/ui/AlertDialog.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';
import { toast } from '@/components/ui/toast.js';

const installCmd = 'puzzle add piece alert-dialog';
const usageImport = `import AlertDialog from '@/components/ui/AlertDialog.pzl';`;
const usageMarkup = `<AlertDialog open={ alertOpen } title="Delete project?" description="This permanently removes the project and all of its data." confirmLabel="Delete" destructive @confirm={ confirmAlert } @cancel={ cancelAlert } />`;

const codeHero = `<Button variant="destructive" @press={ openAlert }>Delete project…</Button>
<AlertDialog
  open={ alertOpen }
  title="Delete project?"
  description="This permanently removes the project and all of its data."
  confirmLabel="Delete"
  destructive
  @confirm={ confirmAlert }
  @cancel={ cancelAlert } />

// parent owns open and flips it false in BOTH confirm and cancel
events = {
  openAlert: () => this.setData('alertOpen', true),
  cancelAlert: () => this.setData('alertOpen', false),
  confirmAlert: () => {
    this.setData('alertOpen', false);
    remove();
  },
};`;

const codeConfirm = `<AlertDialog
  open={ confirmOpen }
  title="Publish this post?"
  description="It will be visible to everyone right away."
  confirmLabel="Publish"
  @confirm={ confirmPublish }
  @cancel={ cancelConfirm } />

// no destructive prop → the confirm button uses the primary recipe`;

export default class AlertDialogDoc extends PuzzleView {
  created() {
    this.setData({ alertOpen: false, confirmOpen: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeConfirm,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Non-destructive confirm', href: '#non-destructive' },
      ],
    };
  }

  events = {
    openAlert: () => this.setData('alertOpen', true),
    cancelAlert: () => this.setData('alertOpen', false),
    confirmAlert: () => {
      this.setData('alertOpen', false);
      toast({ title: 'Project deleted', message: 'The project and its data were removed.', variant: 'danger' });
    },
    openConfirm: () => this.setData('confirmOpen', true),
    cancelConfirm: () => this.setData('confirmOpen', false),
    confirmPublish: () => {
      this.setData('confirmOpen', false);
      toast({ message: 'Post published.', variant: 'success' });
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

AlertDialogDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Alert Dialog' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A confirm and cancel modal for consequential actions, on the native alertdialog element. Backdrop clicks do nothing, Escape cancels, and focus starts on Cancel — so the choice is made deliberately, never dismissed by a stray click.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(Button, {
            variant: 'destructive',
            press: ((this.__h ??= {})[0] ??= (event) => this.events.openAlert(event)),
          }, [
            new ViewNode('text', { value: 'Delete project…' }),
          ]),
          new ViewNode(AlertDialog, {
            open: __d.alertOpen,
            title: 'Delete project?',
            description: 'This permanently removes the project and all of its data. This action cannot be undone.',
            confirmLabel: 'Delete',
            destructive: true,
            confirm: ((this.__h ??= {})[1] ??= (event) => this.events.confirmAlert(event)),
            cancel: ((this.__h ??= {})[2] ??= (event) => this.events.cancelAlert(event)),
          }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'non-destructive',
            title: 'Non-destructive confirm',
            code: __d.codeConfirm,
          }, [
            new ViewNode(Button, {
              variant: 'outline',
              press: ((this.__h ??= {})[3] ??= (event) => this.events.openConfirm(event)),
            }, [
              new ViewNode('text', { value: 'Publish…' }),
            ]),
            new ViewNode(AlertDialog, {
              open: __d.confirmOpen,
              title: 'Publish this post?',
              description: 'It will be visible to everyone right away. You can unpublish later.',
              confirmLabel: 'Publish',
              confirm: ((this.__h ??= {})[4] ??= (event) => this.events.confirmPublish(event)),
              cancel: ((this.__h ??= {})[5] ??= (event) => this.events.cancelConfirm(event)),
            }, []),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
