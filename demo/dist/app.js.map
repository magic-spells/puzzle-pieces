              new ViewNode('text', { value: 'maxHeight' }),
            ]),
            new ViewNode('text', { value: 'to cap the viewport.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(ScrollArea, {
            maxHeight: 256,
            label: 'Ingredients',
            class: 'w-72 rounded-lg border border-border bg-surface',
          }, [
            new ViewNode('ul', { class: 'divide-y divide-border' },
              __d.ingredients.map((item) =>
