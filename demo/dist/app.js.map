            new ViewNode('ul', { class: 'space-y-1.5 text-sm text-body' }, [
              new ViewNode('li', {}, [
                new ViewNode('span', { class: 'font-medium text-ink' }, [
                  new ViewNode('text', { value: 'Native scroll' }),
