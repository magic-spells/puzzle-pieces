
import { PuzzleView } from '@magic-spells/puzzle';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Theming & tokens — the "make it yours" reference. Every swatch is a live
// bg-<token>/text-<token> element rendered in the demo's own theme, so the
// grids double as the light/dark demo. Token names below are the real ones
// defined in registry/theme/pieces.css (@theme block), merged into
// app/styles/styles.css the way a consuming app would merge them.
//
// Tailwind v4 scans source TEXT for literal class strings, so each bg-*/text-*
// utility must appear verbatim in this file — that's why every `cls` literal is
// spelled out here and layout classes are composed around it via .map().

const CHIP = 'h-14 w-full rounded-lg border border-border';

const withChip = (list) => list.map((t) => ({ ...t, chip: `${CHIP} ${t.cls}` }));

// Text — darkest to faintest.
const textTokens = [
  { name: 'ink', cls: 'text-ink', role: 'Headings, strong text, control labels' },
  { name: 'body', cls: 'text-body', role: 'Default body copy' },
  { name: 'muted', cls: 'text-muted', role: 'Secondary text, placeholders, hints' },
  { name: 'faint', cls: 'text-faint', role: 'Disabled text, separators' },
].map((t) => ({ ...t, sample: `text-4xl font-semibold leading-none ${t.cls}` }));

const colorGroups = [
  {
    id: 'surfaces',
    title: 'Surfaces',
    desc: 'Three stacked background layers, deepest to nearest.',
    tokens: withChip([
      { name: 'page', cls: 'bg-page', role: 'App background — the deepest layer' },
      { name: 'surface', cls: 'bg-surface', role: 'Cards, inputs, panels, popovers' },
      { name: 'surface-sunken', cls: 'bg-surface-sunken', role: 'Wells, tracks, secondary-button fills' },
    ]),
  },
  {
    id: 'brand',
    title: 'Brand',
    desc: 'The one accent everything keys off — swap it to re-brand the whole UI.',
    tokens: withChip([
      { name: 'brand', cls: 'bg-brand', role: 'Primary actions, active states, links' },
      { name: 'brand-dark', cls: 'bg-brand-dark', role: 'Hover / active' },
      { name: 'brand-tint', cls: 'bg-brand-tint', role: 'Selected rows, ghost hover, soft chips' },
      { name: 'brand-ink', cls: 'bg-brand-ink', role: 'Text / icons on solid brand' },
    ]),
  },
  {
    id: 'feedback',
    title: 'Feedback',
    desc: 'Danger, success, and warning — each with a solid tone and a soft tint background.',
    tokens: withChip([
      { name: 'danger', cls: 'bg-danger', role: 'Destructive actions, invalid states' },
      { name: 'danger-dark', cls: 'bg-danger-dark', role: 'Hover / active' },
      { name: 'danger-tint', cls: 'bg-danger-tint', role: 'Soft error backgrounds' },
      { name: 'danger-ink', cls: 'bg-danger-ink', role: 'Text / icons on solid danger' },
      { name: 'success', cls: 'bg-success', role: 'Positive deltas, "up is good"' },
      { name: 'success-tint', cls: 'bg-success-tint', role: 'Soft positive backgrounds' },
      { name: 'warning', cls: 'bg-warning', role: 'Caution band — meters, gauges, alerts' },
      { name: 'warning-tint', cls: 'bg-warning-tint', role: 'Soft caution backgrounds' },
    ]),
  },
  {
    id: 'lines',
    title: 'Borders & focus',
    desc: 'Hairlines and the focus ring. Shown here as fills so you can read the color.',
    tokens: withChip([
      { name: 'border', cls: 'bg-border', role: 'Default hairlines (as border-border)' },
      { name: 'border-strong', cls: 'bg-border-strong', role: 'Hover borders, pressed outlines' },
      { name: 'ring', cls: 'bg-ring', role: 'Focus rings (usually equal to brand)' },
    ]),
  },
];

const chartTokens = [
  { name: 'chart-1', cls: 'bg-chart-1' },
  { name: 'chart-2', cls: 'bg-chart-2' },
  { name: 'chart-3', cls: 'bg-chart-3' },
  { name: 'chart-4', cls: 'bg-chart-4' },
  { name: 'chart-5', cls: 'bg-chart-5' },
  { name: 'chart-6', cls: 'bg-chart-6' },
  { name: 'chart-7', cls: 'bg-chart-7' },
  { name: 'chart-8', cls: 'bg-chart-8' },
].map((t) => ({ ...t, chip: `h-16 w-full rounded-lg border border-border ${t.cls}`, short: t.name }));

const mechanismSnippet = `:root                    { color-scheme: light dark; } /* OS decides */
:root[data-theme='light'] { color-scheme: light; }
:root[data-theme='dark']  { color-scheme: dark; }

@theme {
  --color-surface: light-dark(#ffffff, #101013);
  --color-ink:     light-dark(#1f2933, #f4f4f5);
  --color-brand:   light-dark(#4c6ef5, #5c7cfa);
  /* …every token is one light/dark pair… */
}`;

const usageSnippet = `<div class="rounded-xl border border-border bg-surface p-4">
  <h3 class="text-ink">Card title</h3>
  <p class="text-muted">Secondary copy sits on text-muted.</p>

  <button class="bg-brand text-brand-ink hover:bg-brand-dark">
    Primary action
  </button>
</div>`;

export default class Theming extends PuzzleView {
  data(params, props) {
    return {
      bgToken: 'bg-<token>',
      textToken: 'text-<token>',
      htmlTag: '<html>',
      textTokens,
      colorGroups,
      chartTokens,
      mechanismSnippet,
      usageSnippet,
      toc: [
        { label: 'How it works', href: '#how-it-works' },
        { label: 'Text & ink', href: '#text' },
        { label: 'Surfaces', href: '#surfaces' },
        { label: 'Brand', href: '#brand' },
        { label: 'Feedback', href: '#feedback' },
        { label: 'Borders & focus', href: '#lines' },
        { label: 'Chart palette', href: '#charts' },
        { label: 'Using tokens', href: '#usage' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

Theming.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full max-w-5xl min-w-0' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Theming & tokens' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'Every Puzzle Piece styles itself through one small set of semantic tokens —' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'bg-surface' }),
            ]),
            new ViewNode('text', { value: ',' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'text-ink' }),
            ]),
            new ViewNode('text', { value: ',' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'bg-brand' }),
            ]),
            new ViewNode('text', { value: ',' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'border-border' }),
            ]),
            new ViewNode('text', { value: ' — never raw colors. Edit the values in one place and your whole UI re-skins. This is the “make it yours” layer.' }),
          ]),
        ]),
        new ViewNode('div', { class: 'mb-12 rounded-xl border border-border bg-brand-tint p-4' }, [
          new ViewNode('p', { class: 'text-sm/relaxed text-ink' }, [
            new ViewNode('span', { class: 'font-semibold' }, [
              new ViewNode('text', { value: 'Every swatch below is live.' }),
            ]),
            new ViewNode('text', { value: ' Each chip is a bare' }),
            new ViewNode('code', { class: 'rounded bg-surface px-1.5 py-0.5 font-mono text-[12px] text-ink' }, [
              new ViewNode('text', { value: String(__d.bgToken) }),
            ]),
            new ViewNode('text', { value: 'div rendered in this page’s own theme. Flip the theme toggle in the header and watch them all resolve to their dark values — that is the entire mechanism, on display.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'how-it-works',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'How it works' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm/relaxed text-body' }, [
            new ViewNode('text', { value: 'Tokens live in a Tailwind v4' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@theme' }),
            ]),
            new ViewNode('text', { value: 'block. Each one is a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'light-dark()' }),
            ]),
            new ViewNode('text', { value: 'pair, resolved by the element’s' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'color-scheme' }),
            ]),
            new ViewNode('text', { value: '. A manual switcher only has to set' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'data-theme' }),
            ]),
            new ViewNode('text', { value: 'on ' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: String(__d.htmlTag) }),
            ]),
            new ViewNode('text', { value: ' — that flips ' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'color-scheme' }),
            ]),
            new ViewNode('text', { value: ', which also keeps native UI (form controls, scrollbars, dialog backdrops) in step. No duplicate dark-mode class list, no per-component overrides.' }),
          ]),
          new ViewNode(CodeBlock, {
            code: __d.mechanismSnippet,
            lang: 'css',
          }, []),
        ]),
        new ViewNode('section', {
          id: 'text',
          class: 'mt-14 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-2 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Text & ink' }),
          ]),
          new ViewNode('p', { class: 'mb-5 max-w-2xl text-sm/relaxed text-body' }, [
            new ViewNode('text', { value: 'Four text weights, darkest to faintest. Apply them with' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: String(__d.textToken) }),
            ]),
            new ViewNode('text', { value: '.' }),
          ]),
          new ViewNode('div', { class: 'grid gap-4 sm:grid-cols-2 lg:grid-cols-4' },
            __d.textTokens.map((t) =>
              new ViewNode('div', {
                key: t.name,
                class: 'rounded-xl border border-border bg-surface p-4',
              }, [
                new ViewNode('p', { class: t.sample }, [
                  new ViewNode('text', { value: 'Ag' }),
                ]),
                new ViewNode('p', { class: 'mt-3 font-mono text-[13px] text-ink' }, [
                  new ViewNode('text', { value: String(t.cls) }),
                ]),
                new ViewNode('p', { class: 'mt-0.5 text-xs/relaxed text-muted' }, [
                  new ViewNode('text', { value: String(t.role) }),
                ]),
              ])
            )
          ),
        ]),
        ...__d.colorGroups.map((g) =>
          new ViewNode('section', {
            id: g.id,
            key: g.id,
            class: 'mt-14 scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-2 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: String(g.title) }),
            ]),
            new ViewNode('p', { class: 'mb-5 max-w-2xl text-sm/relaxed text-body' }, [
              new ViewNode('text', { value: String(g.desc) }),
            ]),
            new ViewNode('div', { class: 'grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4' },
              g.tokens.map((t) =>
                new ViewNode('div', {
                  key: t.name,
                  class: 'rounded-xl border border-border bg-surface p-3',
                }, [
                  new ViewNode('div', { class: t.chip }, []),
                  new ViewNode('p', { class: 'mt-2.5 font-mono text-[13px] text-ink' }, [
                    new ViewNode('text', { value: String(t.cls) }),
                  ]),
                  new ViewNode('p', { class: 'mt-0.5 text-xs/relaxed text-muted' }, [
                    new ViewNode('text', { value: String(t.role) }),
                  ]),
                ])
              )
            ),
          ])
        ),
        new ViewNode('section', {
          id: 'charts',
          class: 'mt-14 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-2 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Chart palette' }),
          ]),
          new ViewNode('p', { class: 'mb-5 max-w-2xl text-sm/relaxed text-body' }, [
            new ViewNode('text', { value: 'Eight categorical series colors, assigned in fixed slot order (1 → 8), never cycled. Validated for colorblind safety and consistent lightness/chroma bands in both light and dark. Chart pieces read these as' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'chart-1' }),
            ]),
            new ViewNode('text', { value: 'through' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'chart-8' }),
            ]),
            new ViewNode('text', { value: '.' }),
          ]),
          new ViewNode('div', { class: 'grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-8' },
            __d.chartTokens.map((t) =>
              new ViewNode('div', {
                key: t.name,
                class: 'rounded-xl border border-border bg-surface p-3',
              }, [
                new ViewNode('div', { class: t.chip }, []),
                new ViewNode('p', { class: 'mt-2.5 font-mono text-[12px] text-ink' }, [
                  new ViewNode('text', { value: String(t.short) }),
                ]),
              ])
            )
          ),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-14 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Using tokens in your markup' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm/relaxed text-body' }, [
            new ViewNode('text', { value: 'Reach for the semantic utility, never a hex or a stock Tailwind color. The same markup is correct in both themes because the token, not the class, carries the light/dark values.' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageSnippet }, []),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
