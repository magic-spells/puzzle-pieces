            new ViewNode('p', { class: 'mb-4 text-sm text-body' }, [
              new ViewNode('text', { value: 'The day grid is a roving-tabindex grid — one Tab stop lands on the active day, then the keys move the focus:' }),
            ]),
            new ViewNode('ul', { class: 'space-y-2.5 text-sm text-body' }, [
              new ViewNode('li', {}, [
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: '←' }),
                ]),
                new ViewNode('text', { value: ' ' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: '→' }),
                ]),
                new ViewNode('text', { value: ' move by one day;' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: '↑' }),
                ]),
                new ViewNode('text', { value: ' ' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: '↓' }),
                ]),
                new ViewNode('text', { value: ' move by one week (±7 days).' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'Home' }),
                ]),
                new ViewNode('text', { value: ' and ' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'End' }),
                ]),
                new ViewNode('text', { value: ' jump to the start and end of the focused week.' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'Page Up' }),
                ]),
                new ViewNode('text', { value: ' and ' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'Page Down' }),
                ]),
                new ViewNode('text', { value: ' move by one month; hold ' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'Shift' }),
                ]),
                new ViewNode('text', { value: ' to move by one year.' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'Enter' }),
                ]),
                new ViewNode('text', { value: ' or ' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'Space' }),
                ]),
                new ViewNode('text', { value: ' selects the focused day.' }),
              ]),
              new ViewNode('li', {}, [
                new ViewNode('text', { value: 'Activate the header label to drill down into the months and years views; the arrows rove those grids too, and ' }),
                new ViewNode('kbd', { class: __d.keyClass }, [
                  new ViewNode('text', { value: 'Escape' }),
