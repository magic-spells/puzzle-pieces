              new ViewNode('text', { value: 'attachments' }),
            ]),
            new ViewNode('text', { value: 'slot.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-xl' }, [
            new ViewNode(ChatMessage, {
              author: 'Ada Lovelace',
              time: '9:41 AM',
              avatarName: 'Ada Lovelace',
            }, [
              new ViewNode('text', { value: 'Are we still on for the design review at 3?' }),
            ]),
            new ViewNode(ChatMessage, {
              showMeta: false,
              avatarName: 'Ada Lovelace',
            }, [
              new ViewNode('text', { value: 'I pushed the latest mockups just now.' }),
            ]),
            new ViewNode(ChatMessage, {
              align: 'end',
              variant: 'sent',
              author: 'You',
              time: '9:42 AM',
              avatarName: 'You',
            }, [
              new ViewNode('text', { value: 'Yep — see you then. Taking a look now.' }),
            ]),
            new ViewNode(ChatMessage, {
              align: 'end',
              variant: 'sent',
              showMeta: false,
              avatarName: 'You',
            }, [
              new ViewNode('text', { value: 'These look great 🎉' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
