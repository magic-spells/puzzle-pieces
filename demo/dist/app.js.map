
import { PuzzleView } from '@magic-spells/puzzle';
import RadioGroup from '@/components/ui/RadioGroup.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece radio-group';
const usageImport = `import RadioGroup from '@/components/ui/RadioGroup.pzl';`;
const usageMarkup = `<RadioGroup label="Plan" options={ planOptions } value={ plan } @change={ setPlan } />`;

const codeHero = `<RadioGroup label="Plan" options={ planOptions } value={ plan } @change={ setPlan } />

// parent
data() {
  return {
    planOptions: [
      { value: 'free', label: 'Free' },
      { value: 'pro', label: 'Pro' },
      { value: 'enterprise', label: 'Enterprise' },
    ],
  };
}
events = { setPlan: (v) => this.setData('plan', v) };`;

const codeHorizontal = `<RadioGroup
  label="Size"
  options={ sizeOptions }
  value={ size }
  orientation="horizontal"
  @change={ setSize } />`;

const codeHints = `const planOptions = [
  { value: 'free', label: 'Free', hint: 'For hobby projects' },
  { value: 'pro', label: 'Pro', hint: 'For growing teams' },
  { value: 'enterprise', label: 'Enterprise', hint: 'Talk to sales', disabled: true },
];

<RadioGroup label="Plan" options={ planOptions } value={ plan } @change={ setPlan } />`;

export default class RadioGroupDoc extends PuzzleView {
  created() {
    this.setData({ plan: 'pro', size: 'm', planDetail: 'pro' });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeHorizontal,
      codeHints,
      planOptions: [
        { value: 'free', label: 'Free' },
        { value: 'pro', label: 'Pro' },
        { value: 'enterprise', label: 'Enterprise' },
      ],
      sizeOptions: [
        { value: 's', label: 'Small' },
        { value: 'm', label: 'Medium' },
        { value: 'l', label: 'Large' },
      ],
      planDetailOptions: [
        { value: 'free', label: 'Free', hint: 'For hobby projects' },
        { value: 'pro', label: 'Pro', hint: 'For growing teams' },
        { value: 'enterprise', label: 'Enterprise', hint: 'Talk to sales', disabled: true },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Horizontal', href: '#horizontal' },
        { label: 'Option hints and disabled', href: '#hints' },
      ],
    };
  }

  events = {
    setPlan: (v) => {
      this.setData('plan', v);
      this.refresh();
    },
    setSize: (v) => {
      this.setData('size', v);
      this.refresh();
    },
    setPlanDetail: (v) => {
      this.setData('planDetail', v);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

RadioGroupDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Radio Group' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A config-first radio group rendered from an' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'options' }),
            ]),
            new ViewNode('text', { value: 'array. Each row is a native radio input, so arrow-key movement comes for free; layout is vertical or horizontal, and options carry their own hints and disabled state.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode(RadioGroup, {
            label: 'Plan',
            options: __d.planOptions,
            value: __d.plan,
            change: ((this.__h ??= {})[0] ??= (event) => this.events.setPlan(event)),
          }, []),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'horizontal',
            title: 'Horizontal',
            code: __d.codeHorizontal,
          }, [
            new ViewNode(RadioGroup, {
              label: 'Size',
              options: __d.sizeOptions,
              value: __d.size,
              orientation: 'horizontal',
              change: ((this.__h ??= {})[1] ??= (event) => this.events.setSize(event)),
            }, []),
          ]),
          new ViewNode(ExampleBox, {
            id: 'hints',
            title: 'Option hints and disabled',
            code: __d.codeHints,
          }, [
            new ViewNode(RadioGroup, {
              label: 'Plan',
              options: __d.planDetailOptions,
              value: __d.planDetail,
              change: ((this.__h ??= {})[2] ??= (event) => this.events.setPlanDetail(event)),
            }, []),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
