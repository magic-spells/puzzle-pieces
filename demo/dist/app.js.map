
import { PuzzleView } from '@magic-spells/puzzle';
import Table from '@/components/ui/Table.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece table';
const usageImport = `import Table from '@/components/ui/Table.pzl';`;
const usageMarkup = `<Table columns={ columns } rows={ rows } caption="Invoices billed this quarter" />`;

const codeHero = `const columns = [
  { key: 'invoice', label: 'Invoice' },
  { key: 'client', label: 'Client' },
  { key: 'status', label: 'Status' },
  { key: 'amount', label: 'Amount', align: 'right' },
];
const rows = [
  { invoice: 'INV-1042', client: 'Acme Inc.', status: 'Paid', amount: '$1,200.00' },
  { invoice: 'INV-1043', client: 'Globex', status: 'Pending', amount: '$980.00' },
  { invoice: 'INV-1044', client: 'Initech', status: 'Paid', amount: '$3,450.00' },
];

<Table columns={ columns } rows={ rows } caption="Invoices billed this quarter" />`;

const codeAlignment = `const columns = [
  { key: 'item', label: 'Item' },
  { key: 'qty', label: 'Qty', align: 'center' },
  { key: 'price', label: 'Price', align: 'right' },
];

<Table columns={ columns } rows={ rows } />`;

const codeEmpty = `// An empty rows array renders one centered cell spanning every column.
// The empty prop overrides the default "No results." text.
<Table columns={ columns } rows={ [] } empty="No invoices this quarter." />`;

export default class TableDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeAlignment,
      codeEmpty,
      invoiceColumns: [
        { key: 'invoice', label: 'Invoice' },
        { key: 'client', label: 'Client' },
        { key: 'status', label: 'Status' },
        { key: 'amount', label: 'Amount', align: 'right' },
      ],
      invoiceRows: [
        { invoice: 'INV-1042', client: 'Acme Inc.', status: 'Paid', amount: '$1,200.00' },
        { invoice: 'INV-1043', client: 'Globex', status: 'Pending', amount: '$980.00' },
        { invoice: 'INV-1044', client: 'Initech', status: 'Paid', amount: '$3,450.00' },
        { invoice: 'INV-1045', client: 'Umbrella Co.', status: 'Overdue', amount: '$540.00' },
        { invoice: 'INV-1046', client: 'Soylent', status: 'Draft', amount: '$120.00' },
      ],
      alignColumns: [
        { key: 'item', label: 'Item' },
        { key: 'qty', label: 'Qty', align: 'center' },
        { key: 'price', label: 'Price', align: 'right' },
      ],
      alignRows: [
        { item: 'Enamel pin', qty: '3', price: '$18.00' },
        { item: 'Sticker sheet', qty: '12', price: '$6.00' },
        { item: 'Tote bag', qty: '1', price: '$24.00' },
      ],
      noRows: [],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Alignment', href: '#alignment' },
        { label: 'Empty state', href: '#empty' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

TableDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Table' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A config-first styled semantic table. A' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'columns' }),
            ]),
            new ViewNode('text', { value: 'schema and a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'rows' }),
            ]),
            new ViewNode('text', { value: 'array render one real table with per-column alignment, an optional caption, and an empty state.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full' }, [
            new ViewNode(Table, {
              columns: __d.invoiceColumns,
              rows: __d.invoiceRows,
              caption: 'Invoices billed this quarter',
            }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'This is the presentational tier, not a data grid. Sorting, selection, and virtualization are out of scope by design — own that state in the parent and feed sorted or paged rows in.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'alignment',
            title: 'Alignment',
            code: __d.codeAlignment,
          }, [
            new ViewNode('div', { class: 'w-full' }, [
              new ViewNode(Table, {
                columns: __d.alignColumns,
                rows: __d.alignRows,
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'empty',
            title: 'Empty state',
            code: __d.codeEmpty,
          }, [
            new ViewNode('div', { class: 'w-full' }, [
              new ViewNode(Table, {
                columns: __d.invoiceColumns,
                rows: __d.noRows,
                empty: 'No invoices this quarter.',
              }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
