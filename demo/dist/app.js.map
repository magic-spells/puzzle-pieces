          ]),
          new ViewNode(ExampleBox, {
            id: 'forms',
            title: 'Forms',
            code: __d.codeForms,
          }, [
            new ViewNode('div', { class: 'flex flex-col items-center gap-3' }, [
              new ViewNode(Rating, {
