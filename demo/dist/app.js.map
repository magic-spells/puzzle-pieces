
import { PuzzleView } from '@magic-spells/puzzle';
import Button from '@/components/ui/Button.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';
import { toast, clearToasts } from '@/components/ui/toast.js';

// Docs page for Toast — follows the Button exemplar shape (header → hero
// ExampleBox → Installation → examples → Toc). Toast ships as two files, so
// installation copies both toast.js and Toaster.pzl.
const installCmd = 'puzzle add piece toast';
const usageImport = `import { toast } from '@/components/ui/toast.js';`;
const usageMarkup = `toast('Your draft was saved.');`;

const codeHero = `import { toast } from '@/components/ui/toast.js';

toast('Your draft was saved.');
toast({ title: 'Published', message: 'The post is now live.', variant: 'success' });
toast({ title: 'Upload failed', message: 'Check your connection.', variant: 'danger' });`;

const codeSticky = `import { toast, clearToasts } from '@/components/ui/toast.js';

// duration: 0 never auto-dismisses — it stays until closed
toast({ title: 'Sticky', message: 'This one stays until dismissed.', duration: 0 });

// dismiss every visible toast at once
clearToasts();`;

const setupCode = `// app/layouts/AppLayout.pzl — mount the host once, near the root
<Toaster position="bottom-right" />

// then, from any view or module
import { toast } from '@/components/ui/toast.js';
toast('Saved!');`;

export default class ToastDoc extends PuzzleView {
  data(params, props) {
    return {
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeSticky,
      setupCode,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Sticky and dismissal', href: '#sticky' },
        { label: 'Setup', href: '#setup' },
      ],
    };
  }

  events = {
    fireDefault: () => toast('Your draft was saved.'),
    fireSuccess: () => toast({ title: 'Published', message: 'The post is now live.', variant: 'success' }),
    fireDanger: () => toast({ title: 'Upload failed', message: 'Check your connection and retry.', variant: 'danger' }),
    fireSticky: () => toast({ title: 'Sticky', message: 'This one stays until dismissed.', duration: 0 }),
    clearAll: () => clearToasts(),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ToastDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Toast' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An imperative' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'toast()' }),
            ]),
            new ViewNode('text', { value: 'API with a host that mounts once in your layout — variants, pausable auto-dismiss, and corner positioning.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
            new ViewNode(Button, {
              variant: 'outline',
              press: ((this.__h ??= {})[0] ??= (event) => this.events.fireDefault(event)),
            }, [
              new ViewNode('text', { value: 'Default' }),
            ]),
            new ViewNode(Button, {
              variant: 'outline',
              press: ((this.__h ??= {})[1] ??= (event) => this.events.fireSuccess(event)),
            }, [
              new ViewNode('text', { value: 'Success' }),
            ]),
            new ViewNode(Button, {
              variant: 'outline',
              press: ((this.__h ??= {})[2] ??= (event) => this.events.fireDanger(event)),
            }, [
              new ViewNode('text', { value: 'Danger' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Toast is two files — the store and public API in toast.js, and the Toaster host that renders them. Copy both into your app:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'sticky',
            title: 'Sticky and dismissal',
            code: __d.codeSticky,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(Button, {
                variant: 'outline',
                press: ((this.__h ??= {})[3] ??= (event) => this.events.fireSticky(event)),
              }, [
                new ViewNode('text', { value: 'Sticky toast' }),
              ]),
              new ViewNode(Button, {
                variant: 'ghost',
                press: ((this.__h ??= {})[4] ??= (event) => this.events.clearAll(event)),
              }, [
                new ViewNode('text', { value: 'Clear all' }),
              ]),
            ]),
          ]),
          new ViewNode('section', {
            id: 'setup',
            class: 'scroll-mt-20',
          }, [
            new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
              new ViewNode('text', { value: 'Setup' }),
            ]),
            new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
              new ViewNode('text', { value: 'Mount a single Toaster host once, near the root of your app layout, and pick a corner with the position prop. Then call' }),
              new ViewNode('code', {
                class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink',
              }, [
                new ViewNode('text', { value: 'toast()' }),
              ]),
              new ViewNode('text', { value: 'from anywhere — the host subscribes to the store and renders every notification.' }),
            ]),
            new ViewNode(CodeBlock, { code: __d.setupCode }, []),
            new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
              new ViewNode('text', { value: 'This demo\'s layout already mounts a Toaster, which is why the buttons above just work.' }),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
