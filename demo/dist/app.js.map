
import { PuzzleView } from '@magic-spells/puzzle';
import QuantityInput from '@/components/ui/QuantityInput.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece quantity-input';
const usageImport = `import QuantityInput from '@/components/ui/QuantityInput.pzl';`;
const usageMarkup = `<QuantityInput value={ qty } min={ 1 } max={ 10 } @change={ setQty } />`;

const codeHero = `<QuantityInput value={ qty } min={ 1 } max={ 10 } @change={ setQty } />

// parent
events = {
  setQty: (v) => this.setData('qty', v),
};`;

const codeBounds = `// buttons disable at the bounds; typing past them clamps on commit
<QuantityInput value={ boxes } min={ 2 } max={ 6 } @change={ setBoxes } />`;

export default class QuantityInputDoc extends PuzzleView {
  created() {
    this.setData({ qty: 1, boxes: 2 });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeBounds,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Bounds', href: '#bounds' },
      ],
    };
  }

  events = {
    setQty: (v) => {
      this.setData('qty', v);
      this.refresh();
    },
    setBoxes: (v) => {
      this.setData('boxes', v);
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

QuantityInputDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Quantity Input' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An e-commerce stepper: decrement and increment buttons around a number input, as one bordered control. Every emitted value is clamped to' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '[min, max]' }),
            ]),
            new ViewNode('text', { value: '— the buttons stop and disable at the bounds, and typing is clamped on commit.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex items-center gap-6' }, [
            new ViewNode(QuantityInput, {
              value: __d.qty,
              min: 1,
              max: 10,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setQty(event)),
            }, []),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'Current: ' + String(__d.qty) }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'bounds',
            title: 'Bounds',
            code: __d.codeBounds,
          }, [
            new ViewNode('div', { class: 'flex items-center gap-6' }, [
              new ViewNode(QuantityInput, {
                value: __d.boxes,
                min: 2,
                max: 6,
                change: ((this.__h ??= {})[1] ??= (event) => this.events.setBoxes(event)),
              }, []),
              new ViewNode('p', { class: 'text-sm text-muted' }, [
                new ViewNode('text', { value: '2–6 · Current: ' + String(__d.boxes) }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
