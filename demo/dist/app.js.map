
import { PuzzleView } from '@magic-spells/puzzle';
import ToggleGroup from '@/components/ui/ToggleGroup.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for ToggleGroup — follows the ButtonDoc exemplar shape.
const installCmd = 'puzzle add piece toggle-group';
const usageImport = `import ToggleGroup from '@/components/ui/ToggleGroup.pzl';`;
const usageMarkup = `<ToggleGroup items={ aligns } value={ align } @change={ setAlign } label="Text alignment"/>`;

const codeHero = `const aligns = [
  { value: 'left', label: 'Left' },
  { value: 'center', label: 'Center' },
  { value: 'right', label: 'Right' },
];

// single-select with deselect — '' means nothing selected
<ToggleGroup items={ aligns } value={ align } @change={ setAlign } label="Text alignment"/>

// parent
events = { setAlign: (v) => this.setData('align', v) };`;

const codeMultiple = `const marks = [
  { value: 'bold', label: 'B' },
  { value: 'italic', label: 'I' },
  { value: 'underline', label: 'U' },
];

// multiple-select — value is an array of selected values
<ToggleGroup type="multiple" items={ marks } value={ marks$ } @change={ setMarks } label="Text formatting"/>

// parent
events = { setMarks: (v) => this.setData('marks', v) };`;

const codeIcon = `// icon field is ignored — use a short/emoji label as the accessible name
const aligns = [
  { value: 'left', label: '⇤' },
  { value: 'center', label: '↔' },
  { value: 'right', label: '⇥' },
];

<ToggleGroup items={ aligns } value={ align } @change={ setAlign } label="Text alignment"/>`;

export default class ToggleGroupDoc extends PuzzleView {
  created() {
    this.setData({ align: 'left', marks: ['bold'] });
  }

  data(params, props) {
    const { marks } = this.getData();
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeMultiple,
      codeIcon,
      marksLabel: marks && marks.length ? marks.join(', ') : 'none',
      alignOptions: [
        { value: 'left', label: 'Left' },
        { value: 'center', label: 'Center' },
        { value: 'right', label: 'Right' },
      ],
      markOptions: [
        { value: 'bold', label: 'B' },
        { value: 'italic', label: 'I' },
        { value: 'underline', label: 'U' },
      ],
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Multiple', href: '#multiple' },
        { label: 'Icon-only groups', href: '#icon-only' },
      ],
    };
  }

  events = {
    setAlign: (v) => this.setData('align', v),
    setMarks: (v) => this.setData('marks', v),
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ToggleGroupDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Toggle Group' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A config-first joined row of pressed-state buttons. It\'s a' }),
            new ViewNode('strong', { class: 'font-medium text-ink' }, [
              new ViewNode('text', { value: 'pressed-buttons' }),
            ]),
            new ViewNode('text', { value: ' pattern, not a radio group — even in single mode you can click the active item again to deselect it. The parent owns' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'value' }),
            ]),
            new ViewNode('text', { value: '.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
            new ViewNode(ToggleGroup, {
              items: __d.alignOptions,
              value: __d.align,
              change: ((this.__h ??= {})[0] ??= (event) => this.events.setAlign(event)),
              label: 'Text alignment',
            }, []),
            new ViewNode('p', { class: 'text-sm text-muted' }, [
              new ViewNode('text', { value: 'Alignment: ' + String(__d.align || 'none') }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'multiple',
            title: 'Multiple',
            code: __d.codeMultiple,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(ToggleGroup, {
                type: 'multiple',
                items: __d.markOptions,
                value: __d.marks,
                change: ((this.__h ??= {})[1] ??= (event) => this.events.setMarks(event)),
                label: 'Text formatting',
              }, []),
              new ViewNode('p', { class: 'text-sm text-muted' }, [
                new ViewNode('text', { value: 'Marks: ' + String(__d.marksLabel) }),
              ]),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'icon-only',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Icon-only groups' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Per-item SVG props aren\'t possible in Puzzle: a component only inlines SVG through the compile-time svg block, which needs a literal file path, not per-item data. So an item\'s icon field is never rendered — the label is what shows.' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'For an icon-only look today, pass a short or emoji label. It stays a real accessible name, so screen readers still announce the control:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.codeIcon }, []),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
