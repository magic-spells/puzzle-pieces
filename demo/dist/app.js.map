
import { PuzzleView } from '@magic-spells/puzzle';
import Kbd from '@/components/ui/Kbd.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

const installCmd = 'puzzle add piece kbd';
const usageImport = `import Kbd from '@/components/ui/Kbd.pzl';`;
const usageMarkup = `<Kbd>⌘</Kbd>`;

const codeHero = `<span><Kbd>⌘</Kbd> <Kbd>K</Kbd> Command palette</span>
<span><Kbd>⌘</Kbd> <Kbd>S</Kbd> Save</span>
<span><Kbd>Esc</Kbd> Close</span>`;

const codeProse = `<p>
  Press <Kbd>⌘</Kbd> <Kbd>K</Kbd> to open the command palette, or hit
  <Kbd>Esc</Kbd> at any time to dismiss it.
</p>`;

export default class KbdDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeProse,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'In prose', href: '#prose' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

KbdDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Kbd' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A keyboard-key hint rendered in the native kbd element with an inset keycap shadow. Slot content is the key or chord text; a class prop appends the caller\'s utilities.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, {
          tall: false,
          code: __d.codeHero,
        }, [
          new ViewNode('div', {
            class: 'flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-sm text-body',
          }, [
            new ViewNode('span', { class: 'inline-flex items-center gap-1.5' }, [
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: '⌘' }),
              ]),
              new ViewNode('text', { value: ' ' }),
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: 'K' }),
              ]),
              new ViewNode('text', { value: ' Command palette' }),
            ]),
            new ViewNode('span', { class: 'inline-flex items-center gap-1.5' }, [
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: '⌘' }),
              ]),
              new ViewNode('text', { value: ' ' }),
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: 'S' }),
              ]),
              new ViewNode('text', { value: ' Save' }),
            ]),
            new ViewNode('span', { class: 'inline-flex items-center gap-1.5' }, [
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: 'Esc' }),
              ]),
              new ViewNode('text', { value: ' Close' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'prose',
            title: 'In prose',
            tall: false,
            code: __d.codeProse,
          }, [
            new ViewNode('p', { class: 'max-w-md text-center text-sm/relaxed text-body' }, [
              new ViewNode('text', { value: 'Press ' }),
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: '⌘' }),
              ]),
              new ViewNode('text', { value: ' ' }),
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: 'K' }),
              ]),
              new ViewNode('text', { value: ' to open the command palette, or hit' }),
              new ViewNode(Kbd, {}, [
                new ViewNode('text', { value: 'Esc' }),
              ]),
              new ViewNode('text', { value: ' at any time to dismiss it.' }),
            ]),
          ]),
          new ViewNode('p', { class: 'text-sm text-body' }, [
            new ViewNode('text', { value: 'Each key is its own piece, so chords are written as adjacent tags. Inline, they sit on the text baseline and inherit the surrounding size, so they read naturally mid-sentence.' }),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
