
import { PuzzleView } from '@magic-spells/puzzle';
import Alert from '@/components/ui/Alert.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';

// Docs page for Alert — follows the Button exemplar shape (header → hero
// ExampleBox → Installation → titled example sections → Toc).
const installCmd = 'puzzle add piece alert';
const usageImport = `import Alert from '@/components/ui/Alert.pzl';`;
const usageMarkup = `<Alert variant="brand" title="Heads up"></Alert>`;

const codeHero = `<Alert variant="brand" title="Heads up">
  A new version is available. Refresh to update.
</Alert>`;

const codeVariants = `<Alert>Your changes were saved.</Alert>
<Alert variant="brand" title="Heads up">A new version is available.</Alert>
<Alert variant="danger" title="Payment failed">Update your card to continue.</Alert>`;

const codeNoTitle = `<Alert>Your changes were saved.</Alert>
<Alert variant="danger">We couldn't reach the server. Retrying…</Alert>`;

export default class AlertDoc extends PuzzleView {
  data(params, props) {
    return {
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeVariants,
      codeNoTitle,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Variants', href: '#variants' },
        { label: 'Without title', href: '#without-title' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

AlertDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Alert' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'An inline callout with default, brand, and danger variants, a leading icon, and an optional title. The danger variant is assertive (role="alert"); the others announce politely.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-md' }, [
            new ViewNode(Alert, {
              variant: 'brand',
              title: 'Heads up',
            }, [
              new ViewNode('text', { value: 'A new version is available. Refresh to update.' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'variants',
            title: 'Variants',
            code: __d.codeVariants,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md space-y-3' }, [
              new ViewNode(Alert, {}, [
                new ViewNode('text', { value: 'Your changes were saved.' }),
              ]),
              new ViewNode(Alert, {
                variant: 'brand',
                title: 'Heads up',
              }, [
                new ViewNode('text', { value: 'A new version is available.' }),
              ]),
              new ViewNode(Alert, {
                variant: 'danger',
                title: 'Payment failed',
              }, [
                new ViewNode('text', { value: 'Update your card to continue.' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'without-title',
            title: 'Without title',
            code: __d.codeNoTitle,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md space-y-3' }, [
              new ViewNode(Alert, {}, [
                new ViewNode('text', { value: 'Your changes were saved.' }),
              ]),
              new ViewNode(Alert, { variant: 'danger' }, [
                new ViewNode('text', { value: 'We couldn\'t reach the server. Retrying…' }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
