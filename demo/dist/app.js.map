
import { PuzzleView } from '@magic-spells/puzzle';
import Button from '@/components/ui/Button.pzl';
import ExampleBox from '@/components/docs/ExampleBox.pzl';
import CodeBlock from '@/components/docs/CodeBlock.pzl';
import Toc from '@/components/docs/Toc.pzl';
import { toast } from '@/components/ui/toast.js';

// Docs page for Button — THE exemplar page: every other component page follows
// this exact shape (header → hero ExampleBox → Installation → titled example
// sections → Toc mirroring the section ids).
const installCmd = 'puzzle add piece button';
const usageImport = `import Button from '@/components/ui/Button.pzl';`;
const usageMarkup = `<Button variant="primary" @press={ getStarted }>Get started</Button>`;

const codeHero = `<Button variant="primary" @press={ getStarted }>Get started</Button>
<Button variant="outline" @press={ learnMore }>Learn more</Button>`;

const codeVariants = `<Button variant="primary" @press={ save }>Primary</Button>
<Button variant="secondary" @press={ save }>Secondary</Button>
<Button variant="outline" @press={ save }>Outline</Button>
<Button variant="ghost" @press={ save }>Ghost</Button>
<Button variant="destructive" @press={ remove }>Destructive</Button>`;

const codeSizes = `<Button size="sm" @press={ save }>Small</Button>
<Button size="md" @press={ save }>Medium</Button>
<Button size="lg" @press={ save }>Large</Button>`;

const codeStates = `<Button disabled>Disabled</Button>
<Button variant="primary" loading={ saving }>Save changes</Button>

// parent
events = {
  save: async () => {
    this.setData({ saving: true });
    this.refresh();
    await api.save();
    this.setData({ saving: false });
    this.refresh();
  },
};`;

export default class ButtonDoc extends PuzzleView {
  created() {
    this.setData({ loading: false });
  }

  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      codeHero,
      codeVariants,
      codeSizes,
      codeStates,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Variants', href: '#variants' },
        { label: 'Sizes', href: '#sizes' },
        { label: 'Disabled and loading', href: '#states' },
      ],
    };
  }

  events = {
    cheer: () => toast({ message: 'Buttons wire up @press callbacks.', variant: 'success' }),
    toggleLoading: () => {
      this.setData({ loading: !this.getData().loading });
      this.refresh();
    },
  };
}

import { ViewNode } from '@magic-spells/puzzle';

ButtonDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Button' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A button with five variants, three sizes, and a loading state. Fires a' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: '@press' }),
            ]),
            new ViewNode('text', { value: 'callback; disabled and loading both block it.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
            new ViewNode(Button, {
              variant: 'primary',
              press: ((this.__h ??= {})[0] ??= (event) => this.events.cheer(event)),
            }, [
              new ViewNode('text', { value: 'Get started' }),
            ]),
            new ViewNode(Button, {
              variant: 'outline',
              press: ((this.__h ??= {})[1] ??= (event) => this.events.cheer(event)),
            }, [
              new ViewNode('text', { value: 'Learn more' }),
            ]),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Requires the pieces.css tokens merged into your app styles (see Introduction).' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'variants',
            title: 'Variants',
            code: __d.codeVariants,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(Button, {
                variant: 'primary',
                press: ((this.__h ??= {})[2] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Primary' }),
              ]),
              new ViewNode(Button, {
                variant: 'secondary',
                press: ((this.__h ??= {})[3] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Secondary' }),
              ]),
              new ViewNode(Button, {
                variant: 'outline',
                press: ((this.__h ??= {})[4] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Outline' }),
              ]),
              new ViewNode(Button, {
                variant: 'ghost',
                press: ((this.__h ??= {})[5] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Ghost' }),
              ]),
              new ViewNode(Button, {
                variant: 'destructive',
                press: ((this.__h ??= {})[6] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Destructive' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'sizes',
            title: 'Sizes',
            code: __d.codeSizes,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(Button, {
                size: 'sm',
                press: ((this.__h ??= {})[7] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Small' }),
              ]),
              new ViewNode(Button, {
                size: 'md',
                press: ((this.__h ??= {})[8] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Medium' }),
              ]),
              new ViewNode(Button, {
                size: 'lg',
                press: ((this.__h ??= {})[9] ??= (event) => this.events.cheer(event)),
              }, [
                new ViewNode('text', { value: 'Large' }),
              ]),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'states',
            title: 'Disabled and loading',
            code: __d.codeStates,
          }, [
            new ViewNode('div', { class: 'flex flex-wrap items-center justify-center gap-3' }, [
              new ViewNode(Button, { disabled: true }, [
                new ViewNode('text', { value: 'Disabled' }),
              ]),
              new ViewNode(Button, {
                variant: 'primary',
                loading: __d.loading,
              }, [
                new ViewNode('text', { value: 'Save changes' }),
              ]),
              new ViewNode(Button, {
                variant: 'outline',
                press: ((this.__h ??= {})[10] ??= (event) => this.events.toggleLoading(event)),
              }, [
                new ViewNode('text', { value: 'Toggle loading' }),
              ]),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
