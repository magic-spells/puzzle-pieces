//   { title: 'Delivery attempt failed', time: '2h ago',
//     description: 'No one was available.', status: 'danger' },
// ];`;

const codeStatus = `<!-- status tints the dot: 'default' | 'brand' | 'success' |
     'danger' | 'muted' (omit for 'default'). -->
<Timeline items={ [
  { title: 'Default event', time: 'Just now', status: 'default' },
  { title: 'Brand highlight', time: '5m ago', status: 'brand' },
  { title: 'Completed step', time: '1h ago', status: 'success' },
  { title: 'Something went wrong', time: '3h ago', status: 'danger' },
  { title: 'Muted / low priority', time: 'Yesterday', status: 'muted' },
] }/>`;

const codeIcons = `<!-- icon = a 24×24 stroke-current SVG path 'd' string; the dot
     becomes a ringed icon marker tinted by status. -->
<Timeline items={ [
  { title: 'Signed up', time: 'Mon', status: 'brand',
    icon: 'M12 5v14M5 12h14' },
  { title: 'Invited teammates', time: 'Tue', status: 'default',
    icon: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z' },
  { title: 'First project shipped', time: 'Fri', status: 'success',
    icon: 'M20 6 9 17l-5-5' },
] }/>`;

const codeNumbered = `<!-- 'numbered' auto-fills each marker with its 1-based index.
     Pass a per-item 'number' to override any single one. -->
<Timeline numbered items={ [
  { title: 'Create your account', status: 'brand',
    description: 'Pick a workspace name and verify your email.' },
  { title: 'Invite your team', status: 'brand',
    description: 'Send invites by email or share a join link.' },
  { title: 'Connect a repository', status: 'brand',
    description: 'Authorize GitHub and choose the repos to track.' },
  { title: 'Ship your first build', status: 'brand',
    description: 'Push to main and watch the pipeline run.' },
] }/>`;

const codeMixed = `<!-- Marker precedence is icon > number > dot, so an explicit
     'icon' opts one step out of numbering — the finished step shows a
     checkmark while the remaining steps keep their 2 / 3 digits. -->
<Timeline numbered items={ [
  { title: 'Account created', time: 'Done', status: 'success',
    description: 'Workspace verified and ready.',
    icon: 'M20 6 9 17l-5-5' },
  { title: 'Invite your team', status: 'brand',
    description: 'Send invites by email or share a join link.' },
  { title: 'Connect a repository',
    description: 'Authorize GitHub and choose the repos to track.' },
] }/>`;

const codeCompact = `<!-- Omit description for a dense title + time feed. -->
<Timeline items={ [
  { title: 'Build queued', time: '12:00' },
  { title: 'Build running', time: '12:01', status: 'brand' },
  { title: 'Tests passed', time: '12:04', status: 'success' },
  { title: 'Deployed', time: '12:05', status: 'success' },
] }/>`;

export default class TimelineDoc extends PuzzleView {
  data(params, props) {
    return {
      ...this.getData(),
      installCmd,
      usageImport,
      usageMarkup,
      itemShape,
      feed,
      statusFeed,
      iconFeed,
      stepFeed,
      mixedFeed,
      compactFeed,
      codeHero,
      codeStatus,
      codeIcons,
      codeNumbered,
      codeMixed,
      codeCompact,
      toc: [
        { label: 'Installation', href: '#installation' },
        { label: 'Usage', href: '#usage' },
        { label: 'Status colors', href: '#status' },
        { label: 'With icons', href: '#icons' },
        { label: 'Numbered steps', href: '#numbered' },
        { label: 'Numbers with a completed step', href: '#mixed' },
        { label: 'Compact', href: '#compact' },
      ],
    };
  }
}

import { ViewNode } from '@magic-spells/puzzle';

TimelineDoc.prototype.render = function () {
  const __d = this.getData();
  const __f = this.ctx.formatters.getAll();

  return new ViewNode('puzzle-view', { class: 'w-full' }, [
    new ViewNode('div', { class: 'flex gap-12' }, [
      new ViewNode('article', { class: 'mx-auto w-full min-w-0 max-w-5xl' }, [
        new ViewNode('header', { class: 'mb-8' }, [
          new ViewNode('h1', { class: 'text-3xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Timeline' }),
          ]),
          new ViewNode('p', { class: 'mt-2 text-body' }, [
            new ViewNode('text', { value: 'A vertical event feed rendered from an' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'items' }),
            ]),
            new ViewNode('text', { value: 'array — a dot/connector rail with a per-item title, an optional preformatted' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1.5 py-0.5 font-mono text-[13px] text-ink' }, [
              new ViewNode('text', { value: 'time' }),
            ]),
            new ViewNode('text', { value: ', a description, and an optional status color. Purely presentational: the parent owns the data and passes times already formatted.' }),
          ]),
        ]),
        new ViewNode(ExampleBox, { code: __d.codeHero }, [
          new ViewNode('div', { class: 'w-full max-w-md' }, [
            new ViewNode(Timeline, { items: __d.feed }, []),
          ]),
        ]),
        new ViewNode('section', {
          id: 'installation',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Installation' }),
          ]),
          new ViewNode('p', { class: 'mb-3 text-sm text-body' }, [
            new ViewNode('text', { value: 'Copy the piece into your app — it compiles with your build and the code is yours:' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.installCmd }, []),
          new ViewNode('p', { class: 'mt-3 text-sm text-muted' }, [
            new ViewNode('text', { value: 'Each item is' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink' }, [
              new ViewNode('text', { value: String(__d.itemShape) }),
            ]),
            new ViewNode('text', { value: '. The last item drops its connector automatically. The piece never formats dates — pass' }),
            new ViewNode('code', { class: 'rounded bg-surface-sunken px-1 py-0.5 font-mono text-[12px] text-ink' }, [
              new ViewNode('text', { value: 'time' }),
            ]),
            new ViewNode('text', { value: 'as a ready-to-display string.' }),
          ]),
        ]),
        new ViewNode('section', {
          id: 'usage',
          class: 'mt-12 scroll-mt-20',
        }, [
          new ViewNode('h2', { class: 'mb-4 text-xl font-semibold tracking-tight text-ink' }, [
            new ViewNode('text', { value: 'Usage' }),
          ]),
          new ViewNode(CodeBlock, { code: __d.usageImport }, []),
          new ViewNode(CodeBlock, {
            code: __d.usageMarkup,
            class: 'mt-3',
          }, []),
        ]),
        new ViewNode('div', { class: 'mt-12 space-y-12' }, [
          new ViewNode(ExampleBox, {
            id: 'status',
            title: 'Status colors',
            code: __d.codeStatus,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Timeline, { items: __d.statusFeed }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'icons',
            title: 'With icons',
            code: __d.codeIcons,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Timeline, { items: __d.iconFeed }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'numbered',
            title: 'Numbered steps',
            code: __d.codeNumbered,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Timeline, {
                items: __d.stepFeed,
                numbered: true,
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'mixed',
            title: 'Numbers with a completed step',
            code: __d.codeMixed,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Timeline, {
                items: __d.mixedFeed,
                numbered: true,
              }, []),
            ]),
          ]),
          new ViewNode(ExampleBox, {
            id: 'compact',
            title: 'Compact',
            code: __d.codeCompact,
          }, [
            new ViewNode('div', { class: 'w-full max-w-md' }, [
              new ViewNode(Timeline, { items: __d.compactFeed }, []),
            ]),
          ]),
        ]),
      ]),
      new ViewNode(Toc, {
        class: 'sticky top-24 hidden h-fit w-48 shrink-0 self-start xl:block',
        items: __d.toc,
      }, []),
    ]),
  ]);
};
