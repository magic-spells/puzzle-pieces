const usageImport = `import Kanban from '@/components/ui/Kanban.pzl';`;
const usageMarkup = `<Kanban columns={ columns } @move={ onMove } label="Sprint board"/>`;

const codeHero = `const columns = [
  { id: 'todo', title: 'To do', cards: [
    { id: 'c1', title: 'Design empty states', badge: 'Design', assignee: 'Ada Lovelace' },
    { id: 'c2', title: 'Fix drag on Safari', badge: 'Bug', badgeVariant: 'danger', meta: 'Due Fri' },
  ] },
  { id: 'doing', title: 'In progress', cards: [
    { id: 'c3', title: 'Ship keyboard DnD', badge: 'a11y', badgeVariant: 'brand', assignee: 'Grace Hopper' },
  ] },
  { id: 'done', title: 'Done', cards: [
    { id: 'c4', title: 'Token audit', meta: 'Merged' },
  ] },
];

<Kanban columns={ columns } @move={ onMove } label="Sprint board"/>

// toIndex is the position in the DESTINATION column AFTER the card is removed
// from its source — remove-then-insert and you match what the user dropped on.
events = {
  // @move forwards ONE payload object — destructure the move details from it.
  onMove: ({ cardId, toColumnId, toIndex }) => {
    const cols = this.getData().board.map((c) => ({ ...c, cards: c.cards.slice() }));
    let card = null;
    for (const c of cols) {
      const i = c.cards.findIndex((k) => k.id === cardId);
      if (i !== -1) { card = c.cards.splice(i, 1)[0]; break; }
    }
    cols.find((c) => c.id === toColumnId).cards.splice(toIndex, 0, card);
    this.setData({ board: cols });
    this.refresh();
  },
};`;

const codeData = `columns: [
  {
    id: 'todo',              // stable column id
    title: 'To do',
    cards: [
      {
        id: 'c1',            // board-unique card id
        title: 'Card title',
        badge: 'Bug',        // optional chip text
        badgeVariant: 'danger', // default | brand | danger | outline
        meta: 'Due Fri',     // optional secondary line
        assignee: 'Ada Lovelace', // optional → initials disc
      },
    ],
  },
]`;

const codeDisabled = `// disabled blocks every drag + keyboard move; cards stay focusable and readable.
<Kanban columns={ columns } disabled label="Read-only board"/>`;

const INITIAL_BOARD = [
  {
    id: 'todo',
    title: 'To do',
    cards: [
      { id: 'c1', title: 'Design empty states', badge: 'Design', assignee: 'Ada Lovelace' },
      { id: 'c2', title: 'Fix drag on Safari', badge: 'Bug', badgeVariant: 'danger', meta: 'Due Fri' },
