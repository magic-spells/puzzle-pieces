  },
  {
    title: 'First project shipped',
    time: 'Fri',
    description: 'Deployed to production.',
    status: 'success',
    icon: 'M20 6 9 17l-5-5',
  },
];

// `numbered` fills each marker with its 1-based index — no per-item number needed.
const stepFeed = [
  {
    title: 'Create your account',
    description: 'Pick a workspace name and verify your email address.',
    status: 'brand',
  },
  {
    title: 'Invite your team',
